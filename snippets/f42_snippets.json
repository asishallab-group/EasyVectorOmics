      "                   kernel_sigma, kernel_cutoff, y_out, workspace_weights, workspace_values, mask_in)"
    ],
    "description": "Call loess_smooth_2d subroutine in Fortran"
  },
  "R call to loess_smooth_2d_r": {
    "prefix": "f42:R_loess",
    "body": [
      "result <- .Fortran(\"loess_smooth_2d_r\",",
      "  n_total = as.integer(${1:n_total}),",
      "  n_target = as.integer(${2:n_target}),",
      "  x_ref = as.double(${3:x_ref}),",
      "  y_ref = as.double(${4:y_ref}),",
      "  indices_used = as.integer(${5:indices_used}),",
      "  x_query = as.double(${6:x_query}),",
      "  kernel_sigma = as.double(${7:kernel_sigma}),",
      "  kernel_cutoff = as.double(${8:kernel_cutoff}),",
      "  y_out = as.double(${9:y_out}),",
      "  workspace_weights = as.double(${10:workspace_weights}),",
      "  workspace_values = as.double(${11:workspace_values}),",
      "  mask_in = as.logical(${12:mask_in}))"
    ],
    "description": "Call loess_smooth_2d_r Fortran function from R (univariate, with mask)"
  },
  "Python call to loess_smooth_2d_c": {
    "prefix": "f42:py_loess",
    "body": [
	  "lib.loess_smooth_2d_c.argtypes = [",
