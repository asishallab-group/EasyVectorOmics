{

    "Parallel Loop": {
    "prefix": "f42:do-parallel",
    "body": [
        "integer :: ${1:i}",
        "integer :: ${2:N}",
        "integer :: start_${1:i}, end_${1:i}",
        "",
        "${2:N} = ${3:10}",
        "",
        "! ----------------------",
        "! START OF PARALLEL LOOP",
        "! ----------------------",
        "#ifdef USE_COARRAY",
        "  start_${1:i} = (this_image() - 1) * ${2:N} / num_images() + 1",
        "  end_${1:i}   = min(this_image() * ${2:N} / num_images(), ${2:N})",
        "  do ${1:i} = start_${1:i}, end_${1:i}",
        "",
        "#elif defined(USE_OPENMP)",
        "  !$$omp parallel do private(${1:i})",
        "  do ${1:i} = 1, ${2:N}",
        "",
        "#else",
        "  do ${1:i} = 1, ${2:N}",
        "#endif",
        "",
        "! BODY OF THE PARALLEL LOOP",
        "! -----------------------------",
        "    ${4:! Your code here}",
        "! -----------------------------",
        "! END BODY OF THE PARALLEL LOOP",
        "",
        "  end do",
        "",
        "#ifdef USE_COARRAY",
        "  sync all",
        "#endif",
        "",
        "#ifdef USE_OPENMP",
        "  !$$omp end parallel do",
        "#endif",
        "! --------------------",
        "! END OF PARALLEL LOOP",
        "! --------------------",
        "$0"
    ],
    "description": "Unified parallel loop for Coarray, OpenMP, or serial fallback with tab stops"
    },

    "Fortran call to sort_array": {
		"prefix": "f42:sort_array",
		"body": [
		"! Fortran sort - automatically selects implementation based on data type",
		"call sort_array(array, perm, stack_left, stack_right)"
		],
		"description": "Generic interface that resolves to appropriate sort function"
	},
  	"R call to sort_real": {
		"prefix": "f42:R_sort_real",
		"body": [
			"result <- .Fortran(\"sort_real_r\",",
			"                  as.double(${1:array}),",
			"                  perm = as.integer(1:${2:n}),",
			"                  stack_left = integer(${2:n}),",
			"                  stack_right = integer(${2:n}),",
			"                  n = as.integer(${2:n}))"
		],
		"description": "Call sort_real_r Fortran function from R"
	},

	"R call to sort_integer": {
		"prefix": "f42:R_sort_integer",
		"body": [
			"result <- .Fortran(\"sort_integer_r\",",
			"                  array = as.integer(${1:x}),",
			"                  perm = as.integer(1:${2:n}),",
			"                  stack_left = integer(${2:n}),",
			"                  stack_right = integer(${2:n}),",
			"                  n = as.integer(${2:n}))"
		],
		"description": "Call sort_integer_r Fortran function from R"
	},

	"R call to sort_character": {
		"prefix": "f42:R_sort_character",
		"body": [
			"# Convert strings to raw ASCII for Fortran",
			"strlen <- max(nchar(${1:strings}))",
			"char_matrix <- matrix(\" \", nrow = strlen, ncol = length(${1:strings}))",
			"for (i in seq_len(length(${1:strings}))) {",
			"  padded <- sprintf(\"%-*s\", strlen, ${1:strings}[i])",
			"  chars <- strsplit(padded, \"\")[[1]]",
			"  char_matrix[, i] <- chars",
			"}",
			"char_raw <- as.raw(sapply(as.vector(char_matrix), charToRaw))",
			"",
			"result <- .Fortran(\"sort_character_r\",",
			"                  char_data = char_raw,",
			"                  perm = as.integer(seq_len(length(${1:strings}))),",
			"                  stack_left = integer(length(${1:strings})),",
			"                  stack_right = integer(length(${1:strings})),",
			"                  n = as.integer(length(${1:strings})),",
			"                  strlen = as.integer(strlen))"
		],
		"description": "Call sort_character_r Fortran function from R"
	}

  }
  