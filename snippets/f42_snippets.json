{
    "R call to get_array_dims":{
        "prefix": "f42:R_get_array_dims",
        "body": [
            "res <- .Fortran(\"get_array_dims_r\",",
            "      filename_ascii = as.integer(ascii),",
            "      fn_len = as.integer(length(ascii)),",
            "      dims_out = dims,",
            "      ndims = ndims)",
            "res$dims_out[1:res$ndims]"
        ],
        "description": "Gets arrays dimensions from a file"
    },
    "R call to get_array_metadata_chars":{
        "prefix": "f42:R_get_array_metadata_chars",
        "body": [
            "res <- .Fortran(\"get_array_metadata_chars_r\",",
            "       filename_ascii = as.integer(ascii),",
            "       fn_len = as.integer(length(ascii))",
            "       dims_out = dims",
            "       ndims = ndims",
            "       type_code_out = typecode",
            "       clen_out = clen",
            "list(dims = res$dims_out[1:res$ndims]",
            "   type = res$type_code_out",
            "   clen = res$clen_out)"
        ],
        "description": "Gets metadata of a character array from a file"
    },
    "R call to deserialize_int_array":{
        "prefix": "f42:R_deserialize_int_array",
        "body": [
            "# Use get_array_dims to read dimensions before assigning array",
            "res <- .Fortran(\"deserialize_int_r\",",
            "    flat_arr = flat,",
            "    dims_out = dims,",
            "    ndim_out = ndim,",
            "    filename_ascii = as.integer(ascii),",
            "    fn_len = as.integer(length(ascii)),",
            "",
            "actual_dims <- res$dims_out[1:res$ndim_out]",
            "array(res$flat_arr[1:prod(actual_dims)], dim = actual_dims)"
        ],
        "description": "Deserilizes an integer array."
    },
    "R call to deserialize_real_array":{
        "prefix": "f42:R_deserialize_real_array",
        "body": [
            "# Use get_array_dims to read dimensions before assigning array",
            "res <- .Fortran(\"deserialize_real_r\",",
            "    flat_arr = flat,",
            "    dims_out = dims,",
            "    ndim_out = ndim,",
            "    filename_ascii = as.integer(ascii),",
            "    fn_len = as.integer(length(ascii)),",
            "",
            "actual_dims <- res$dims_out[1:res$ndim_out]",
            "array(res$flat_arr[1:prod(actual_dims)], dim = actual_dims)"
        ],
        "description": "Deserilizes a real(double) array."
    },
    "R call to deserialize_char_array":{
        "prefix": "f42:R_deserialize_char_array",
        "body": [
            "# use get_array_metadata_chars first for needed variables",
            "res <- .Fortran(\"deserialize_char_flat_r\",",
            "       ascii_arr = ascii_arr,",
            "       arr_size = integer(clen * total),  # size is ignored in the Fortran code,",
            "       dims_out = actual_dims,",
            "       ndim_out = ndim,",
            "       clen_out = clen,",   
            "       filename_ascii = ascii,",
            "       fn_len = length(ascii),",
            "       ndim_actual = as.integer(length(actual_dims))",
            ")",
            "",
            "# translate ASCII back to char",
            "mat <- matrix(res$ascii_arr, nrow = clen)",
            "chars <- apply(mat, 2, function(col) rawToChar(as.raw(col[col > 0])))",
            "",
            "array(chars, dim = res$dims_out[1:res$ndim_out])"
        ],
        "description": "Deserializes a character array from a given file"
    },
