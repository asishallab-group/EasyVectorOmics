{
    "Fortran: Call mean_vector": {
        "prefix": "tox:mean_vector",
        "body": [
            "! Computes the element-wise mean of specified vectors.",
            "call mean_vector(${1:vectors}, ${2:d}, ${3:gene_indices}, ${4:num_selected}, ${5:centroid_out})",
            "$0"
        ],
        "description": "Call the core Fortran subroutine to compute a mean vector."
    },
    "Fortran: Call group_centroid": {
        "prefix": "tox:group_centroid",
        "body": [
            "! Computes centroids for multiple gene groups.",
            "call group_centroid(${1:vectors}, ${2:d}, ${3:num_genes}, ${4:gene_to_family_map}, ${5:num_families}, &",
            "                    ${6:centroid_matrix_out}, ${7:use_all_mode}, ${8:ortholog_set}, ${9:workspace_indices})",
            "$0"
        ],
        "description": "Call the core Fortran subroutine to compute group centroids."
    },
    "R: Call group_centroid_r": {
        "prefix": "tox:R_group_centroid",
        "body": [
            "result <- .Fortran(\"group_centroid_r\",",
            "    vectors = as.double(${1:vectors_matrix}),",
            "    d = as.integer(nrow(${1:vectors_matrix})),",
            "    n = as.integer(ncol(${1:vectors_matrix})),",
            "    gene_to_family_map = as.integer(${2:family_map_vector}),",
            "    num_families = as.integer(${3:num_families}),",
            "    centroid_matrix = matrix(0.0, nrow=nrow(${1:vectors_matrix}), ncol=${3:num_families}),",
            "    use_all_mode = as.logical(${4:TRUE}),",
            "    ortholog_set = as.logical(${5:ortholog_logical_vector}),",
            "    selected_indices = integer(ncol(${1:vectors_matrix})),",
            "    selected_indices_len = as.integer(ncol(${1:vectors_matrix})))",
            "$0"
        ],
        "description": "Call the group_centroid_r Fortran function from R."
    },
    "Python/C: Setup group_centroid_c": {
        "prefix": "tox:C_setup_group_centroid",
        "body": [
            "group_centroid = lib.group_centroid_c",
            "group_centroid.argtypes = [",
            "    np.ctypeslib.ndpointer(dtype=np.float64, flags=\"F_CONTIGUOUS\"), # vectors",
            "    ctypes.c_int,                                                  # d",
            "    ctypes.c_int,                                                  # n",
            "    np.ctypeslib.ndpointer(dtype=np.int32, flags=\"F_CONTIGUOUS\"),  # gene_to_family_map",
            "    ctypes.c_int,                                                  # num_families",
            "    np.ctypeslib.ndpointer(dtype=np.float64, flags=\"F_CONTIGUOUS\"), # centroid_matrix",
            "    ctypes.c_bool,                                                 # use_all_mode",
            "    np.ctypeslib.ndpointer(dtype=np.bool_, flags=\"F_CONTIGUOUS\"),   # ortholog_set",
            "    np.ctypeslib.ndpointer(dtype=np.int32, flags=\"F_CONTIGUOUS\"),  # selected_indices",
            "    ctypes.c_int                                                   # selected_indices_len",
            "]",
            "group_centroid.restype = None"
        ],
        "description": "Setup ctypes interface for the group_centroid_c function."
    }
}
