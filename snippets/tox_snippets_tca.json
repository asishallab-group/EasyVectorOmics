    "Python set up compute_edf": {
        "prefix": "tox:compute_edf_py",
        "body": [
            "def tox_compute_edf(values):",
            "    \"\"\"",
            "    Compute empirical distribution function (EDF) for an array of values.",
            "",
            "    This wrapper calls the C ABI `compute_edf_c` which sorts internally and returns",
            "    the unique values and their cumulative distribution (CDF).",
            "",
            "    Args:",
            "        values (np.ndarray): 1D array of numeric values (float64)",
            "",
            "    Returns:",
            "        dict: { 'unique': np.ndarray, 'cdf': np.ndarray, 'n_unique': int }",
            "    \"\"\"",
            "    values = np.ascontiguousarray(values, dtype=np.float64)",
            "    n_values = ctypes.c_int(values.shape[0])",
            "",
            "    # allocate output buffers (max size = n_values)",
            "    unique_values = np.empty(n_values.value, dtype=np.float64)",
            "    cdf_values = np.empty(n_values.value, dtype=np.float64)",
            "    n_unique = ctypes.c_int(0)",
            "    ierr = ctypes.c_int(0)",
            "",
            "    compute_edf_c = lib.compute_edf_c",
            "    compute_edf_c.argtypes = [",
            "        np.ctypeslib.ndpointer(dtype=np.float64, flags=\"C_CONTIGUOUS\"),  # values",
            "        ctypes.POINTER(ctypes.c_int),                                      # n_values",
            "        np.ctypeslib.ndpointer(dtype=np.float64, flags=\"C_CONTIGUOUS\"),  # unique_values",
            "        np.ctypeslib.ndpointer(dtype=np.float64, flags=\"C_CONTIGUOUS\"),  # cdf_values",
            "        ctypes.POINTER(ctypes.c_int),                                      # n_unique",
            "        ctypes.POINTER(ctypes.c_int)                                       # ierr",
            "    ]",
            "    compute_edf_c.restype = None",
            "",
            "    compute_edf_c(",
            "        values,",
            "        ctypes.byref(n_values),",
            "        unique_values,",
            "        cdf_values,",
            "        ctypes.byref(n_unique),",
            "        ctypes.byref(ierr)",
            "    )",
            "    check_err_code(ierr.value)",
            "    _readonly(unique_values, cdf_values)",
            "",
            "    return {",
            "        \"unique\": unique_values[:n_unique.value].copy(),",
            "        \"cdf\": cdf_values[:n_unique.value].copy(),",
            "        \"n_unique\": int(n_unique.value)",
            "    }",
            ""
        ],
        "description": "Python setup for compute_edf_c: convenience wrapper that returns unique values and CDF"
    },

