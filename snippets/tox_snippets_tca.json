            "        np.ctypeslib.ndpointer(dtype=np.int32, flags=\"C_CONTIGUOUS\"),   # perm",
            "        np.ctypeslib.ndpointer(dtype=np.float64, flags=\"C_CONTIGUOUS\"),  # unique_values",
            "        np.ctypeslib.ndpointer(dtype=np.float64, flags=\"C_CONTIGUOUS\"),  # cdf_values",
            "        ctypes.POINTER(ctypes.c_int),                                      # n_unique",
            "        ctypes.POINTER(ctypes.c_int)                                       # ierr",
            "    ]",
            "    compute_edf_expert_c.restype = None",
            "",
            "    compute_edf_expert_c(",
            "        values,",
            "        ctypes.byref(n_values),",
