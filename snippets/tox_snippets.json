  "R call to identify_outliers": {
    "prefix": "tox:R_identify_outliers_r",
    "body": [
      "n_genes <- as.integer(${1:n_genes})",
      "rdi <- as.double(${2:rdi})",
      "sorted_rdi <- double(n_genes)",
