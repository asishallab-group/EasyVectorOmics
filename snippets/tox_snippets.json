        "call normalize_by_std_dev_r(n_genes, n_tissues, input_matrix, output_matrix)"
      ],
      "description": "Invoke normalization by standard deviation"
    },
    
    "Call to quantile_normalization": {
      "prefix": "tox:norm_quantile",
