{
    "Call to normalize_by_std_dev": {
      "prefix": "tox:normalize_by_std_dev",
      "body": [
        "integer :: n_genes, n_tissues",
        "real*8, allocatable :: input_matrix(:), output_matrix(:)",
        "integer :: i",
        "",
        "! Example: 3 genes x 2 tissues",
        "n_genes = 3",
        "n_tissues = 2",
        "",
        "allocate(input_matrix(n_genes * n_tissues))",
        "allocate(output_matrix(n_genes * n_tissues))",
        "",
        "! Fill example input (column-major: tissue1: g1,g2,g3, then tissue2: g1,g2,g3)",
        "input_matrix = [1.0d0, 2.0d0, 3.0d0, 4.0d0, 5.0d0, 6.0d0]",
        "",
        "! Call the subroutine",
        "call normalize_by_std_dev(n_genes, n_tissues, input_matrix, output_matrix)",
        "",
        "print *, \"Normalized values:\"",
        "do i = 1, n_genes * n_tissues",
        "  print *, output_matrix(i)",
        "end do"
      ],
      "description": "Example usage of normalize_by_std_dev subroutine with small test matrix"
    },
