            "                  d = d, ",
            "                  n = n, ",
            "                  kd_ix = kd_ix, ",
            "                  dim_order = as.integer(dim_order), ",
            "                  work = work, ",
            "                  subarray = subarray, ",
            "                  perm = perm, ",
            "                  stack_left = stack_left, ",
            "                  stack_right = stack_right,",
            "                  ierr = ierr)",
            "  check_err_code(res$ierr)",
