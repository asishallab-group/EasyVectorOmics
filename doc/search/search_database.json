Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_points Number of reference points real(kind=c_double), intent(in), dimension(n_points), target :: x_star Mean-expression reference points integer(kind=c_int), intent(in), target :: n_genes_S Number of genes in the current study real(kind=c_double), intent(in), dimension(n_genes_S), target :: mean_S Per-gene mean expression values integer(kind=c_int), intent(in), target :: n_reps_S Number of biological replicates in the study real(kind=c_double), intent(in), dimension(n_reps_S, n_genes_S), target :: resid_S Matrix of signed residuals real(kind=c_double), intent(out), dimension(n_reps_S, n_neighbors, n_points), target :: neighborhood_residuals Collection of residual vectors for each neighborhood integer(kind=c_int), intent(out), dimension(n_neighbors, n_points), target :: neighborhood_indices Indices of selected neighborhood genes integer(kind=c_int), intent(in), target :: n_neighbors Number of neighbors integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/construct_neighborhoods_c.html"},{"title":"serialize_logical_nd_C – TensorOmics","text":"subroutine serialize_logical_nd_C(arr, dims, ndim, filename_raw, fn_len, ierr) bind(C, name=\"serialize_logical_nd_C\") Uses tox_conversions tox_errors iso_c_binding f42_serialize_logical iso_fortran_env C binding for the subroutine to serialize a flat logical array to a binary file. Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: arr (product(dims)) Pointer to the flat logical array integer(kind=c_int), intent(in), target :: dims (ndim) Dimensions of the array integer(kind=c_int), intent(in), target :: ndim Number of dimensions character(kind=c_char, len=1), intent(in), target :: filename_raw (fn_len) Array of raw bytes characters representing the filename integer(kind=c_int), intent(in), target :: fn_len Length of the filename array integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/serialize_logical_nd_c.html"},{"title":"create_zip_archive_c – TensorOmics","text":"subroutine create_zip_archive_c(zip_filename, zip_len, keys, keys_len, keys_count, filenames, filenames_len, filenames_count, ierr) bind(C, name=\"create_zip_archive_c\") Uses tox_conversions tox_archive tox_errors iso_c_binding iso_fortran_env C binding for generic archive creation with arrays of keys and filenames Arguments Type Intent Optional Attributes Name character(kind=c_char, len=1), intent(in), target :: zip_filename (zip_len) Zip Filename as c_chars integer(kind=c_int), intent(in), target :: zip_len Length of the zip filename character(kind=c_char, len=1), intent(in), target :: keys (keys_len,keys_count) Keys as c_chars integer(kind=c_int), intent(in), target :: keys_len lengths of the keys integer(kind=c_int), intent(in), target :: keys_count number of keys character(kind=c_char, len=1), intent(in), target :: filenames (filenames_len,filenames_count) Filenames as c_chars integer(kind=c_int), intent(in), target :: filenames_len Length of the filenames integer(kind=c_int), intent(in), target :: filenames_count Number of files integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/create_zip_archive_c.html"},{"title":"extract_zip_archive_c – TensorOmics","text":"subroutine extract_zip_archive_c(zip_filename, filename_len, ierr) bind(C, name=\"extract_zip_archive_c\") Uses tox_conversions tox_archive tox_errors iso_c_binding iso_fortran_env C binding for extract_zip_archive - can be called directly from Python via ctypes Arguments Type Intent Optional Attributes Name character(kind=c_char, len=1), intent(in), target :: zip_filename (filename_len) Zip filename length integer(kind=c_int), intent(in), target :: filename_len Length of the filename integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/extract_zip_archive_c.html"},{"title":"serialize_int_nd_C – TensorOmics","text":"subroutine serialize_int_nd_C(arr, dims, ndim, filename_raw, fn_len, ierr) bind(C, name=\"serialize_int_nd_C\") Uses tox_conversions tox_errors iso_c_binding iso_fortran_env f42_serialize_int C binding for the subroutine to serialize a flat integer array to a binary file. Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: arr (product(dims)) Pointer to the flat integer array integer(kind=c_int), intent(in), target :: dims (ndim) Dimensions of the array integer(kind=c_int), intent(in), target :: ndim Number of dimensions character(kind=c_char, len=1), intent(in), target :: filename_raw (fn_len) Array of ASCII characters representing the filename integer(kind=c_int), intent(in), target :: fn_len Length of the filename array integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/serialize_int_nd_c.html"},{"title":"detect_neofunctionalization_c – TensorOmics","text":"pure subroutine detect_neofunctionalization_c(ancestors, n_families, genes, n_axes, gene_to_fam, n_genes, thresholds, neofunc, ierr) bind(C, name=\"detect_neofunctionalization_c\") Uses tox_errors tox_conversions tox_paralog_analysis iso_c_binding C-compatible wrapper for detect_neofunctionalization Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_axes, n_families), target :: ancestors integer(kind=c_int), intent(in), target :: n_families real(kind=c_double), intent(in), dimension(n_axes, n_genes), target :: genes integer(kind=c_int), intent(in), target :: n_axes integer(kind=c_int), intent(in), dimension(n_genes), target :: gene_to_fam integer(kind=c_int), intent(in), target :: n_genes real(kind=c_double), intent(in), dimension(n_axes), target :: thresholds integer(kind=c_int), intent(out), dimension(n_genes, n_axes), target :: neofunc integer(kind=c_int), intent(out), target :: ierr","tags":"","url":"proc/detect_neofunctionalization_c.html"},{"title":"detect_dosage_effect_c – TensorOmics","text":"pure subroutine detect_dosage_effect_c(ancestor, genes, n_genes, n_dims, filtered_paralogs_mask, n_mask_chunks, n_results, max_subset_size, work_arr_paralog_subsets, n_paralog_subsets, active_mask, temp_paralog_vector, max_angle, gain_gamma, ierr) bind(C, name=\"detect_dosage_effect_c\") Uses tox_errors tox_paralog_analysis iso_c_binding C-compatible wrapper for detect_dosage_effect Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_dims), target :: ancestor expression vector of ancestral ortholog real(kind=c_double), intent(in), dimension(n_dims, n_genes), target :: genes expression vectors of genes integer(kind=c_int), intent(in), target :: n_genes number of vectors in genes integer(kind=c_int), intent(in), target :: n_dims size of ancestor vector and vectors in genes integer(kind=c_int), intent(in), dimension(n_mask_chunks), target :: filtered_paralogs_mask bit mask with genes' indices kept by pattern set to 1, else 0. Use filter_paralogs_by_pattern for its calculation integer(kind=c_int), intent(in), target :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes. Use subroutine mask_chunk_count for calculation integer(kind=c_int), intent(out), target :: n_results number of resulting subsets. They are stored as the first n_results elements of work_arr_paralog_subsets integer(kind=c_int), intent(in), target :: max_subset_size maximum subset size of checked gene subsets. USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=c_int), intent(out), dimension(n_mask_chunks, n_paralog_subsets), target :: work_arr_paralog_subsets working array to hold bitmask encoded subsets for detection. Note Each bitmask is built of 32 bit chunks. (n_genes + 31) / 32 is equivalent to ceil(n_genes / 32) and represents the number of chunks integer(kind=c_int), intent(in), target :: n_paralog_subsets number of gene subsets that can be stored in work_arr_paralog_subsets . USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=c_int), intent(out), dimension(n_mask_chunks), target :: active_mask working array to hold the extended subsets real(kind=c_double), intent(out), dimension(n_dims), target :: temp_paralog_vector vector used for pruning subsets real(kind=c_double), intent(in), target :: max_angle in dosage mode maximum angle in radians 0<=angle<=Pi that a subset candidate must not exceed, otherwise pruned, default is Pi real(kind=c_double), intent(in), target :: gain_gamma positive magnitude gain for dosage effect, default 0.1 integer(kind=c_int), intent(out), target :: ierr error code","tags":"","url":"proc/detect_dosage_effect_c.html"},{"title":"detect_subfunctionalization_c – TensorOmics","text":"pure subroutine detect_subfunctionalization_c(ancestor, genes, n_genes, n_dims, rdi_threshold, filtered_paralogs_mask, n_mask_chunks, n_results, max_subset_size, work_arr_paralog_subsets, n_paralog_subsets, active_mask, temp_paralog_vector, paralog_norms, sorted_paralog_norms_perm, temp_work_array, ierr) bind(C, name=\"detect_subfunctionalization_c\") Uses tox_errors tox_paralog_analysis iso_c_binding C-compatible wrapper for detect_subfunctionalization Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_dims), target :: ancestor expression vector of ancestral ortholog real(kind=c_double), intent(in), dimension(n_dims, n_genes), target :: genes expression vectors of genes integer(kind=c_int), intent(in), target :: n_genes number of vectors in genes integer(kind=c_int), intent(in), target :: n_dims size of ancestor vector and vectors in genes real(kind=c_double), intent(in), target :: rdi_threshold max allowed residual distance from ancestor integer(kind=c_int), intent(in), dimension(n_mask_chunks), target :: filtered_paralogs_mask bit mask with genes' indices kept by pattern set to 1, else 0. Use filter_paralogs_by_pattern for its calculation integer(kind=c_int), intent(in), target :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes. Use subroutine mask_chunk_count for calculation integer(kind=c_int), intent(out), target :: n_results number of resulting subsets. They are stored as the first n_results elements of work_arr_paralog_subsets integer(kind=c_int), intent(in), target :: max_subset_size maximum subset size of checked gene subsets. USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=c_int), intent(out), dimension(n_mask_chunks, n_paralog_subsets), target :: work_arr_paralog_subsets working array to hold bitmask encoded subsets for detection. Note Each bitmask is built of 32 bit chunks. (n_genes + 31) / 32 is equivalent to ceil(n_genes / 32) and represents the number of chunks integer(kind=c_int), intent(in), target :: n_paralog_subsets number of gene subsets that can be stored in work_arr_paralog_subsets . USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=c_int), intent(out), dimension(n_mask_chunks), target :: active_mask working array to hold the extended subsets real(kind=c_double), intent(out), dimension(n_dims), target :: temp_paralog_vector vector used for pruning subsets real(kind=c_double), intent(in), dimension(n_genes), target :: paralog_norms needed for subset pruning, holds the euclidean norms of genes (you can use the norm function from f42_utils function for this) integer(kind=c_int), intent(in), dimension(n_genes), target :: sorted_paralog_norms_perm needed for subset pruning, as the minimum norm of the genes that could extend a subset should not be lower than the subset angle to the ancestor real(kind=c_double), intent(out), dimension(n_genes), target :: temp_work_array needed for efficient check of minimum value after a certain index integer(kind=c_int), intent(out), target :: ierr error code","tags":"","url":"proc/detect_subfunctionalization_c.html"},{"title":"filter_paralogs_by_pattern_subfunctionalization_c – TensorOmics","text":"pure subroutine filter_paralogs_by_pattern_subfunctionalization_c(gene_angles, threshold, n_genes, n_families, gene_to_fam, masks, n_mask_chunks, ierr) bind(C, name=\"filter_paralogs_by_pattern_subfunctionalization_c\") Uses tox_errors tox_paralog_analysis iso_c_binding C-compatible wrapper for filter_paralogs_by_pattern_subfunctionalization Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_genes), target :: gene_angles vector, holding the angles between ancestor and genes (0<=angle<=Pi) real(kind=c_double), intent(in), target :: threshold filter threshold integer(kind=c_int), intent(in), target :: n_genes number of genes integer(kind=c_int), intent(in), target :: n_families number of families integer(kind=c_int), intent(in), dimension(n_genes), target :: gene_to_fam a mapping of gene index to family index, so gene i is related to gene_angles(i) and part of family j=gene_to_fam(i) . integer(kind=c_int), intent(out), dimension(n_mask_chunks, n_families), target :: masks bit mask that will have indices of genes kept by pattern set to 1, else 0 integer(kind=c_int), intent(in), target :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=c_int), intent(out), target :: ierr error code","tags":"","url":"proc/filter_paralogs_by_pattern_subfunctionalization_c.html"},{"title":"filter_paralogs_by_pattern_dosage_effect_c – TensorOmics","text":"pure subroutine filter_paralogs_by_pattern_dosage_effect_c(gene_angles, threshold, n_genes, n_families, gene_to_fam, masks, n_mask_chunks, ierr) bind(C, name=\"filter_paralogs_by_pattern_dosage_effect\") Uses tox_errors tox_paralog_analysis iso_c_binding C-compatible wrapper for filter_paralogs_by_pattern_dosage_effect Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_genes), target :: gene_angles vector, holding the angles between ancestor and genes (0<=angle<=Pi) real(kind=c_double), intent(in), target :: threshold filter threshold integer(kind=c_int), intent(in), target :: n_genes number of genes integer(kind=c_int), intent(in), target :: n_families number of families integer(kind=c_int), intent(in), dimension(n_genes), target :: gene_to_fam a mapping of gene index to family index, so gene i is related to gene_angles(i) and part of family j=gene_to_fam(i) . integer(kind=c_int), intent(out), dimension(n_mask_chunks, n_families), target :: masks bit mask that will have indices of genes kept by pattern set to 1, else 0 integer(kind=c_int), intent(in), target :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=c_int), intent(out), target :: ierr error code","tags":"","url":"proc/filter_paralogs_by_pattern_dosage_effect_c.html"},{"title":"calc_work_arr_paralog_subsets_size_c – TensorOmics","text":"pure subroutine calc_work_arr_paralog_subsets_size_c(max_subset_size, n_genes, work_array_size, filtered_paralogs_mask, n_mask_chunks, ierr) bind(C, name=\"calc_work_arr_paralog_subsets_size\") Uses tox_errors tox_paralog_analysis iso_c_binding C-compatible wrapper for calc_work_arr_paralog_subsets_size Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(inout), target :: max_subset_size maximum size that a subset must not exceed. Warning If the desired size is too large and leads to an integer overflow, max_subset_size will be set to the maximum valid size. Also, size will be set to number of paralogs in filtered_paralogs_mask if larger. integer(kind=c_int), intent(in), target :: n_genes number of paralogs integer(kind=c_int), intent(out), target :: work_array_size The calculated needed work array size in absolute worst case scenario. Look into source for details. integer(kind=c_int), intent(in), dimension(n_mask_chunks), target :: filtered_paralogs_mask Output mask with all paralogs disabled that did not pass the filter integer(kind=c_int), intent(in), target :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/calc_work_arr_paralog_subsets_size_c.html"},{"title":"mask_chunk_count_c – TensorOmics","text":"pure subroutine mask_chunk_count_c(n_genes, count, ierr) bind(C, name=\"mask_chunk_count_c\") Uses tox_errors tox_paralog_analysis iso_c_binding C-compatible wrapper for mask_chunk_count Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_genes number of paralogs integer(kind=c_int), intent(out), target :: count number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/mask_chunk_count_c.html"},{"title":"mask_check_state_c – TensorOmics","text":"pure subroutine mask_check_state_c(bit_mask, n_mask_chunks, i_gene, state, ierr) bind(C, name=\"mask_check_state_c\") Uses tox_errors tox_conversions tox_paralog_analysis iso_c_binding C-compatible wrapper for mask_check_state Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), dimension(n_mask_chunks), target :: bit_mask chunked mask to mark active paralogs integer(kind=c_int), intent(in), target :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=c_int), intent(in), target :: i_gene index of paralog to be checked, starting with 0 integer(kind=c_int), intent(out), target :: state check result integer(kind=c_int), intent(out), target :: ierr","tags":"","url":"proc/mask_check_state_c.html"},{"title":"compute_all_contributions_c – TensorOmics","text":"pure subroutine compute_all_contributions_c(trajectories, n_factors, n_samples, n_timepoints, factor_indices, n_selected_factors, dependent_indices, n_selected_dependents, mode, local_contributions, total_contributions, temp_factors, temp_dependent, ierr) bind(C, name=\"compute_all_contributions_c\") Uses tox_errors iso_fortran_env tox_trajectory_contribution_analysis iso_c_binding C-compatible wrapper for compute_all_contributions Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_factors, n_samples, n_timepoints), target :: trajectories trajectories array: (n_factors, n_samples, n_timepoints) integer(kind=c_int), intent(in), target :: n_factors number of factors integer(kind=c_int), intent(in), target :: n_samples number of samples integer(kind=c_int), intent(in), target :: n_timepoints number of timepoints integer(kind=c_int), intent(in), dimension(n_selected_factors), target :: factor_indices indices of factors to compute the contributions for integer(kind=c_int), intent(in), target :: n_selected_factors number of selected factors in factor_indices integer(kind=c_int), intent(in), dimension(n_selected_dependents), target :: dependent_indices indices of dependents to compute the contributions for integer(kind=c_int), intent(in), target :: n_selected_dependents number of selected dependents in dependent_indices character(kind=c_char, len=1), intent(in), dimension(*), target :: mode Baseline mode: \"raw\", \"min\", \"mean\" real(kind=c_double), intent(out), dimension(n_timepoints, n_selected_factors, n_selected_dependents, n_samples), target :: local_contributions Per-timepoint contributions per sample-dependent-factor combination real(kind=c_double), intent(out), dimension(n_selected_factors, n_selected_dependents, n_samples), target :: total_contributions Total contribution ( sum(local_contributions) ) per sample-dependent-factor combination real(kind=c_double), intent(out), dimension(n_timepoints, n_selected_factors), target :: temp_factors Working array to hold the currently handled sample's factors in contiguous memory real(kind=c_double), intent(out), dimension(n_timepoints), target :: temp_dependent Working array to hold the currently handled dependent in contiguous memory integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/compute_all_contributions_c.html"},{"title":"compute_contributions_c – TensorOmics","text":