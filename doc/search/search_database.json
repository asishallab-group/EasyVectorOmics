lobal JSD real(kind=c_double), intent(out), dimension(n_points), target :: weights Weights real(kind=c_double), intent(out), dimension(n_points,n_bins), target :: pmf_S1 PMF S1 real(kind=c_double), intent(out), dimension(n_points,n_bins), target :: pmf_S2 PMF S2 integer(kind=c_int), intent(out), dimension(n_points,n_bins), target :: tmp_counts Temporary histogram counts integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/fjct_compute_jsd_expert_c.html"},{"title":"fjct_compute_contribution_scores_c – TensorOmics","text":"pure subroutine fjct_compute_contribution_scores_c(global_js_divergences, total_included_n_reps_per_f, k_families, support_weights, contribution_scores, ierr) bind(C, name=\"fjct_compute_contribution_scores_c\") Uses tox_data_integration tox_errors iso_c_binding C-compatible wrapper for fjct_compute_contribution_scores Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(k_families), target :: global_js_divergences Per-sub-neighborhood weighted global JSD integer(kind=c_int), intent(in), dimension(k_families), target :: total_included_n_reps_per_f Per-sub-neighborhood total_included_n_reps integer(kind=c_int), intent(in), target :: k_families Number of sub-neighborhoods analyzed real(kind=c_double), intent(out), dimension(k_families), target :: support_weights Per-sub-neighborhood calculated support weight (ratio between its total_included_n_reps and sum(total_included_n_reps_per_f) ,\nzero if there were no replicates included at all) real(kind=c_double), intent(out), dimension(k_families), target :: contribution_scores Per-sub-neighborhood calculated contribution\n( ) integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/fjct_compute_contribution_scores_c.html"},{"title":"determine_shared_residual_range_expert_c – TensorOmics","text":"pure subroutine determine_shared_residual_range_expert_c(abs_residual_pool, abs_residual_pool_perm, pool_size, residual_r