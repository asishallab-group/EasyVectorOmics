indices of construct_neighborhoods integer(kind=c_int), intent(in), target :: n_reps_S1 Number of replicates in study 1 integer(kind=c_int), intent(in), target :: n_reps_S2 Number of replicates in study 2 integer(kind=c_int), intent(in), target :: n_neighbors Number of neighbors in the studies integer(kind=c_int), intent(in), target :: n_points Number of reference points in the studies integer(kind=c_int), intent(in), target :: n_bins Number of equally sized histogram bins used for the studies in build_residual_histograms real(kind=c_double), intent(in), target :: shared_residual_range Computed residual range for both studies, from determine_shared_residual_range real(kind=c_double), intent(out), dimension(n_points), target :: js_divergences Jensen-Shannon divergence per reference point, computed for studies S1 and S2 integer(kind=c_int), intent(out), dimension(n_points), target :: included_n_reps_S1 Count of non-NaN residuals (included ones) in study 1 integer(kind=c_int), intent(out), dimension(n_points), target :: included_n_reps_S2 Count of non-NaN residuals (included ones) in study 2 integer(kind=c_int), intent(out), target :: total_included_n_reps Total number of included replicates from both studies real(kind=c_double), intent(out), target :: global_js_divergence Weighted global Jensen-Shannon divergence real(kind=c_double), intent(out), dimension(n_points), target :: weights Weights used for calculating the global weighted Jensen-Shannon divergence integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/fjct_compute_jsd_c.html"},{"title":"fjct_compute_jsd_expert_c – TensorOmics","text":"pure subroutine fjct_compute_jsd_expert_c(neighborhood_residuals_S1, neighborhood_residuals_S2, n_reps_S1, n_reps_S2, n_neighbors, n_points, neighbor_mask_S1, neighbor_mask_S2, n_bins, shared_residual_range, js_divergences, included_n_reps_S1, included_n_reps_S2, total_included_n_reps, global_js_divergence, weights, pmf_S1, pmf_S2, tmp_counts, ierr)