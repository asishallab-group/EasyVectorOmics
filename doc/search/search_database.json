ted_threshold_expert_c.html"},{"title":"calc_integrated_threshold_C – TensorOmics","text":"subroutine calc_integrated_threshold_C(contributions, n_samples, percentile_val, threshold, ierr) bind(C, name=\"calc_integrated_threshold_C\") Uses tox_trajectory_contribution_analysis_outlier_detection iso_c_binding tox_errors C wrapper for calc_integrated_threshold_alloc (with internal allocations)\nInput: contributions(n_samples) - one integrated contribution per sample Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in) :: contributions (n_samples) 1D array of integrated contributions integer(kind=c_int), intent(in), value :: n_samples Number of samples real(kind=c_double), intent(in), value :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=c_double), intent(out) :: threshold Scalar threshold value integer(kind=c_int), intent(out) :: ierr Error code","tags":"","url":"proc/calc_integrated_threshold_c.html"},{"title":"detect_outliers_integrated_expert_C – TensorOmics","text":"subroutine detect_outliers_integrated_expert_C(contributions, n_samples, threshold, outlier_mask, ierr) bind(C, name=\"detect_outliers_integrated_expert_C\") Uses iso_c_binding tox_conversions tox_trajectory_contribution_analysis_outlier_detection tox_errors C wrapper for detect_outliers_integrated\nIdentifies outlier samples based on integrated contributions Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in) :: contributions (n_samples) Array of integrated contributions integer(kind=c_int), intent(in), value :: n_samples Number of samples real(kind=c_double), intent(in), value :: threshold Scalar threshold value for outlier detection integer(kind=c_int), intent(out) :: outlier_mask (n_samples) 1D array indicating outlier samples integer(kind=c_int), intent(out) :: ierr Error code","tags":"","url":"proc/detect_outliers_integrated_expert_c.html"},{"title":"detect_outliers_spike_expert_C – TensorOmics","text":"subroutine detect_o