t(out), target :: ierr error code","tags":"","url":"proc/omics_field_rap_projection_c.html"},{"title":"relative_axes_changes_from_shift_vector_c – TensorOmics","text":"pure subroutine relative_axes_changes_from_shift_vector_c(vec, n_axes, contributions, ierr) bind(C, name=\"relative_axes_changes_from_shift_vector_c\") Uses tox_relative_axis_plane_tools tox_errors iso_c_binding C/Python wrapper for relative_axes_changes_from_shift_vector Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_axes), target :: vec RAP-projected and normalized shift vector integer(kind=c_int), intent(in), target :: n_axes Number of axes real(kind=c_double), intent(out), dimension(n_axes), target :: contributions Fractional contribution of each axis integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/relative_axes_changes_from_shift_vector_c.html"},{"title":"relative_axes_expression_from_expression_vector_c – TensorOmics","text":"pure subroutine relative_axes_expression_from_expression_vector_c(vec, n_axes, contributions, ierr) bind(C, name=\"relative_axes_expression_from_expression_vector_c\") Uses tox_relative_axis_plane_tools tox_errors iso_c_binding C/Python wrapper for relative_axes_expression_from_expression_vector Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_axes), target :: vec RAP-projected and normalized expression vector integer(kind=c_int), intent(in), target :: n_axes Number of axes real(kind=c_double), intent(out), dimension(n_axes), target :: contributions Fractional contribution of each axis integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/relative_axes_expression_from_expression_vector_c.html"},{"title":"k_means_clustering_c – TensorOmics","text":"pure subroutine k_means_clustering_c(n_clusters, data_points, n_points, n_dims, centroids, labels, label_counts, ierr, max_iterations) bind(C, name=\"k_means_clustering_c\") Uses tox_errors tox_clustering iso_c_binding k-means clustering algorithm: Assigns each data point to one of k clusters whose centroid is clostest Recalculates the centroids using the mean of its assigned points repeat 1-2 until assignment remains unchanged Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_clusters number ( k ) of clusters real(kind=c_double), intent(in), dimension(n_dims, n_points), target :: data_points matrix with data points to cluster integer(kind=c_int), intent(in), target :: n_points number of points to cluster integer(kind=c_int), intent(in), target :: n_dims number of elements a point has real(kind=c_double), intent(inout), dimension(n_dims, n_clusters), target :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. The final values will be the final centroids of the clusters integer(kind=c_int), intent(out), dimension(n_points), target :: labels array of labels, each index corresponds to the respective point's index, so first label is first point's label. each label is the index of its related cluster -> 1<=label<=n_clusters=k integer(kind=c_int), intent(out), dimension(n_clusters), target :: label_counts holds the number of points having the respective label assigned integer(kind=c_int), intent(out), target :: ierr Error code integer(kind=c_int), intent(in), target :: max_iterations number of maximum iterations of the clustering","tags":"","url":"proc/k_means_clustering_c.html"},{"title":"cluster_factor_trajectories_k_means_c – TensorOmics","text":"pure subroutine cluster_factor_trajectories_k_means_c(n_clusters, trajectories, n_factors, n_samples, n_timepoints, centroids, labels, label_counts, ierr, max_iterations) bind(C, name=\"cluster_factor_trajectories_k_means_c\") Uses tox_errors tox_clustering iso_c_binding C-compatible wrapper for cluster_factor_trajectories_k_means Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_clusters real(kind=c_double), intent(in), dimension(n_factors, n_samples, n_timepoints), target :: trajectories integer(kind=c_int), intent(in), target :: n_factors integer(kind=c_int), intent(in), target :: n_samples integer(kind=c_int), intent(in), target :: n_timepoints real(kind=c_double), intent(inout), dimension(n_factors, n_clusters), target :: centroids integer(kind=c_int), intent(out), dimension(n_samples * n_timepoints), target :: labels integer(kind=c_int), intent(out), dimension(n_clusters), target :: label_counts integer(kind=c_int), intent(out), target :: ierr integer(kind=c_int), intent(in), target :: max_iterations","tags":"","url":"proc/cluster_factor_trajectories_k_means_c.html"},{"title":"linkage_clustering_c – TensorOmics","text":"subroutine linkage_clustering_c(distances, n_points, merge_i, merge_j, heights, cluster_sizes, method, ierr) bind(C, name=\"linkage_clustering_c\") Uses tox_errors tox_conversions tox_clustering iso_c_binding C-compatible wrapper for linkage_clustering Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(inout), dimension(n_points, n_points), target :: distances symmetric distance matrix, holding the positive distances between points. Distance of X->X is always zero. Note This subroutine operates in-place in the bottom triangle of the distance matrix and recovers it using the top triangle once done or on error.\nSo there is no need to copy an existing distance matrix, just pass the original. integer(kind=c_int), intent(in), target :: n_points number of points to cluster integer(kind=c_int), intent(out), dimension(n_points - 1), target :: merge_i holds cluster labels of the merged node pair at iteration k -> positives relate to leafs/data point indices, negatives to inner nodes integer(kind=c_int), intent(out), dimension(n_points - 1), target :: merge_j holds cluster labels of the merged node pair at iteration k -> positives relate to leafs/data point indices, negatives to inner nodes real(kind=c_double), intent(out), dimension(n_points - 1), target :: heights height of the shorter branch of the merge, e.g. if (A,B)+(C) merges to ((A,B),C), the branch to (A,B) is shorter integer(kind=c_int), intent(out), dimension(n_points - 1), target :: cluster_sizes size of cluster at iteration k character(kind=c_char, len=1), intent(in), dimension(8), target :: method used algorithm Method Value Average / UPGMA \"average\" Weighted / WPGMA \"weighted\" Ward \"ward\" integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/linkage_clustering_c.html"},{"title":"normalization_pipeline_c – TensorOmics","text":"pure subroutine normalization_pipeline_c(n_genes, n_tissues, input_matrix, buf_stddev, buf_quant, buf_avg, buf_log, temp_col, rank_means, perm, stack_left, stack_right, max_stack, group_s, group_c, n_grps, ierr) bind(C, name=\"normalization_pipeline_c\") Uses tox_normalization tox_errors iso_c_binding C/Python wrapper for normalization pipeline.\nProvides a C/Python-compatible interface to the normalization pipeline routine.\nSuitable for use with ctypes. Performs: std dev normalization, quantile normalization, replicate averaging, log2(x+1) transformation.\nFinal result is in buf_log. If fold change is needed, call calc_fchange separately. Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_genes Number of genes (rows) integer(kind=c_int), intent(in), target :: n_tissues Number of tissues (columns) real(kind=c_double), intent(in), target :: input_matrix (n_genes*n_tissues) Flattened input matrix (n_genes * n_tissues), column-major real(kind=c_double), intent(out), target :: buf_stddev (n_genes*n_tissues) Buffer for std dev normalization (n_genes * n_tissues) real(kind=c_double), intent(out), target :: buf_quant (n_genes*n_tissues) Buffer for quantile normalization (n_genes * n_tissues) real(kind=c_double), intent(out), target :: buf_avg (n_genes*n_grps) Buffer for replicate averaging (n_genes * n_grps) real(kind=c_double), intent(out), target :: buf_log (n_genes*n_grps) Buffer for log2(x+1) transformation (n_genes * n_grps) real(kind=c_double), intent(out), target :: temp_col (n_genes) Temporary column vector for sorting (n_genes) real(kind=c_double), intent(out), target :: rank_means (n_genes) Buffer for rank means (n_genes) integer(kind=c_int), intent(out), target :: perm (n_genes) Permutation vector for sorting (n_genes) integer(kind=c_int), intent(out), target :: stack_left (max_stack) Left stack for quicksort (max_stack) integer(kind=c_int), intent(out), target :: stack_right (max_stack) Right stack for quicksort (max_stack) integer(kind=c_int), intent(in), target :: max_stack Stack size for quicksort integer(kind=c_int), intent(in), target :: group_s (n_grps) Start column index for each replicate group (n_grps) integer(kind=c_int), intent(in), target :: group_c (n_grps) Number of columns per replicate group (n_grps) integer(kind=c_int), intent(in), target :: n_grps Number of replicate groups integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/normalization_pipeline_c.html"},{"title":"normalize_by_std_dev_c – TensorOmics","text":"pure subroutine normalize_by_std_dev_c(n_genes, n_tissues, input_matrix, output_matrix, ierr) bind(C, name=\"normalize_by_std_dev_c\") Uses tox_errors tox_normalization iso_c_binding C-compatible wrapper for normalize_by_std_dev Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_genes Number of genes (rows) integer(kind=c_int), intent(in), target :: n_tissues Number of tissues (columns) real(kind=c_double), intent(in), target :: input_matrix (n_genes*n_tissues) Flattened input matrix (n_genes * n_tissues) real(kind=c_double), intent(out), target :: output_matrix (n_genes*n_tissues) Output normalized matrix (same shape as input) integer(kind=c_int), intent(out), target :