x integer(kind=c_int), value :: comp integer(kind=c_int), value :: flags Return Value integer(kind=c_int) interface public  function zip_fopen(archive, fname, flags) bind(C, name=\"zip_fopen\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive character(kind=c_char, len=1), dimension(*) :: fname integer(kind=c_int), value :: flags Return Value type(c_ptr) interface public  function zip_fread(file, buf, nbytes) bind(C, name=\"zip_fread\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: file type(c_ptr), value :: buf integer(kind=c_size_t), value :: nbytes Return Value integer(kind=c_int64_t) interface public  function zip_fclose(file) bind(C, name=\"zip_fclose\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: file Return Value integer(kind=c_int) interface public  function zip_get_num_entries(archive, flags) bind(C, name=\"zip_get_num_entries\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive integer(kind=c_int), value :: flags Return Value integer(kind=c_int64_t) interface public  function zip_get_name(archive, index, flags) bind(C, name=\"zip_get_name\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive integer(kind=c_int64_t), value :: index integer(kind=c_int), value :: flags Return Value type(c_ptr) interface public  subroutine free(ptr) bind(C, name=\"free\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: ptr interface public  subroutine zip_source_free(source) bind(C, name=\"zip_source_free\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: source Subroutines public  subroutine create_zip_archive (zip_filename, keys, filenames, ierr) Creates a zip archive with generic file lists Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: zip_filename Name of the zip file to create character(len=*), intent(in) :: keys (:) Array of keys for manifest entries character(len=*), intent(in) :: filenames (:) Array of filenames to add to zip integer(kind=int32), intent(out) :: ierr Error code public  subroutine extract_zip_archive (zip_filename, keys, filenames, ierr) Extract a zip archive and return all key-value pairs from manifest Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: zip_filename Zip file to read character(len=:), intent(out), allocatable :: keys (:) Array of keys from manifest character(len=:), intent(out), allocatable :: filenames (:) Array of filenames from manifest integer(kind=int32), intent(out) :: ierr Error code public  subroutine delete_file (filename, ierr) Delete a file from the disk Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename File to delete integer(kind=int32), intent(out) :: ierr Error code public  subroutine get_zip_entry_name (zip_handle, entry_index, entry_name, ierr) Helper function to get the name of a ZIP entry Arguments Type Intent Optional Attributes Name type(c_ptr), intent(in) :: zip_handle Zip file connection integer(kind=c_int64_t), intent(in) :: entry_index Index of the entry character(len=:), intent(out), allocatable :: entry_name Name of the entry integer(kind=int32), intent(out) :: ierr Error code public  subroutine extract_file_from_zip (zip_handle, filename, ierr) Arguments Type Intent Optional Attributes Name type(c_ptr), intent(in) :: zip_handle Zip connection character(len=*), intent(in) :: filename Name of the file to extract integer(kind=int32), intent(out) :: ierr Error code public  subroutine add_data_to_zip (zip_handle, filename, data_source, data_type, ierr) Arguments Type Intent Optional Attributes Name type(c_ptr), intent(in) :: zip_handle Zip connection character(len=*), intent(in) :: filename Filename to add character(len=*), intent(in) :: data_source File path or string content integer(kind=int32), intent(in) :: data_type Type of input integer(kind=int32), intent(out) :: ierr Error code public  subroutine write_manifest (keys, filenames, manifest_filename, ierr) Write manifest from given key-value pairs Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: keys (:) Array of keys for manifest entries character(len=*), intent(in) :: filenames (:) Array of filenames for manifest entries character(len=*), intent(in) :: manifest_filename Name of the manifest file (should be manifest.txt) integer(kind=int32), intent(out) :: ierr Error code public  subroutine read_manifest_generic (manifest_filename, keys, values, ierr) Read manifest file and return key-value pairs Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: manifest_filename Filename of the manifest (should be manifest.txt) character(len=:), intent(out), allocatable :: keys (:) Array of keys from manifest character(len=:), intent(out), allocatable :: values (:) Array of values from manifest integer(kind=int32), intent(out) :: ierr Error code public  subroutine extract_and_parse_manifest (zip_handle, keys, filenames, ierr) Extract and parse the manifest file for generic key-value pairs. Arguments Type Intent Optional Attributes Name type(c_ptr), intent(in) :: zip_handle Zip file connection character(len=:), intent(out), allocatable :: keys (:) Array of keys from manifest character(len=:), intent(out), allocatable :: filenames (:) Array of filenames from manifest integer(kind=int32), intent(out) :: ierr Error code public  subroutine save_tox_data (zip_filename, ierr, gene_ids, gene_ids_file, expression, expression_file, gene_to_family, gene_to_family_file, family_ids, family_ids_file, family_centroids, family_centroids_file, shift_vectors, shift_vectors_file) Save standard tox data Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: zip_filename Zip filename integer(kind=int32), intent(out) :: ierr Error code character(len=*), intent(in), optional :: gene_ids (:) Gene ids array, will be saved if provided character(len=*), intent(in), optional :: gene_ids_file Name of the gene ids file real(kind=real64), intent(in), optional :: expression (:,:) Expression vectors array, will be saved if provided character(len=*), intent(in), optional :: expression_file Name of the expression file integer(kind=int32), intent(in), optional :: gene_to_family (:) Gene to family mapping array, will be saved if provided character(len=*), intent(in), optional :: gene_to_family_file Name of the gene to family mapping file character(len=*), intent(in), optional :: family_ids (:) Family ids array, will be saved if provided character(len=*), intent(in), optional :: family_ids_file Name of the family ids file real(kind=real64), intent(in), optional :: family_centroids (:,:) Family centroids array, will be saved if provided character(len=*), intent(in), optional :: family_centroids_file Name of the family centroids file real(kind=real64), intent(in), optional :: shift_vectors (:,:) Shift vectors array, will be saved if provided character(len=*), intent(in), optional :: shift_vectors_file Name of the shift vectors file public  subroutine read_tox_data (zip_filename, ierr, gene_ids, gene_ids_file, expression, expression_file, gene_to_family, gene_to_family_file, family_ids, family_ids_file, family_centroids, family_centroids_file, shift_vectors, shift_vectors_file) Read standard tox from a zip archive Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: zip_filename Name of the zipfile integer(kind=int32), intent(out) :: ierr Error code character(len=:), intent(out), optional, allocatable :: gene_ids (:) Gene IDs array, will be populated if provided character(len=:), intent(out), optional, allocatable :: gene_ids_file Name of the gene ids file in the zip archive real(kind=real64), intent(out), optional, allocatable :: expression (:,:) Expression vectors array, will be populated if provided character(len=:), intent(out), optional, allocatable :: expression_file Name of the expression vectors file in the zip archive integer(kind=int32), intent(out), optional, allocatable :: gene_to_family (:) Gene to family mapping array, will be populated if provided character(len=:), intent(out), optional, allocatable :: gene_to_family_file Name of the gene to family mapping file in the zip archive character(len=:), intent(out), optional, allocatable :: family_ids (:) Family IDs array, will be populated if provided character(len=:), intent(out), optional, allocatable :: family_ids_file Name of the family ids file in the zip archive real(kind=real64), intent(out), optional, allocatable :: family_centroids (:,:) Family centroids array, will be populated if provided character(len=:), intent(out), optional, allocatable :: family_centroids_file Name of the family centroids file in the zip archive real(kind=real64), intent(out), optional, allocatable :: shift_vectors (:,:) Shift vectors array, will be populated if provided character(len=:), intent(out), optional, allocatable :: shift_vectors_file Name of the shift vectors file in the zip archive","tags":"","url":"module/tox_archive.html"},{"title":"tox_data_integration – TensorOmics","text":"In multi-study omics analyses, it is often unclear whether biological replicates originating from different studies can be safely treated as sampling the same biological condition.\nEven when studies nominally target the same tissue and condition, differences in sample handling, sequencing technologies, preprocessing pipelines, or cohort,\ncomposition can introduce batch effects that are not easily detectable from mean expression levels alone. This ambiguity has direct consequences for downstream analyses in Tensor Omics. Integrating incompatible replicate sets can: distort expression spaces, affect distance-based analyses, bias machine learning models, while unnecessarily separating compatible datasets reduces statistical power. To address this, we introduce a Jensen–Shannon-Divergence based compatibility test (JSD-Comp-Test)\nthat empirically evaluates whether two sets of biological replicates exhibit comparable replicate-level variability.\nRather than comparing mean expression values, the method focuses on the distribution of signed residuals (replicate deviations from the gene-wise mean),\nconditioned on mean expression levels to account for heteroscedasticity, which is a well-known property of omics data. The goal of this issue is to define, implement, and validate this compatibility test as a diagnostic tool that can be applied prior to data integration.\nThe test is intended to support principled decisions\non whether replicate sets from different studies should be merged or treated as distinct conditions within Tensor Omics workflows. Uses safeguard iso_fortran_env Used by Descendants: tox_data_integration_jsd tox_data_integration_per_family tox_data_integration_preprocessing tox_data_integration_stats Interfaces public        interface compute_gene_means public pure module subroutine compute_gene_means(n_genes, n_reps, expr, means, ierr) Compute per-gene mean expression, ignoring NaN values Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes in the study integer(kind=int32), intent(in) :: n_reps Number of biological replicates in the study real(kind=real64), intent(in) :: expr (n_reps,n_genes) Expression matrix real(kind=real64), intent(out) :: means (n_genes) Per-gene mean expression values integer(kind=int32), intent(out) :: ierr Error code public        interface compute_gene_means_helper public pure module subroutine compute_gene_means_helper(n_genes, n_reps, expr, means) (no input validation) Compute per-gene mean expression, ignoring NaN values Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes in the study integer(kind=int32), intent(in) :: n_reps Number of biological replicates in the study real(kind=real64), intent(in) :: expr (n_reps,n_genes) Expression matrix real(kind=real64), intent(out) :: means (n_genes) Per-gene mean expression values public        interface compute_residuals public pure module subroutine compute_residuals(n_genes, n_reps, expr, means, resid, ierr) Compute signed residuals (centering by mean) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes in the study integer(kind=int32), intent(in) :: n_reps Number of biological replicates in the study real(kind=real64), intent(in) :: expr (n_reps,n_genes) Expression matrix containing real(kind=real64), intent(in) :: means (n_genes) Per-gene mean expression values real(kind=real64), intent(out) :: resid (n_reps,n_genes) Matrix of signed residuals integer(kind=int32), intent(out) :: ierr Error code public        interface compute_residuals_helper public pure module subroutine compute_residuals_helper(n_genes, n_reps, expr, means, resid) (no input validation) Compute signed residuals (centering by mean) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes in the study integer(kind=int32), intent(in) :: n_reps Number of biological replicates in the study real(kind=real64), intent(in) :: expr (n_reps,n_genes) Expression matrix containing real(kind=real64), intent(in) :: means (n_genes) Per-gene mean expression values real(kind=real64), intent(out) :: resid (n_reps,n_genes) Matrix of signed residuals public        interface pool_means_alloc public pure module subroutine pool_means_alloc(n_genes_S1, mean_S1, n_genes_S2, mean_S2, n_points, n_pool, x_star, ierr) Pool per-gene mean expression values across studies Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes_S1 Number of genes in study S1 real(kind=real64), intent(in) :: mean_S1 (n_genes_S1) Per-gene mean expression values integer(kind=int32), intent(in) :: n_genes_S2 Number of genes in study S2 real(kind=real64), intent(in) :: mean_S2 (n_genes_S2) Per-gene mean expression values integer(kind=int32), intent(in) :: n_points Number of reference points to define integer(kind=int32), intent(out) :: n_pool Total number of included (non-NaN) pooled mean-expression values real(kind=real64), intent(out) :: x_star (n_points) Mean-expression reference points integer(kind=int32), intent(out) :: ierr Error code public        interface pool_means public pure module subroutine pool_means(pooled_means, pooled_means_perm, pool_size, n_points, n_pool, x_star, ierr) Pool per-gene mean expression values across studies Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: pooled_means (pool_size) Pooled means integer(kind=int32), intent(in) :: pooled_means_perm (pool_size) Sorting permutation for pooled_means integer(kind=int32), intent(in), target :: pool_size Number of means in the pool, usually n_genes_S1 + n_genes_S2 integer(kind=int32), intent(in) :: n_points Number of reference points to define integer(kind=int32), intent(out) :: n_pool Total number of included (non-NaN) pooled mean-expression values real(kind=real64), intent(out) :: x_star (n_points) Mean-expression reference points integer(kind=int32), intent(out) :: ierr Error code public        interface pool_means_helper public pure module subroutine pool_means_helper(pooled_means, pooled_means_perm, pool_size, n_points, n_pool, x_star) (no input validation) Pool per-gene mean expression values across studies Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: pooled_means (pool_size) Pooled means integer(kind=int32), intent(in) :: pooled_means_perm (pool_size) Sorting permutation for pooled_means integer(kind=int32), intent(in), target :: pool_size Number of means in the pool, usually n_genes_S1 + n_genes_S2 integer(kind=int32), intent(in) :: n_points Number of reference points to define integer(kind=int32), intent(out) :: n_pool Total number of included (non-NaN) pooled mean-expression values real(kind=real64), intent(out) :: x_star (n_points) Mean-expression reference points public        interface calc_neighborhood_size Calculate the number of neighbors to be used for construct_neighborhoods . The desired_size works as upper limit, as the actual neighborhood size might be lower due to few genes with non-NaN mean. public pure module function calc_neighborhood_size(n_pool, n_points, n_genes_S, mean_S, desired_size) result(n_neighbors) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_pool Total number of pooled mean-expression values across both studies integer(kind=int32), intent(in) :: n_points Number of reference points integer(kind=int32), intent(in) :: n_genes_S Number of genes in the current study real(kind=real64), intent(in) :: mean_S (n_genes_S) Per-gene mean expression values integer(kind=int32), intent(in), optional :: desired_size Optional desired neighborhood size, default=1000 Return Value integer(kind=int32) Calculated neighborhood size public        interface construct_neighborhoods_alloc public pure module subroutine construct_neighborhoods_alloc(n_points, x_star, n_genes_S, mean_S, n_reps_S, resid_S, neighborhood_residuals, neighborhood_indices, n_neighbors, ierr) Construct neighborhood-based residual sets (kNN) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_points Number of reference points real(kind=real64), intent(in) :: x_star (n_points) Mean-expression reference points integer(kind=int32), intent(in) :: n_genes_S Number of genes in the current study real(kind=real64), intent(in) :: mean_S (n_genes_S) Per-gene mean expression values integer(kind=int32), intent(in) :: n_reps_S Number of biological replicates in the study real(kind=real64), intent(in) :: resid_S (n_reps_S,n_genes_S) Matrix of signed residuals real(kind=real64), intent(out) :: neighborhood_residuals (n_reps_S,n_neighbors,n_points) Collection of residual vectors for each neighborhood integer(kind=int32), intent(out) :: neighborhood_indices (n_neighbors,n_points) Indices of selected neighborhood genes integer(kind=int32), intent(in) :: n_neighbors Number of neighbors, CALCULATE IT WITH calc_neighborhood_size integer(kind=int32), intent(out) :: ierr Error code public        interface construct_neighborhoods public pure module subroutine construct_neighborhoods(n_points, x_star, n_genes_S, mean_S, n_reps_S, resid_S, tmp_distances, tmp_distances_perm, neighborhood_residuals, neighborhood_indices, n_neighbors, ierr) Construct neighborhood-based residual sets (kNN) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_points Number of reference points real(kind=real64), intent(in) :: x_star (n_points) Mean-expression reference points integer(kind=int32), intent(in) :: n_genes_S Number of genes in the current study real(kind=real64), intent(in) :: mean_S (n_genes_S) Per-gene mean expression values integer(kind=int32), intent(in) :: n_reps_S Number of biological replicates in the study real(kind=real64), intent(in) :: resid_S (n_reps_S,n_genes_S) Matrix of signed residuals real(kind=real64), intent(out) :: tmp_distances (n_genes_S) Distances work array integer(kind=int32), intent(out) :: tmp_distances_perm (n_genes_S) Work array for permutation vector to sort tmp_distances_perm real(kind=real64), intent(out) :: neighborhood_residuals (n_reps_S,n_neighbors,n_points) Collection of residual vectors for each neighborhood integer(kind=int32), intent(out) :: neighborhood_indices (n_neighbors,n_points) Indices of selected neighborhood genes integer(kind=int32), intent(in) :: n_neighbors Number of neighbors, CALCULATE IT WITH calc_neighborhood_size integer(kind=int32), intent(out) :: ierr Error code public        interface construct_neighborhoods_helper public pure module subroutine construct_neighborhoods_helper(n_points, x_star, n_genes_S, mean_S, n_reps_S, resid_S, tmp_distances, tmp_distances_perm, neighborhood_residuals, neighborhood_indices, n_neighbors) (no input validation) Construct neighborhood-based residual set