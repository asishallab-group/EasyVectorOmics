ndex Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), target :: vectors (num_dimensions,num_vectors) input unit vectors integer(kind=c_int), intent(in), target :: num_dimensions number of input dimensions integer(kind=c_int), intent(in), target :: num_vectors number of input vectors integer(kind=c_int), intent(out), target :: sphere_indices (num_vectors) output sphere indices integer(kind=c_int), intent(out), target :: dimension_order (num_dimensions) output dimension order integer(kind=c_int), intent(out), target :: workspace (num_vectors) workspace real(kind=c_double), intent(out), target :: value_buffer (num_vectors) value buffer integer(kind=c_int), intent(out), target :: permutation (num_vectors) permutation array integer(kind=c_int), intent(out), target :: left_stack (num_vectors) left stack integer(kind=c_int), intent(out), target :: right_stack (num_vectors) right stack integer(kind=c_int), intent(out), target :: ierr error code","tags":"","url":"proc/build_spherical_kd_c.html"},{"title":"gjct_permutation_test_c – TensorOmics","text":"subroutine gjct_permutation_test_c(neighborhood_residuals_S1, neighborhood_residuals_S2, n_reps_S1, n_reps_S2, n_neighbors, n_points, global_jsd_observed, n_bins, shared_residual_range, n_permutations, jsd_null, p_value, ierr, random_seed) bind(C, name=\"gjct_permutation_test_c\") Uses tox_data_integration tox_errors iso_c_binding C-compatible wrapper for gjct_permutation_test_alloc Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_reps_S1, n_neighbors, n_points), target :: neighborhood_residuals_S1 Computed neighborhood residuals for study 1 ( construct_neighborhoods ), NaN is explicitly allowed for missing values real(kind=c_double), intent(in), dimension(n_reps_S2, n_neighbors, n_points), target :: neighborhood_residuals_S2 Computed neighborhood residuals for study 2 ( construct_neighborhoods ), NaN is explicitly allowed for missing values integer(kind=c_int), intent(in), target :: n_reps_S1 Number of replicates in study 1 integer(kind=c_int), intent(in), target :: n_reps_S2 Number of replicates in study 2 integer(kind=c_int), intent(in), target :: n_neighbors Number of neighbors in the studies integer(kind=c_int), intent(in), target :: n_points Number of reference points in the studies real(kind=c_double), intent(in), target :: global_jsd_observed Observed global JSD value for both studies (from compute_weighted_global_divergence ) integer(kind=c_int), intent(in), target :: n_bins Number of equally sized histogram bins used for the studies in build_residual_histograms real(kind=c_double), intent(in), target :: shared_residual_range Computed residual range for both studies, from determine_shared_residual_range integer(kind=c_int), intent(in), target :: n_permutations Number of permutations to perform real(kind=c_double), intent(out), dimension(n_permutations), target :: jsd_null Vector of global divergence values obtained under the null hypothesis real(kind=c_double), intent(out), target :: p_value Empirical p-value of the permutation test: integer(kind=c_int), intent(out), target :: ierr Error code integer(kind=c_int), intent(in), target :: random_seed Seed to use for shuffling","tags":"","url":"proc/gjct_permutation_test_c.html"},{"title":"gjct_permutation_test_filtered_c – TensorOmics","text":"subroutine gjct_permutation_test_filtered_c(neighborhood_residuals_S1, neighborhood_residuals_S2, n_reps_S1, n_reps_S2, n_neighbors, n_points, global_jsd_observed, n_bins, shared_residual_range, n_permutations, jsd_null, p_value, ierr, random_seed, neighbor_mask_S1, neighbor_mask_S2) bind(C, name=\"gjct_permutation_test_filtered_c\") Uses tox_data_integration tox_conversions tox_errors iso_c_binding C-compatible wrapper for gjct_permutation_test_alloc , including neighbor masks for filtered analysis Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_reps_S1, n_neighbors, n_points), target :: neighborhood_residuals_S1 Computed neighborhood residuals for study 1 ( construct_neighborhoods ), NaN is explicitly allowed for missing values real(kind=c_double), intent(in), dimension(n_reps_S2, n_neighbors, n_points), target :: neighborhood_residuals_S2 Computed neighborhood residuals for study 2 ( construct_neighborhoods ), NaN is explicitly allowed for missing values integer(kind=c_int), intent(in), target :: n_reps_S1 Number of replicates in study 1 integer(kind=c_int), intent(in), target :: n_reps_S2 Number of replicates in study 2 integer(kind=c_int), intent(in), target :: n_neighbors Number of neighbors in the studies integer(kind=c_int), intent(in), target :: n_points Number of reference points in the studies real(kind=c_double), intent(in), target :: global_jsd_observed Observed global JSD value for both studies (from compute_weighted_global_divergence ) integer(kind=c_int), intent(in), target :: n_bins Number of equally sized histogram bins used for the studies in build_residual_histograms real(kind=c_double), intent(in), target :: shared_residual_range Computed residual range for both studies, from determine_shared_residual_range integer(kind=c_int), intent(in), target :: n_permutations Number of permutations to perform real(kind=c_double), intent(out), dimension(n_permutations), target :: jsd_null Vector of global divergence values obtained under the null hypothesis real(kind=c_double), intent(out), target :: p_value Empirical p-value of the permutation test: integer(kind=c_int), intent(out), target :: ierr Error code integer(kind=c_int), intent(in), target :: random_seed Seed to use for shuffling integer(kind=c_int), intent(in), dimension(n_neighbors, n_points), target :: neighbor_mask_S1 Mask to exclude specific neighbors from study 1 (e.g. for family-wise analysis) integer(kind=c_int), intent(in), dimension(n_neighbors, n_points), target :: neighbor_mask_S2 Mask to exclude specific neighbors from study 2 (e.g. for family-wise analysis)","tags":"","url":"proc/gjct_permutation_test_filtered_c.html"},{"title":"compute_tissue_versatility_c – TensorOmics","text":"pure subroutine compute_tissue_versatility_c(n_axes, n_vectors, expression_vectors, exp_vecs_selection_index, n_selected_vectors, axes_selection, n_selected_axes, tissue_versatilities, tissue_angles_deg, ierr) bind(C, name=\"compute_tissue_versatility_c\") Uses tox_tissue_versatility tox_errors iso_c_binding C wrapper for compute_tissue_versatility.\nExposes compute_tissue_versatility to C via iso_c_binding types with explicit dimensions. Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_axes Number of axes (tissues/dimensions) integer(kind=c_int), intent(in), target :: n_vectors Number of expression vectors (genes) real(kind=c_double), intent(in), target :: expression_vectors (n_axes,n_vectors) 2D array (n_axes, n_vectors), each column is a gene expression vector (column-major) integer(kind=c_int), intent(in), target :: exp_vecs_selection_index (n_vectors) Integer array (n_vectors), 0/1 values. 0=not selected, 1=selected. Interpreted as logical internally. integer(kind=c_int), intent(in), target :: n_selected_vectors Number of selected expression vectors (count of 1s in exp_vecs_selection_index) integer(kind=c_int), intent(in), target :: axes_selection (n_axes) Integer array (n_axes), 0/1 values. 0=not selected, 1=selected. Interpreted as logical internally. integer(kind=c_int), intent(in), target :: n_selected_axes Number of selected axes (count of 1s in axes_selection) real(kind=c_double), intent(out), target :: tissue_versatilities (n_selected_vectors) Output, real array, length = n_selected_vectors, stores the calculated tissue versatilities for selected vectors real(kind=c_double), intent(out), target :: tissue_angles_deg (n_selected_vectors) Output, real array, length = n_selected_vectors, stores the calculated angles in degrees for selected vectors integer(kind=c_int), intent(out), target :: ierr Error code: 0 = success, non-zero = error","tags":"","url":"proc/compute_tissue_versatility_c.html"},{"title":"compute_shift_vector_field_c – TensorOmics","text":"pure subroutine compute_shift_vector_field_c(d, n_genes, n_families, expression_vectors, family_centroids, gene_to_centroid, shift_vectors, ierr) bind(C, name=\"compute_shift_vector_field_c\") Uses tox_shift_vectors tox_errors iso_c_binding C wrapper for compute_shift_vector_field .\nExposes compute_shift_vector_field to C via iso_c_binding types with explicit dimensions.\nWhen using these C wrapper functions, no copies of the arrays will be created. The Fortran routine will operate directly on the memory provided by the caller. Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: d Expression vector dimension integer(kind=c_int), intent(in), target :: n_genes Total number of genes integer(kind=c_int), intent(in), target :: n_families Total number of families real(kind=c_double), intent(in), target :: expression_vectors (d,n_genes) Gene expression matrix (d × n_genes) real(kind=c_double), intent(in), target :: family_centroids (d,n_families) Family centroid matrix (d × n_families) integer(kind=c_int), intent(in), target :: gene_to_centroid (n_genes) Mapping from genes to families (family IDs for each gene in expression_vectors ) real(kind=c_double), intent(out), target :: shift_vectors (2*d,n_genes) Output, real matrix array, size = 2d x n_genes , stores the centroid of the gene's family in rows 1..d and the shift vectors in rows d+1...2d integer(kind=c_int), intent(out), target :: ierr Error code: 0 - success, non-zero = error","tags":"","url":"proc/compute_shift_vector_field_c.html"},{"title":"deserialize_int_nd_C – TensorOmics","text":"subroutine deserialize_int_nd_C(arr, arr_size, filename_raw, fn_len, ierr) bind(C, name=\"deserialize_int_nd_C\") Uses tox_conversions tox_errors iso_c_binding f42_deserialize_int iso_fortran_env C binding for the subroutine to deser