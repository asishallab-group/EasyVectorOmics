 the number integer(kind=c_size_t), intent(out) :: c_val the element that will hold the c_size_t representation","tags":"","url":"proc/int32_as_c_size.html"},{"title":"c_size_as_int32 – TensorOmics","text":"public elemental subroutine c_size_as_int32(c_val, f_val) Converts c_size_t to int32, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=c_size_t), intent(in) :: c_val the element containing the c variant of the number integer(kind=int32), intent(out) :: f_val the element that will hold the int32 representation","tags":"","url":"proc/c_size_as_int32.html"},{"title":"c_int64_as_c_size – TensorOmics","text":"public elemental subroutine c_int64_as_c_size(c64_val, csize_val) Converts c_int64_t to c_size_t, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=c_int64_t), intent(in) :: c64_val the element containing the c_int64_t value integer(kind=c_size_t), intent(out) :: csize_val the element that will hold the c_size_t representation","tags":"","url":"proc/c_int64_as_c_size.html"},{"title":"c_size_as_c_int64 – TensorOmics","text":"public elemental subroutine c_size_as_c_int64(csize_val, c64_val) Converts c_size_t to c_int64_t, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=c_size_t), intent(in) :: csize_val the element containing the c_size_t value integer(kind=c_int64_t), intent(out) :: c64_val the element that will hold the c_int64_t representation","tags":"","url":"proc/c_size_as_c_int64.html"},{"title":"check_okay_ioerror – TensorOmics","text":"public  subroutine check_okay_ioerror(ioerror, ierr, msg, unit) Check I/O error and set ierr accordingly Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ioerror IO error set by fortran integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in) :: msg Error code readable version used for setting integer(kind=int32), intent(in) :: unit pass unit allowing it to be closed","tags":"","url":"proc/check_okay_ioerror.html"},{"title":"check_okay_dims – TensorOmics","text":"public  subroutine check_okay_dims(dims, expected, ierr) check if array dimensions match the expected dimensions Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: dims (:) array of actual dimensions integer(kind=int32), intent(in) :: expected expected number of dimensions integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/check_okay_dims.html"},{"title":"check_okay_ndims – TensorOmics","text":"public  subroutine check_okay_ndims(ndims, expected, unit, ierr) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ndims number of dimensions integer(kind=int32), intent(in) :: expected expected number of dimensions integer(kind=int32), intent(in) :: unit unit representation integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/check_okay_ndims.html"},{"title":"write_file_header – TensorOmics","text":"public  subroutine write_file_header(filename, unit, type_code, ndim, dims, ierr, clen) Opens unit and writes fileheader with all metadata to the given filename Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename filename to write to integer(kind=int32), intent(out) :: unit Fortran unit number for the file integer(kind=int32), intent(in) :: type_code type code of the array (1=int, 2=real, 3=char) integer(kind=int32), intent(in) :: ndim number of dimensions integer(kind=int32), intent(in) :: dims (ndim) dimensions of the array integer(kind=int32), intent(inout) :: ierr error code integer(kind=int32), intent(in), optional :: clen character length (only for character arrays)","tags":"","url":"proc/write_file_header.html"},{"title":"read_file_header – TensorOmics","text":"public  subroutine read_file_header(filename, unit, type_code, ndims, dims, clen, ierr) Opens unit and reads file header with all metadata from given file Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename filename to read from integer(kind=int32), intent(out) :: unit Fortran unit number for the file integer(kind=int32), intent(out) :: type_code type code of the array (1=int, 2=real, 3=char) integer(kind=int32), intent(out) :: ndims number of dimensions integer(kind=int32), allocatable :: dims (:) dimensions of the array integer(kind=int32), intent(out) :: clen character length (only for character arrays) integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/read_file_header.html"},{"title":"get_array_metadata – TensorOmics","text":"public  subroutine get_array_metadata(filename, dims_out, dims_out_capacity, ndims, ierr, clen) Get the metadata of an array file Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: dims_out (dims_out_capacity) Array to store output dimensions integer(kind=int32), intent(in) :: dims_out_capacity Capacity of the dims_out array integer(kind=int32), intent(out) :: ndims number of dimensions integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(out), optional :: clen length of each string (needed for char arrays)","tags":"","url":"proc/get_array_metadata.html"},{"title":"ascii_to_string – TensorOmics","text":"public  subroutine ascii_to_string(ascii_array, clen, str) subroutine to convert an ASCII array to a string Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ascii_array (clen) Array of ASCII characters integer(kind=int32), intent(in) :: clen Length of the ASCII array character(len=:), intent(out), allocatable :: str Output string","tags":"","url":"proc/ascii_to_string.html"},{"title":"string_to_ascii_arr – TensorOmics","text":"public  subroutine string_to_ascii_arr(flat, array_size, ascii_arr, clen) converts a string array to an ascii array Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: flat (array_size) input array with characters integer(kind=int32), intent(in) :: array_size size of the input array integer(kind=int32), intent(out) :: ascii_arr (array_size*clen) ascii output array integer(kind=int32), intent(in) :: clen length of the longest string","tags":"","url":"proc/string_to_ascii_arr.html"},{"title":"save_gene_ids – TensorOmics","text":"public  subroutine save_gene_ids(gene_ids, filename, ierr) Wrapper for serialize_char_1D function Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: gene_ids (:) Gene IDs to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/save_gene_ids.html"},{"title":"save_expression_vectors – TensorOmics","text":"public  subroutine save_expression_vectors(expression_vectors, filename, ierr) Wrapper for serialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: expression_vectors (:,:) Expression vectors to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/save_expression_vectors.html"},{"title":"save_gene_to_family – TensorOmics","text":"public  subroutine save_gene_to_family(gene_to_fam, filename, ierr) Wrapper for serialize_int_1D function Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_to_fam (:) Gene to family mapping to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr","tags":"","url":"proc/save_gene_to_family.html"},{"title":"save_family_ids – TensorOmics","text":"public  subroutine save_family_ids(family_ids, filename, ierr) Wrapper for serialize_char_1D function Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: family_ids (:) Family IDs to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/save_family_ids.html"},{"title":"save_family_centroids – TensorOmics","text":"public  subroutine save_family_centroids(family_centroids, filename, ierr) Wrapper for serialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: family_centroids (:,:) Family centroids to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/save_family_centroids.html"},{"title":"save_shift_vectors – TensorOmics","text":"public  subroutine save_shift_vectors(shift_vectors, filename, ierr) Wrapper for serialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: shift_vectors (:,:) Shift vectors to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/save_shift_vectors.html"},{"title":"load_gene_ids – TensorOmics","text":"public  subroutine load_gene_ids(gene_ids, filename, ierr) Wrapper for deserialize_char_1D function Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: gene_ids (:) Gene IDs to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/load_gene_ids.html"},{"title":"load_expression_vectors – TensorOmics","text":"public  subroutine load_expression_vectors(expression_vectors, filename, ierr) Wrapper for deserialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: expression_vectors (:,:) Expression vectors to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/load_expression_vectors.html"},{"title":"load_gene_to_family – TensorOmics","text":"public  subroutine load_gene_to_family(gene_to_fam, filename, ierr) Wrapper for deserialize_int_1D function Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out) :: gene_to_fam (:) Gene to family mapping to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/load_gene_to_family.html"},{"title":"load_family_ids – TensorOmics","text":"public  subroutine load_family_ids(family_ids, filename, ierr) Wrapper for deserialize_char_1D function Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: family_ids (:) Family IDs to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code (0 if successful)","tags":"","url":"proc/load_family_ids.html"},{"title":"load_family_centroids – TensorOmics","text":"public  subroutine load_family_centroids(family_centroids, filename, ierr) Wrapper for deserialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: family_centroids (:,:) Family centroids to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/load_family_centroids.html"},{"title":"load_shift_vectors – TensorOmics","text":"public  subroutine load_shift_vectors(shift_vectors, filename, ierr) Wrapper for deserialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: shift_vectors (:,:) Shift vectors to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/load_shift_vectors.html"},{"title":"deserialize_real_1d – TensorOmics","text":"public  subroutine deserialize_real_1d(arr, filename, ierr) Directly deserialize a 1D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_real_1d.html"},{"title":"deserialize_real_2d – TensorOmics","text":"public  subroutine deserialize_real_2d(arr, filename, ierr) Directly deserialize a 2D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_real_2d.html"},{"title":"deserialize_real_3d – TensorOmics","text":"public  subroutine deserialize_real_3d(arr, filename, ierr) Directly deserialize a 3D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_real_3d.html"},{"title":"deserialize_real_4d – TensorOmics","text":"public  subroutine deserialize_real_4d(arr, filename, ierr) Directly deserialize a 4D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_real_4d.html"},{"title":"deserialize_real_5d – TensorOmics","text":"public  subroutine deserialize_real_5d(arr, filename, ierr) Directly deserialize a 5D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:,:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_real_5d.html"},{"title":"cluster_factor_trajectories_k_means – TensorOmics","text":"public pure subroutine cluster_factor_trajectories_k_means(n_clusters, trajectories, n_factors, n_samples, n_timepoints, centroids, labels, label_counts, ierr, max_iterations) Performs k-means clustering on factor trajectories, so factor evolution over time Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_clusters number ( k ) of clusters real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories matrix with data points to cluster integer(kind=int32), intent(in) :: n_factors number of factors integer(kind=int32), intent(in) :: n_samples number of samples integer(kind=int32), intent(in) :: n_timepoints number of timepoints real(kind=real64), intent(inout), dimension(n_factors, n_clusters) :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. The final values will be the final centroids of the clusters integer(kind=int32), intent(out), dimension(n_samples * n_timepoints) :: labels array of labels, each index corresponds to the respective point's index, so first label is first point's label. each label is the index of its related cluster -> 1<=label<=n_clusters=k integer(kind=int32), intent(out), dimension(n_clusters) :: label_counts holds the number of points having the respective label assigned integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in) :: max_iterations number of maximum iterations of the clustering","tags":"","url":"proc/cluster_factor_trajectories_k_means.html"},{"title":"k_means_clustering – TensorOmics","text":"public pure subroutine k_means_clustering(n_clusters, data_points, n_points, n_dims, centroids, labels, label_counts, ierr, max_iterations) k-means clustering algorithm: Assigns each data point to one of k clusters whose centroid is clostest Recalculates the centroids using the mean of its assigned points repeat 1-2 until assignment remains unchanged Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_clusters number ( k ) of clusters real(kind=real64), intent(in), dimension(n_dims, n_points) :: data_points matrix with data points to cluster integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: n_dims number of elements a point has real(kind=real64), intent(inout), dimension(n_dims, n_clusters) :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. The final values will be the final centroids of the clusters integer(kind=int32), intent(out), dimension(n_points) :: labels array of labels, each index corresponds to the respective point's index, so first label is first point's label. each label is the index of its related cluster -> 1<=label<=n_clusters=k integer(kind=int32), intent(out), dimension(n_clusters) :: label_counts holds the number of points having the respective label assigned integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in), optional :: max_iterations number of maximum iterations of the clustering, default 300","tags":"","url":"proc/k_means_clustering.html"},{"title":"k_means_recompute_cluster_centroids_helper – TensorOmics","text":"public pure subroutine k_means_recompute_cluster_centroids_helper(data_points, n_points, n_dims, centroids, n_clusters, labels, label_counts) Helper to recompute the centroids in k-means by taking the mean of assigned points Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims, n_points) :: data_points matrix with data points to cluster integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: n_dims number of elements a point has real(kind=real64), intent(inout), dimension(n_dims, n_clusters) :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. The final values will be the final centroids of the clusters integer(kind=int32), intent(in) :: n_clusters number ( k ) of clusters integer(kind=int32), intent(in), dimension(n_points) :: labels array of labels, each index corresponds to the respective point's index, so first label is first point's label. each label is the index of its related cluster -> 1<=label<=n_clusters=k integer(kind=int32), intent(in), dimension(n_clusters) :: label_counts holds the number of points having the respective label assigned","tags":"","url":"proc/k_means_recompute_cluster_centroids_helper.html"},{"title":"k_means_assign_cluster_helper – TensorOmics","text":"public pure subroutine k_means_assign_cluster_helper(i_point, n_clusters, data_points, n_points, n_dims, centroids, label) Helper routine to assign a cluster's label to a point in k-means Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: i_point index of the point that should be assigned a cluster integer(kind=int32), intent(in) :: n_clusters number ( k ) of clusters real(kind=real64), intent(in), dimension(n_dims, n_points) :: data_points matrix with data points to cluster integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: n_dims number of elements a point has real(kind=real64), intent(in), dimension(n_dims, n_clusters) :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. The final values will be the final centroids of the clusters integer(kind=int32), intent(out) :: label assigned label","tags":"","url":"proc/k_means_assign_cluster_helper.html"},{"title":"linkage_clustering – TensorOmics","text":"public pure subroutine linkage_clustering(distances, n_points, merge_i, merge_j, heights, cluster_sizes, method, ierr) Perform linkage clustering on a distance matrix. Note This subroutine operates in-place in the bottom triangle of the distance matrix and recovers it using the top triangle once done or on error.\nSo there is no need to copy an existing distance matrix, just pass the original. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances symmetric distance matrix, holding the positive distances between points. Distance of X->X is always zero. Note This subroutine operates in-place in the bottom triangle of the distance matrix and recovers it using the top triangle once done or on error.\nSo there is no need to copy an existing distance matrix, just pass the original. integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(out), dimension(n_points - 1) :: merge_i holds cluster labels of the merged node pair at iteration k -> positives relate to leafs/data point indices, negatives to inner nodes integer(kind=int32), intent(out), dimension(n_points - 1) :: merge_j holds cluster labels of the merged node pair at iteration k -> positives relate to leafs/data point indices, negatives to inner nodes real(kind=real64), intent(out), dimension(n_points - 1) :: heights height of the shorter branch of the merge, e.g. if (A,B)+(C) merges to ((A,B),C), the branch to (A,B) is shorter integer(kind=int32), intent(out), dimension(n_points - 1) :: cluster_sizes size of cluster at iteration k integer(kind=int32), intent(in) :: method used algorithm Method Value Average / UPGMA 0 Weighted / WPGMA 1 Ward 2 integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/linkage_clustering.html"},{"title":"recover_distance_matrix_helper – TensorOmics","text":"public pure subroutine recover_distance_matrix_helper(distances, n_points) Helper to recover a distance matrix from its top triangle. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances top triangle holds distances, bottom triangle will be recovered integer(kind=int32), intent(in) :: n_points number of points to cluster","tags":"","url":"proc/recover_distance_matrix_helper.html"},{"title":"get_cluster_data_linkage_helper – TensorOmics","text":"public pure subroutine get_cluster_data_linkage_helper(distances, n_points, cluster_sizes, idx, weight, cluster_label) Helper for linkage clustering to get the size/weight and label of a cluster\nby using the self-distance as indicator in which iteration the cluster was merged Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_points, n_points) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in), dimension(n_points - 1) :: cluster_sizes size of cluster at iteration k integer(kind=int32), intent(in) :: idx index of cluster in distances integer(kind=int32), intent(out) :: weight number of leafs of cluster integer(kind=int32), intent(out) :: cluster_label index/label of cluster","tags":"","url":"proc/get_cluster_data_linkage_helper.html"},{"title":"merge_distances_xPGMA_linkage_helper – TensorOmics","text":"public pure subroutine merge_distances_xPGMA_linkage_helper(distances, n_points, idx_A, idx_B, size_A, size_B, iteration_k) Helper for *PGMA algorithms for updating the distance matrix on merge of two clusters Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: idx_A row index of min distance in distances integer(kind=int32), intent(in) :: idx_B column index of min distance in distances integer(kind=int32), intent(in) :: size_A cluster size of cluster at idx_A integer(kind=int32), intent(in) :: size_B cluster size of cluster at idx_B integer(kind=int32), intent(in) :: iteration_k iteration of current merge","tags":"","url":"proc/merge_distances_xpgma_linkage_helper.html"},{"title":"merge_distances_ward_linkage_helper – TensorOmics","text":"public pure subroutine merge_distances_ward_linkage_helper(distances, n_points, idx_A, idx_B, size_A, size_B, iteration_k, cluster_sizes, dist_AB) Helper for ward algorithm for updating the distance matrix on merge of two clusters Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: idx_A row index of min distance in distances integer(kind=int32), intent(in) :: idx_B column index of min distance in distances integer(kind=int32), intent(in) :: size_A cluster size of cluster at idx_A integer(kind=int32), intent(in) :: size_B cluster size of cluster at idx_B integer(kind=int32), intent(in) :: iteration_k iteration of current merge integer(kind=int32), intent(in), dimension(n_points - 1) :: cluster_sizes size of cluster at iteration k, needed for ward algorithm real(kind=real64), intent(in) :: dist_AB distance between cluster A and B","tags":"","url":"proc/merge_distances_ward_linkage_helper.html"},{"title":"post_merge_distances_helper – TensorOmics","text":"public pure subroutine post_merge_distances_helper(distances, n_points, idx_A, idx_B, iteration_k) Helper for doing last updates after merge: disable merged cluster, update self-distance to current iteration Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: idx_A row index of min distance in distances integer(kind=int32), intent(in) :: idx_B column index of min distance in distances integer(kind=int32), intent(in) :: iteration_k iteration of current merge","tags":"","url":"proc/post_merge_distances_helper.html"},{"title":"get_min_distance_indices_helper – TensorOmics","text":"public pure subroutine get_min_distance_indices_helper(distances, n, row_idx, col_idx, min_dist) Helper routine to find the indices of the minimum value a distance matrix. Expects n>1 Ignores columns with self-distance (i,i)<0 Searches in bottom triangle (excluding self-distance (i, i)) bottom triangle -> row_idx > col_idx Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n, n) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n number of rows and columns of square matrix distances integer(kind=int32), intent(out) :: row_idx row index of min distance in distances integer(kind=int32), intent(out) :: col_idx column index of min distance in distances real(kind=real64), intent(out) :: min_dist min distance","tags":"","url":"proc/get_min_distance_indices_helper.html"},{"title":"trajectory_contribution – TensorOmics","text":"public pure subroutine trajectory_contribution(factor, dependent, n_timepoints, mode, contribution, ierr) Calculates trajectory contribution using cosine similarity There are two modes: Normal Mode : meant for normal vectors, it returns the cosine similarity RAP Mode : meant for RAP projected vectors, it focusses only on angular similarity and returns the arccos of the cosine similarity Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_timepoints) :: factor Vector of independent variable that contributes to dependent real(kind=real64), intent(in), dimension(n_timepoints) :: dependent Vector of dependent variable integer(kind=int32), intent(in) :: n_timepoints Number of timepoints included in factor and dependent integer(kind=int32), intent(in) :: mode Mode Value Normal 1 RAP 2 real(kind=real64), intent(out) :: contribution Contribution value integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/trajectory_contribution.html"},{"title":"spike_contribution – TensorOmics","text":"public pure subroutine spike_contribution(factor, dependent, n_timepoints, mode, contribution, ierr) Calculates spike contributions using cosine similarity for specific indices There are two modes: Normal Mode : meant for normal vectors, it returns the cosine similarity RAP Mode : meant for RAP projected vectors, it focusses only on angular similarity and returns the arccos of the cosine similarity Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_timepoints) :: factor Vector of independent variable that contributes to dependent real(kind=real64), intent(in), dimension(n_timepoints) :: dependent Vector of independent variable that contributes dependent integer(kind=int32), intent(in) :: n_timepoints Number of timepoints included in factor and dependent integer(kind=int32), intent(in) :: mode Mode Value Normal 1 RAP 2 real(kind=real64), intent(out), dimension(n_timepoints) :: contribution Contribution value integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/spike_contribution.html"},{"title":"calc_contributions – TensorOmics","text":"public pure subroutine calc_contributions(trajectories, n_factors, n_samples, n_timepoints, i_factor, dependent_idx, mode, spike_contribs, integrated_contribs, temp_factor_vector, temp_dependent_vector, ierr) Calculates both spike and integrated contributions for a given factor against a dependent variable Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories of expression data integer(kind=int32), intent(in) :: n_factors Number of factors in trajectories integer(kind=int32), intent(in) :: n_samples Number of samples in trajectories integer(kind=int32), intent(in) :: n_timepoints Number of timepoints in trajectories integer(kind=int32), intent(in) :: i_factor Factor (independent variable) index the contributions should be calculated for integer(kind=int32), intent(in) :: dependent_idx Index of the dependent variable the contributions should be calculated for integer(kind=int32), intent(in) :: mode Mode Value Normal 1 RAP 2 real(kind=real64), intent(out), dimension(n_timepoints, n_samples) :: spike_contribs Output array to hold the timpoint-wise contributions per sample real(kind=real64), intent(out), dimension(n_samples) :: integrated_contribs Output array to hold the contribution per sample real(kind=real64), intent(out), dimension(n_timepoints) :: temp_factor_vector Work array to hold the vector of i_factor per sample real(kind=real64), intent(out), dimension(n_timepoints) :: temp_dependent_vector Work array to hold the vector of dependent_idx per sample integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_contributions.html"},{"title":"calc_contributions_alloc – TensorOmics","text":"public pure subroutine calc_contributions_alloc(trajectories, n_factors, n_samples, n_timepoints, i_factor, dependent_idx, mode, spike_contribs, integrated_contribs, ierr) Calculates both spike and integrated contributions for a given factor against a dependent variable Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories of expression data integer(kind=int32), intent(in) :: n_factors Number of factors in trajectories integer(kind=int32), intent(in) :: n_samples Number of samples in trajectories integer(kind=int32), intent(in) :: n_timepoints Number of timepoints in trajectories integer(kind=int32), intent(in) :: i_factor Factor (independent variable) index the contributions should be calculated for integer(kind=int32), intent(in) :: dependent_idx Index of the dependent variable the contributions should be calculated for integer(kind=int32), intent(in) :: mode Mode Value Normal 1 RAP 2 real(kind=real64), intent(out), dimension(n_timepoints, n_samples) :: spike_contribs Output array to hold the timpoint-wise contributions per sample real(kind=real64), intent(out), dimension(n_samples) :: integrated_contribs Output array to hold the contribution per sample integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_contributions_alloc.html"},{"title":"get_vec_across_samples – TensorOmics","text":"public pure subroutine get_vec_across_samples(trajectories, n_factors, n_samples, n_timepoints, i_factor, i_timepoint, result_vector, ierr) Accessor routine to extract sample data for a specific factor and timepoint Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories of expression data integer(kind=int32), intent(in) :: n_factors Number of factors in trajectories integer(kind=int32), intent(in) :: n_samples Number of samples in trajectories integer(kind=int32), intent(in) :: n_timepoints Number of timepoints in trajectories integer(kind=int32), intent(in) :: i_factor Factor index the retrieved samples should be related to integer(kind=int32), intent(in) :: i_timepoint Timepoint index the retrieved samples should be related to real(kind=real64), intent(out), dimension(n_samples) :: result_vector Result vector, equivalent to trajectories(i_factor, :, i_timepoint) integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/get_vec_across_samples.html"},{"title":"get_vec_across_timepoints – TensorOmics","text":"public pure subroutine get_vec_across_timepoints(trajectories, n_factors, n_samples, n_timepoints, i_factor, i_sample, result_vector, ierr) Accessor routine to extract timepoint data for a specific factor and sample Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories of expression data integer(kind=int32), intent(in) :: n_factors Number of factors in trajectories integer(kind=int32), intent(in) :: n_samples Number of samples in trajectories integer(kind=int32), intent(in) :: n_timepoints Number of timepoints in trajectories integer(kind=int32), intent(in) :: i_factor Factor index the retrieved timepoints should be related to integer(kind=int32), intent(in) :: i_sample Timepoint index the retrieved timepoints should be related to real(kind=real64), intent(out), dimension(n_timepoints) :: result_vector Result vector, equivalent to trajectories(i_factor, i_sample, :) integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/get_vec_across_timepoints.html"},{"title":"process_trajectories_alloc – TensorOmics","text":"public  subroutine process_trajectories_alloc(trajectories, n_factors, n_samples, n_timepoints, factor_mask, factor_mask_count, dependent_idx, mode, percentile, integrated_contribs, spike_contribs, thresholds_integrated_contrib, outliers_integrated_contrib, thresholds_spike_contrib, outliers_spike_contrib, ierr) Uses tox_trajectory_contribution_analysis_outlier_detection Process trajectories with one percentile per timepoint for spike contributions.\nThis subroutine uses multiple allocations. If you want to avoid this, you need to do the full pipeline manually step-by-step. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories array integer(kind=int32), intent(in) :: n_factors Number of factors integer(kind=int32), intent(in) :: n_samples Number of samples integer(kind=int32), intent(in) :: n_timepoints Number of timepoints logical, intent(in), dimension(n_factors) :: factor_mask Mask for what factors should be included integer(kind=int32), intent(in) :: factor_mask_count Number of true values in the factor mask integer(kind=int32), intent(in) :: dependent_idx Index of the dependend factor integer(kind=int32), intent(in) :: mode Mode for contribution calculation real(kind=real64), intent(in) :: percentile Percentile (0-100) real(kind=real64), intent(out), dimension(n_samples, factor_mask_count) :: integrated_contribs Integrated contributions real(kind=real64), intent(out), dimension(n_timepoints, n_samples, factor_mask_count) :: spike_contribs Spike contributions real(kind=real64), intent(out), dimension(factor_mask_count) :: thresholds_integrated_contrib Thresholds of integrated contributions based on the provided percentile logical, intent(out), dimension(n_samples, factor_mask_count) :: outliers_integrated_contrib Detected outliers of the integrated contributions real(kind=real64), intent(out), dimension(n_timepoints, factor_mask_count) :: thresholds_spike_contrib Thresholds of spike contributions based on the provided percentile logical, intent(out), dimension(n_timepoints, n_samples, factor_mask_count) :: outliers_spike_contrib Detected outliers of the spike contributions integer(kind=int32), intent(out) :: ierr","tags":"","url":"proc/process_trajectories_alloc.html"},{"title":"process_trajectories_flat_alloc – TensorOmics","text":"public  subroutine process_trajectories_flat_alloc(trajectories, n_factors, n_samples, n_timepoints, factor_mask, factor_mask_count, dependent_idx, mode, percentile, integrated_contribs, spike_contribs, thresholds_integrated_contrib, outliers_integrated_contrib, thresholds_spike_contrib, outliers_spike_contrib, ierr) Uses tox_trajectory_contribution_analysis_outlier_detection Process trajectories with global percentile for spike contributions (flattened)\nThis subroutine uses multiple allocations. If you want to avoid this, you need to do the full pipeline manually step-by-step. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories array integer(kind=int32), intent(in) :: n_factors Number of factors integer(kind=int32), intent(in) :: n_samples Number of samples integer(kind=int32), intent(in) :: n_timepoints Number of timepoints logical, intent(in), dimension(n_factors) :: factor_mask Logical mask for factors integer(kind=int32), intent(in) :: factor_mask_count Number of true values in the factor mask integer(kind=int32), intent(in) :: dependent_idx Index of the dependent factor integer(kind=int32), intent(in) :: mode Mode to use for contribution calculation real(kind=real64), intent(in) :: percentile Percentile value (0.0 - 100.0) real(kind=real64), intent(out), dimension(n_samples, factor_mask_count) :: integrated_contribs Integrated contributions real(kind=real64), intent(out), dimension(n_timepoints, n_samples, factor_mask_count) :: spike_contribs Spike contributions real(kind=real64), intent(out), dimension(factor_mask_count) :: thresholds_integrated_contrib Thresholds of integrated contributions based on provided percentile logical, intent(out), dimension(n_samples, factor_mask_count) :: outliers_integrated_contrib Outliers of integrated contributions based on provided percentile real(kind=real64), intent(out), dimension(factor_mask_count) :: thresholds_spike_contrib Thresholds of spike contributions based on provided percentile logical, intent(out), dimension(n_timepoints, n_samples, factor_mask_count) :: outliers_spike_contrib Outliers of spike contributions based on provided percentile integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/process_trajectories_flat_alloc.html"},{"title":"compute_family_scaling – TensorOmics","text":"public pure subroutine compute_family_scaling(n_genes, n_families, distances, gene_to_fam, dscale, loess_x, loess_y, indices_used, perm_tmp, stack_left_tmp, stack_right_tmp, family_distances, ierr) Compute family scaling factors (dscale) to normalize distances.\nUses LOESS on the median/stddev of intra-family distances for scaling, regardless of orthologs. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of gene families real(kind=real64), intent(in) :: distances (n_genes) Array of Euclidean distances for each gene integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Mapping of each gene to its family (1-based) real(kind=real64), intent(out) :: dscale (n_families) Output: array of scaling factors per family real(kind=real64), intent(inout) :: loess_x (n_families) Reference x-coordinates. real(kind=real64), intent(inout) :: loess_y (n_families) Reference y-coordinates (length n_total). integer(kind=int32), intent(inout) :: indices_used (n_families) Indices of reference points used for smoothing. integer(kind=int32), intent(inout) :: perm_tmp (n_genes) Permutation array for sorting gene distances integer(kind=int32), intent(inout) :: stack_left_tmp (n_genes) Stack array for left indices during sorting integer(kind=int32), intent(inout) :: stack_right_tmp (n_genes) Stack array for right indices during sorting real(kind=real64), intent(out) :: family_distances (n_genes) Pre-allocated work array for family distances (dimension n_genes) integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid family indices","tags":"","url":"proc/compute_family_scaling.html"},{"title":"compute_family_scaling_alloc – TensorOmics","text":"public pure subroutine compute_family_scaling_alloc(n_genes, n_families, distances, gene_to_fam, dscale, loess_x, loess_y, indices_used, ierr) Helper routine that allocates internal arrays and calls compute_family_scaling.\nThis makes usage easier since users don't need to care about internal array requirements. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of gene families real(kind=real64), intent(in) :: distances (n_genes) Array of Euclidean distances for each gene integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Mapping of each gene to its family (1-based) real(kind=real64), intent(out) :: dscale (n_families) Output: array of scaling factors per family real(kind=real64), intent(inout) :: loess_x (n_families) Reference x-coordinates. real(kind=real64), intent(inout) :: loess_y (n_families) Reference y-coordinates (length n_total). integer(kind=int32), intent(inout) :: indices_used (n_families) Indices of reference points used for smoothing. integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid family indices","tags":"","url":"proc/compute_family_scaling_alloc.html"},{"title":"compute_rdi – TensorOmics","text":"public pure subroutine compute_rdi(n_genes, distances, gene_to_fam, dscale, rdi, sorted_rdi, perm, stack_left, stack_right) Compute the hybrid RDI for each gene.\nRDI = Euclidean distance / family scaling factor Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes real(kind=real64), intent(in) :: distances (n_genes) Array of Euclidean distances for each gene to its centroid integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Gene-to-family mapping (1-based indexing) real(kind=real64), intent(in) :: dscale (:) Array of scaling factors for each family real(kind=real64), intent(out) :: rdi (n_genes) Output array of RDI values for each gene real(kind=real64), intent(inout) :: sorted_rdi (n_genes) Work array for sorting (dimension n_genes) integer(kind=int32), intent(inout) :: perm (n_genes) Permutation array for sorting (dimension n_genes, should be pre-initialized with 1:n_genes) integer(kind=int32), intent(inout) :: stack_left (n_genes) Stack array for sorting (dimension n_genes) integer(kind=int32), intent(inout) :: stack_right (n_genes) Stack array for sorting (dimension n_genes)","tags":"","url":"proc/compute_rdi.html"},{"title":"identify_outliers – TensorOmics","text":"public pure subroutine identify_outliers(n_genes, rdi, sorted_rdi, is_outlier, threshold, percentile) Identify gene outliers based on the top percentile of RDI values.\nExpects sorted_rdi to be filtered (no negative values) and sorted in ascending order before calling.\nIf sorted_rdi contains negatives or is not sorted, results may be invalid. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes real(kind=real64), intent(in) :: rdi (n_genes) Array of RDI values for each gene real(kind=real64), intent(in) :: sorted_rdi (n_genes) Sorted RDI array (must be filtered to remove negatives and sorted in ascending order before calling) logical, intent(out) :: is_outlier (n_genes) Output boolean array indicating outliers real(kind=real64), intent(out) :: threshold Output threshold value used for detection real(kind=real64), intent(in), optional :: percentile (optional) Percentile threshold (default: 95 for top 5%)","tags":"","url":"proc/identify_outliers.html"},{"title":"detect_outliers – TensorOmics","text":"public pure subroutine detect_outliers(n_genes, n_families, distances, gene_to_fam, work_array, perm, stack_left, stack_right, is_outlier, loess_x, loess_y, loess_n, ierr, percentile) Main routine to detect outliers using RDI and LOESS-based scaling. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of gene families real(kind=real64), intent(in) :: distances (n_genes) Array of Euclidean distances for each gene to its centroid integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Gene-to-family mapping (1-based indexing) real(kind=real64), intent(inout) :: work_array (n_genes) Work array for sorting (dimension n_genes) integer(kind=int32), intent(inout) :: perm (n_genes) Permutation array for sorting (dimension n_genes) integer(kind=int32), intent(inout) :: stack_left (n_genes) Stack array for left indices during sorting integer(kind=int32), intent(inout) :: stack_right (n_genes) Stack array for right indices during sorting logical, intent(out) :: is_outlier (n_genes) Output boolean array indicating outliers real(kind=real64), intent(inout) :: loess_x (n_families) Reference x-coordinates. real(kind=real64), intent(inout) :: loess_y (n_families) Reference y-coordinates (length n_total). integer(kind=int32), intent(inout) :: loess_n (n_families) Indices of reference points used for smoothing. integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid family indices real(kind=real64), intent(in), optional :: percentile (optional) Percentile threshold for outlier detection (default: 95)","tags":"","url":"proc/detect_outliers.html"},{"title":"validate_data_structure – TensorOmics","text":"public  subroutine validate_data_structure(n_genes, n_families, n_samples, gene_ids, gene_family_ids, gene_to_fam, expression_vectors, family_centroids, shift_vectors, ierr) Validate full data structure Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Expected number of genes integer(kind=int32), intent(in) :: n_families Expected number of families integer(kind=int32), intent(in) :: n_samples Expected number of samples character(len=*), intent(in) :: gene_ids (:) Gene ids character(len=*), intent(in) :: gene_family_ids (:) Gene family ids integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping real(kind=real64), intent(in) :: expression_vectors (:,:) Expression vectors real(kind=real64), intent(in) :: family_centroids (:,:) Family centroids real(kind=real64), intent(in) :: shift_vectors (:,:) Shift vectors integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/validate_data_structure.html"},{"title":"validate_gene_to_family_mapping – TensorOmics","text":"public  subroutine validate_gene_to_family_mapping(gene_to_fam, n_families, ierr) Validate gene to family mapping Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping integer(kind=int32), intent(in) :: n_families number of families integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/validate_gene_to_family_mapping.html"},{"title":"validate_expression_data – TensorOmics","text":"public  subroutine validate_expression_data(expression_vectors, check_non_negative, ierr) Validate expresssion data Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: expression_vectors (:,:) Expression vectors logical, intent(in) :: check_non_negative Defines if non negative should be checked integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/validate_expression_data.html"},{"title":"validate_family_centroids – TensorOmics","text":"public  subroutine validate_family_centroids(family_centroids, ierr) Validate the family centroids Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: family_centroids (:,:) Family centroids array integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/validate_family_centroids.html"},{"title":"validate_shift_vectors – TensorOmics","text":"public  subroutine validate_shift_vectors(shift_vectors, expression_vectors, family_centroids, gene_to_fam, n_samples, ierr) Validates shift vectors Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: shift_vectors (:,:) shift vectors real(kind=real64), intent(in) :: expression_vectors (:,:) expression vectors real(kind=real64), intent(in) :: family_centroids (:,:) family centroids integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping integer(kind=int32), intent(in) :: n_samples Number of samples integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/validate_shift_vectors.html"},{"title":"check_for_nan_inf – TensorOmics","text":"public  subroutine check_for_nan_inf(array, ierr) Check if an array of type real contains NaN or Inf values Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:,:) Input array integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/check_for_nan_inf.html"},{"title":"validate_string_array_uniqueness – TensorOmics","text":"public  subroutine validate_string_array_uniqueness(str_arr, ierr) Uses xxh3_hashmap_module Validate that no string appears more than once Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: str_arr (:) string array integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/validate_string_array_uniqueness.html"},{"title":"validate_empty_strings – TensorOmics","text":"public  subroutine validate_empty_strings(string_array, array_name, ierr) Validate that strings in an array are not empty Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: string_array (:) Array of strings character(len=*), intent(in) :: array_name Name of the array integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/validate_empty_strings.html"},{"title":"validate_all_data – TensorOmics","text":"public  subroutine validate_all_data(n_genes, n_families, n_samples, gene_ids, gene_family_ids, gene_to_fam, expression_vectors, family_centroids, shift_vectors, ierr, check_uniqueness, check_shift_consistency) Comprehensive validation routine, combining all checks Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes integer(kind=int32), intent(in) :: n_families Number of families integer(kind=int32), intent(in) :: n_samples Number of samples character(len=*), intent(in) :: gene_ids (:) Gene ids array character(len=*), intent(in) :: gene_family_ids (:) gene family ids integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping real(kind=real64), intent(in) :: expression_vectors (:,:) Expression vectors real(kind=real64), intent(in) :: family_centroids (:,:) family centroids real(kind=real64), intent(in) :: shift_vectors (:,:) shift vectors integer(kind=int32), intent(out) :: ierr error code logical, intent(in), optional :: check_uniqueness Check ID arrays for uniqueness logical, intent(in), optional :: check_shift_consistency Check consitency of shift array","tags":"","url":"proc/validate_all_data.html"},{"title":"is_close – TensorOmics","text":"public pure function is_close(a, b) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: a First variable of comparison a==b real(kind=real64), intent(in) :: b Second variable of comparison a==b Return Value logical","tags":"","url":"proc/is_close.html"},{"title":"next_power_of_two – TensorOmics","text":"public  function next_power_of_two(n) result(power) Find the next power of two greater than or equal to n Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n input value Return Value integer(kind=int32) next greater value that is a power of two","tags":"","url":"proc/next_power_of_two.html"},{"title":"real_less – TensorOmics","text":"public pure function real_less(a, b) NaN-aware less-than comparison for real(real64).\nFinite values are always considered smaller than NaN.\nTwo NaNs are treated as equal (neither less nor greater). Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: a real(kind=real64), intent(in) :: b Return Value logical","tags":"","url":"proc/real_less.html"},{"title":"real_greater – TensorOmics","text":"public pure function real_greater(a, b) NaN-aware greater-than comparison for real(real64).\nNaN is treated as greater than any finite number.\nTwo NaNs are treated as equal. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: a real(kind=real64), intent(in) :: b Return Value logical","tags":"","url":"proc/real_greater.html"},{"title":"sort_real – TensorOmics","text":"public pure subroutine sort_real(array, perm, stack_left, stack_right) Sort a real array indirectly using quicksort.\nCreates a sorted version of the array by reordering the perm vector. The original data in array remains unchanged. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion","tags":"","url":"proc/sort_real.html"},{"title":"sort_integer – TensorOmics","text":"public pure subroutine sort_integer(array, perm, stack_left, stack_right) Sort an integer array indirectly using quicksort.\nSimilar to sort_real , but for integer input. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion","tags":"","url":"proc/sort_integer.html"},{"title":"sort_character – TensorOmics","text":"public pure subroutine sort_character(array, perm, stack_left, stack_right) Sort a character array indirectly using quicksort.\nUses lexicographic ordering and permutation vector sorting. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion","tags":"","url":"proc/sort_character.html"},{"title":"sort_real_heapsort – TensorOmics","text":"public pure subroutine sort_real_heapsort(array, perm) Sort a real array indirectly using heapsort.\nCreates a sorted version of the array by reordering the perm vector. The original data in array remains unchanged. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted","tags":"","url":"proc/sort_real_heapsort.html"},{"title":"sort_integer_heapsort – TensorOmics","text":"public pure subroutine sort_integer_heapsort(array, perm) Sort an integer array indirectly using heapsort.\nSimilar to sort_real_heapsort , but for integer input. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted","tags":"","url":"proc/sort_integer_heapsort.html"},{"title":"sort_character_heapsort – TensorOmics","text":"public pure subroutine sort_character_heapsort(array, perm) Sort a character array indirectly using heapsort.\nUses lexicographic ordering and permutation vector sorting. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted","tags":"","url":"proc/sort_character_heapsort.html"},{"title":"quicksort_real – TensorOmics","text":"public pure subroutine quicksort_real(array, perm, n, stack_left, stack_right) Internal quicksort implementation for real arrays.\nSorts indirectly using the permutation vector perm . Manual stack replaces recursion. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(in) :: n Size of the array integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion","tags":"","url":"proc/quicksort_real.html"},{"title":"quicksort_int – TensorOmics","text":"public pure subroutine quicksort_int(array, perm, n, stack_left, stack_right) Internal quicksort implementation for integer arrays.\nIndirectly sorts array using perm , same algorithm as quicksort_real . Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(in) :: n Size of the array integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion","tags":"","url":"proc/quicksort_int.html"},{"title":"quicksort_char – TensorOmics","text":"public pure subroutine quicksort_char(array, perm, n, stack_left, stack_right) Internal quicksort implementation for character arrays.\nLexicographic quicksort using string comparison, indirect via perm . Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(in) :: n Size of the array integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion","tags":"","url":"proc/quicksort_char.html"},{"title":"heapsort_real – TensorOmics","text":"public pure subroutine heapsort_real(array, perm) Sorts indirectly using the permutation vector perm . Uses heapify_real to maintain heap property. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted","tags":"","url":"proc/heapsort_real.html"},{"title":"heapsort_integer – TensorOmics","text":"public pure subroutine heapsort_integer(array, perm) Internal heapsort implementation for integer arrays.\nIndirectly sorts array using perm , same algorithm as heapsort_real . Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted","tags":"","url":"proc/heapsort_integer.html"},{"title":"heapsort_character – TensorOmics","text":"public pure subroutine heapsort_character(array, perm) Internal heapsort implementation for character arrays.\nLexicographic heapsort using string comparison, indirect via perm . Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted","tags":"","url":"proc/heapsort_character.html"},{"title":"swap_int – TensorOmics","text":"public pure subroutine swap_int(a, b) Swap two integer values in-place. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(inout) :: a First integer to swap integer(kind=int32), intent(inout) :: b Second integer to swap","tags":"","url":"proc/swap_int.html"},{"title":"which – TensorOmics","text":"public pure subroutine which(mask, n, idx_out, m_max, m_out, ierr) Finds the indices of the true values in a logical mask. Arguments Type Intent Optional Attributes Name logical, intent(in) :: mask (:) Logical array of size n. integer(kind=int32), intent(in) :: n Size of the mask. integer(kind=int32), intent(out) :: idx_out (:) Integer array to store the indices of true values. integer(kind=int32), intent(in) :: m_max Maximum size of idx_out. integer(kind=int32), intent(out) :: m_out Actual size of idx_out (number of true values found). integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid input, 202=empty input","tags":"","url":"proc/which.html"},{"title":"loess_smooth_2d – TensorOmics","text":"public pure subroutine loess_smooth_2d(n_total, n_target, x_ref, y_ref, indices_used, n_used, x_query, kernel_sigma, kernel_cutoff, y_out, ierr) Performs LOESS smoothing on a set of data points.\nSmooths y_ref at x_query using reference points x_ref, y_ref, and kernel parameters.\nThe user must pre-filter data and provide only valid indices in indices_used. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_total Total number of reference points. integer(kind=int32), intent(in) :: n_target Number of target points to smooth. real(kind=real64), intent(in) :: x_ref (n_total) Reference x-coordinates. real(kind=real64), intent(in) :: y_ref (n_total) Reference y-coordinates (length n_total). integer(kind=int32), intent(in) :: indices_used (n_used) Indices of reference points used for smoothing (only valid indices). integer(kind=int32), intent(in) :: n_used Number of indices actually used for smoothing. real(kind=real64), intent(in) :: x_query (n_target) Target x-coordinates to smooth. real(kind=real64), intent(in) :: kernel_sigma Bandwidth parameter for the kernel. real(kind=real64), intent(in) :: kernel_cutoff Cutoff for the kernel. real(kind=real64), intent(out) :: y_out (n_target) Output smoothed values (length n_target). integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid input, 202=empty input","tags":"","url":"proc/loess_smooth_2d.html"},{"title":"compute_edf – TensorOmics","text":"public  subroutine compute_edf(values, n_values, perm, unique_values, cdf_values, n_unique, ierr) Compute the Empirical Distribution Function (EDF) from pre-sorted permutation.\nReturns the sorted unique values and their cumulative frequencies in [0,1].\nAssumes perm is already sorted by values[perm]. Caller controls sorting algorithm.\nThe number of unique values can be determined by finding the last non-zero cdf_value. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (n_values) Array of observed data values (e.g., contributions or spikes). integer(kind=int32), intent(in) :: n_values Number of values in the input array. integer(kind=int32), intent(in) :: perm (n_values) Pre-sorted permutation indices (must be sorted by values[perm]). real(kind=real64), intent(out) :: unique_values (n_values) Sorted unique data values. real(kind=real64), intent(out) :: cdf_values (n_values) Corresponding cumulative frequencies between 0 and 1. integer(kind=int32), intent(out) :: n_unique Number of unique values found (actual size of output arrays) integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid input, 202=empty input","tags":"","url":"proc/compute_edf.html"},{"title":"compute_edf_alloc – TensorOmics","text":"public  subroutine compute_edf_alloc(values, n_values, unique_values, cdf_values, n_unique, ierr) Helper routine that sorts and calls compute_edf.\nAllocates workspace internally and performs sorting before computing EDF.\nUse this for convenience; use compute_edf directly for custom sorting. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (n_values) Array of observed data values (e.g., contributions or spikes). integer(kind=int32), intent(in) :: n_values Number of values in the input array. real(kind=real64), intent(out) :: unique_values (n_values) Sorted unique data values. real(kind=real64), intent(out) :: cdf_values (n_values) Corresponding cumulative frequencies between 0 and 1. integer(kind=int32), intent(out) :: n_unique Number of unique values found (actual size of output arrays) integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid input, 202=empty input","tags":"","url":"proc/compute_edf_alloc.html"},{"title":"calc_percentile – TensorOmics","text":"public pure subroutine calc_percentile(array, permutation, percentile, value, ierr) Calculate the percentile of an array given a sorted permutation.\nUses linear interpolation between adjacent values. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) input array integer(kind=int32), intent(in) :: permutation (:) permutation vector representing sorted order real(kind=real64), intent(in) :: percentile desired percentile (0-100) real(kind=real64), intent(out) :: value output percentile value integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_percentile.html"},{"title":"calc_percentile_alloc – TensorOmics","text":"public  subroutine calc_percentile_alloc(array, percentile, value, ierr) Uses tox_errors Calculate the percentile of an array, allocating necessary arrays when no sorting permutation is given Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Input array real(kind=real64), intent(in) :: percentile Desired percentile (0-100) real(kind=real64), intent(out) :: value Output percentile value integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_percentile_alloc.html"},{"title":"sort_array – TensorOmics","text":"public interface sort_array Module Procedures public pure subroutine sort_real (array, perm, stack_left, stack_right) Sort a real array indirectly using quicksort.\nCreates a sorted version of the array by reordering the perm vector. The original data in array remains unchanged. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine sort_integer (array, perm, stack_left, stack_right) Sort an integer array indirectly using quicksort.\nSimilar to sort_real , but for integer input. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine sort_character (array, perm, stack_left, stack_right) Sort a character array indirectly using quicksort.\nUses lexicographic ordering and permutation vector sorting. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion","tags":"","url":"interface/sort_array.html"},{"title":"sort_array_heapsort – TensorOmics","text":"public interface sort_array_heapsort Module Procedures public pure subroutine sort_real_heapsort (array, perm) Sort a real array indirectly using heapsort.\nCreates a sorted version of the array by reordering the perm vector. The original data in array remains unchanged. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine sort_integer_heapsort (array, perm) Sort an integer array indirectly using heapsort.\nSimilar to sort_real_heapsort , but for integer input. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine sort_character_heapsort (array, perm) Sort a character array indirectly using heapsort.\nUses lexicographic ordering and permutation vector sorting. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted","tags":"","url":"interface/sort_array_heapsort.html"},{"title":"deserialize_char_flat – TensorOmics","text":"public  subroutine deserialize_char_flat(flat, dims, clen, filename, ierr) Subroutine to deserialize a flat character array from a file Arguments Type Intent Optional Attributes Name character(len=:), intent(out), pointer :: flat (:) Output flat character array integer(kind=int32), intent(out), allocatable :: dims (:) Output dimensions of the array integer(kind=int32), intent(out) :: clen Maximum length of character string character(len=*), intent(in) :: filename Name of the file to read integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_char_flat.html"},{"title":"deserialize_char_1d – TensorOmics","text":"public  subroutine deserialize_char_1d(arr, filename, ierr) Directly deserialize a 1D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out), contiguous :: arr (:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file to read from integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_char_1d.html"},{"title":"deserialize_char_2d – TensorOmics","text":"public  subroutine deserialize_char_2d(arr, filename, ierr) Directly deserialize a 2D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: arr (:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_char_2d.html"},{"title":"deserialize_char_3d – TensorOmics","text":"public  subroutine deserialize_char_3d(arr, filename, ierr) Directly deserialize a 3D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: arr (:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_char_3d.html"},{"title":"deserialize_char_4d – TensorOmics","text":"public  subroutine deserialize_char_4d(arr, filename, ierr) Directly deserialize a 4D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: arr (:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_char_4d.html"},{"title":"deserialize_char_5d – TensorOmics","text":"public  subroutine deserialize_char_5d(arr, filename, ierr) Directly deserialize a 5D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: arr (:,:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/deserialize_char_5d.html"},{"title":"is_in_hashset – TensorOmics","text":"public  function is_in_hashset(hashset, key) result(res) Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(in) :: hashset character(len=*), intent(in) :: key Return Value logical","tags":"","url":"proc/is_in_hashset.html"},{"title":"hashmap_get – TensorOmics","text":"public  function hashmap_get(map, key) result(value) Lookup a key Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(in) :: map hashmap character(len=*), intent(in) :: key key to look for Return Value integer(kind=int32) return value","tags":"","url":"proc/hashmap_get.html"},{"title":"hashmap_create – TensorOmics","text":"public  subroutine hashmap_create(map, initial_size) Create the hashmap Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(out) :: map Hashmap object to create integer(kind=int32), intent(in), optional :: initial_size Size of the hashmap","tags":"","url":"proc/hashmap_create.html"},{"title":"hashset_create – TensorOmics","text":"public  subroutine hashset_create(map, initial_size) Create the hashmap Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(out) :: map Hashmap object to create integer(kind=int32), intent(in), optional :: initial_size Size of the hashmap","tags":"","url":"proc/hashset_create.html"},{"title":"hashmap_destroy – TensorOmics","text":"public  subroutine hashmap_destroy(map) Destroy the hashmap Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(inout) :: map The hashmap to delete","tags":"","url":"proc/hashmap_destroy.html"},{"title":"hashset_destroy – TensorOmics","text":"public  subroutine hashset_destroy(set) Destroy the set Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(inout) :: set The set to delete","tags":"","url":"proc/hashset_destroy.html"},{"title":"hashmap_put – TensorOmics","text":"public  subroutine hashmap_put(map, key, value) Insert a key-value pair Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(inout) :: map hashmap to insert into character(len=*), intent(in) :: key Key to store integer(kind=int32), intent(in) :: value value to store","tags":"","url":"proc/hashmap_put.html"},{"title":"hashset_put – TensorOmics","text":"public  subroutine hashset_put(set, key, ierr) Insert a key-value pair Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(inout) :: set hashmap to insert into character(len=*), intent(in) :: key Key to store integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/hashset_put.html"},{"title":"get_gene_index – TensorOmics","text":"public  function get_gene_index(gene_ids, gene) result(idx) Helper function to find gene index Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: gene_ids (:) gene ids array character(len=*), intent(in) :: gene gene to look for Return Value integer(kind=int32)","tags":"","url":"proc/get_gene_index.html"},{"title":"get_family_index – TensorOmics","text":"public  function get_family_index(family_ids, family) result(idx) Helper function to find family index Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: family_ids (:) family ids array character(len=*), intent(in) :: family family to look for Return Value integer(kind=int32)","tags":"","url":"proc/get_family_index.html"},{"title":"get_family_for_gene_index – TensorOmics","text":"public  subroutine get_family_for_gene_index(gene_idx, gene_to_fam, out_family_idx, ierr) returns family index for gene index Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_idx gene index integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping integer(kind=int32), intent(out) :: out_family_idx family index integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/get_family_for_gene_index.html"},{"title":"get_expression_vector – TensorOmics","text":"public  subroutine get_expression_vector(gene_idx, expression_vectors, out_vector, ierr) get expression vector for a specific gene id Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_idx target gene index real(kind=real64), intent(in) :: expression_vectors (:,:) expression vectors real(kind=real64), intent(out) :: out_vector (:) output vector integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/get_expression_vector.html"},{"title":"get_family_centroid – TensorOmics","text":"public  subroutine get_family_centroid(family_idx, family_centroids, out_centroid, ierr) get family centroid for a specific family index Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: family_idx Target index real(kind=real64), intent(in) :: family_centroids (:,:) centroid array real(kind=real64), intent(out) :: out_centroid (:) Output centroid integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/get_family_centroid.html"},{"title":"get_shift_components – TensorOmics","text":"public  subroutine get_shift_components(gene_idx, shift_vectors, d, out_start, out_shift, ierr) returns the centroid and the shift of a gene Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_idx gene index to look for real(kind=real64), intent(in) :: shift_vectors (:,:) shift vectors integer(kind=int32), intent(in) :: d number of tissues real(kind=real64), intent(out) :: out_start (:) centroid of the genes family real(kind=real64), intent(out) :: out_shift (:) shift vector of the gene integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/get_shift_components.html"},{"title":"calc_spike_thresholds – TensorOmics","text":"public pure subroutine calc_spike_thresholds(spike_contribs, n_timepoints, n_samples, percentile_val, thresholds, permutation, ierr) Calculate empirical thresholds for spike contributions (using pre-sorted permutations) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: spike_contribs (n_timepoints,n_samples) 2D array of spike contributions integer(kind=int32), intent(in) :: n_timepoints Number of timepoints integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=real64), intent(out) :: thresholds (n_timepoints) 1D array of thresholds for each timepoint integer(kind=int32), intent(in) :: permutation (n_samples,n_timepoints) Pre-computed permutation indices integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_spike_thresholds.html"},{"title":"calc_spike_thresholds_alloc – TensorOmics","text":"public  subroutine calc_spike_thresholds_alloc(spike_contribs, n_timepoints, n_samples, percentile_val, thresholds, ierr) Calculate empirical thresholds for spike contributions (with internal allocations and sorting) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: spike_contribs (n_timepoints,n_samples) 2D array of spike contributions integer(kind=int32), intent(in) :: n_timepoints Number of timepoints integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=real64), intent(out) :: thresholds (n_timepoints) 1D array of thresholds integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_spike_thresholds_alloc.html"},{"title":"calc_integrated_threshold – TensorOmics","text":"public pure subroutine calc_integrated_threshold(contributions, n_samples, percentile_val, threshold, permutation, ierr) Calculate empirical threshold for integrated (trajectory-level) contributions Determines which SAMPLES are significant overall across all genes.\nUses pre-computed permutation array to avoid internal sorting. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: contributions (n_samples) 1D array of integrated contributions integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=real64), intent(out) :: threshold Scalar threshold value integer(kind=int32), intent(in) :: permutation (n_samples) Pre-computed permutation indices for sorted contributions integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_integrated_threshold.html"},{"title":"calc_integrated_threshold_alloc – TensorOmics","text":"public  subroutine calc_integrated_threshold_alloc(contributions, n_samples, percentile_val, threshold, ierr) Calculate empirical threshold for integrated contributions (with internal allocation and sorting) Convenience version that handles workspace allocation and sorting internally.\nFor performance-critical code, use calc_integrated_threshold with pre-computed permutation. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: contributions (n_samples) 1D array of integrated contributions integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=real64), intent(out) :: threshold Scalar threshold value integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_integrated_threshold_alloc.html"},{"title":"detect_outliers_integrated – TensorOmics","text":"public pure subroutine detect_outliers_integrated(contributions, n_samples, threshold, outlier_mask, ierr) Detect outliers in integrated (trajectory-level) contributions Identifies SAMPLES where the integrated contribution exceeds the empirical threshold.\nUsed to find trajectories with significant overall explanatory contributions. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: contributions (n_samples) Array of integrated contributions integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: threshold Scalar threshold value for outlier detection logical, intent(out) :: outlier_mask (n_samples) 1D logical array indicating outliers integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/detect_outliers_integrated.html"},{"title":"detect_outliers_spike – TensorOmics","text":"public pure subroutine detect_outliers_spike(spike_contribs, n_timepoints, n_samples, thresholds, outlier_mask, ierr) Detect outliers in spike contributions Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: spike_contribs (n_timepoints,n_samples) 2D array of spike contributions integer(kind=int32), intent(in) :: n_timepoints Number of timepoints integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: thresholds (n_timepoints) Array of thresholds logical, intent(out) :: outlier_mask (n_timepoints,n_samples) 2D logical array indicating outliers integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/detect_outliers_spike.html"},{"title":"compute_shift_vector_field – TensorOmics","text":"public pure subroutine compute_shift_vector_field(d, n_genes, n_families, expression_vectors, family_centroids, gene_to_centroid, shift_vectors, ierr) Compute the shift vector field for all genes.\nComputes the shift vectors by substracting the corresponding family centroid from the expression vector. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: d Expression vector dimension integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of families real(kind=real64), intent(in) :: expression_vectors (d,n_genes) Gene expression matrix (d × n_genes) real(kind=real64), intent(in) :: family_centroids (d,n_families) Family centroid matrix (d × n_families) integer(kind=int32), intent(in) :: gene_to_centroid (n_genes) Mapping from genes to family centroids to genes of expression_vectors -> family_centroids(:, gene_to_centroid(n)) returns the family centroid of expression_vectors(:,n) real(kind=real64), intent(out) :: shift_vectors (2*d,n_genes) Output, real matrix array, size = 2d x n_genes , stores the centroid of the gene's family in rows 1..d and the shift vectors in rows d+1...2d integer(kind=int32), intent(out) :: ierr Error code: 0 - success, non-zero = error","tags":"","url":"proc/compute_shift_vector_field.html"},{"title":"get_sorted_value – TensorOmics","text":"public  function get_sorted_value(values, sorted_indices, position, ierr) result(sorted_value) Get the value at the sorted position. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (:) Input real array integer(kind=int32), intent(in) :: sorted_indices (:) Permutation index array integer(kind=int32), intent(in) :: position Sorted position (1-based) integer(kind=int32), intent(out) :: ierr Error code Return Value real(kind=real64)","tags":"","url":"proc/get_sorted_value.html"},{"title":"build_bst_index – TensorOmics","text":"public pure subroutine build_bst_index(values, num_values, sorted_indices, left_stack, right_stack, ierr) Build the BST index by sorting indices using values in x. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (num_values) Input real array to be indexed integer(kind=int32), intent(in) :: num_values Number of elements in values array integer(kind=int32), intent(out) :: sorted_indices (num_values) Output permutation index integer(kind=int32), intent(out) :: left_stack (num_values) Manual stack for left indices integer(kind=int32), intent(out) :: right_stack (num_values) Manual stack for right indices integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/build_bst_index.html"},{"title":"bst_range_query – TensorOmics","text":"public pure subroutine bst_range_query(values, sorted_indices, num_values, lower_bound, upper_bound, output_indices, num_matches, ierr) Perform a 1D range query over the sorted index. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (num_values) Input real array integer(kind=int32), intent(in) :: sorted_indices (num_values) Permutation index array (sorted) integer(kind=int32), intent(in) :: num_values Number of elements real(kind=real64), intent(in) :: lower_bound Lower bound of range (inclusive) real(kind=real64), intent(in) :: upper_bound Upper bound of range (inclusive) integer(kind=int32), intent(out) :: output_indices (num_values) Output array of matching indices integer(kind=int32), intent(out) :: num_matches Number of matches found integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/bst_range_query.html"},{"title":"cross_product_orientation_sign – TensorOmics","text":"public pure function cross_product_orientation_sign(a, b, n_dims, selected_axes) result(orientation_sign) Compute orientation sign from cross product of two vectors, using selected axes Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: a (n_dims) real(kind=real64), intent(in) :: b (n_dims) integer(kind=int32), intent(in) :: n_dims integer(kind=int32), intent(in) :: selected_axes (3) Return Value real(kind=real64)","tags":"","url":"proc/cross_product_orientation_sign.html"},{"title":"omics_vector_RAP_projection – TensorOmics","text":"public pure subroutine omics_vector_RAP_projection(vecs, n_axes, n_vecs, vecs_selection_mask, n_selected_vecs, axes_selection_mask, n_selected_axes, projections, ierr) Project selected vectors (e.g. expression vectors) onto the RAP constructed from a selected set of axes. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_axes, n_vecs) :: vecs matrix with expression vectors integer(kind=int32), intent(in) :: n_axes number of axes integer(kind=int32), intent(in) :: n_vecs number of vectors per axis logical, intent(in), dimension(n_vecs) :: vecs_selection_mask .true. for vectors where projection is to be computed integer(kind=int32), intent(in) :: n_selected_vecs count of .true. values in vecs_selection_mask logical, intent(in), dimension(n_axes) :: axes_selection_mask .true. for axes to be included in RAP integer(kind=int32), intent(in) :: n_selected_axes count of .true. values in axes_selection_mask real(kind=real64), intent(out), dimension(n_selected_axes, n_selected_vecs) :: projections projected vectors integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/omics_vector_rap_projection.html"},{"title":"omics_field_RAP_projection – TensorOmics","text":"public pure subroutine omics_field_RAP_projection(vecs, n_axes, n_vecs, vecs_selection_mask, n_selected_vecs, axes_selection_mask, n_selected_axes, projections, ierr) Project selected vector fields (e.g. shift vectors) onto the RAP constructed from a selected set of axes. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(2 * n_axes, n_vecs) :: vecs matrix with vector fields, first n rows mean vector origin, last n rows vector targets integer(kind=int32), intent(in) :: n_axes number of axes integer(kind=int32), intent(in) :: n_vecs number of vectors per axis logical, intent(in), dimension(n_vecs) :: vecs_selection_mask .true. for vectors where projection is to be computed integer(kind=int32), intent(in) :: n_selected_vecs count of .true. values in vecs_selection_mask logical, intent(in), dimension(n_axes) :: axes_selection_mask .true. for axes to be included in RAP integer(kind=int32), intent(in) :: n_selected_axes count of .true. values in axes_selection_mask real(kind=real64), intent(out), dimension(n_selected_axes, n_selected_vecs) :: projections projected vectors integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/omics_field_rap_projection.html"},{"title":"project_selected_vecs_onto_rap – TensorOmics","text":"public pure subroutine project_selected_vecs_onto_rap(selected_vecs, n_selected_axes, n_selected_vecs) Projects selected vectors onto its RAP Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_selected_axes, n_selected_vecs) :: selected_vecs matrix with vectors for selected axes integer(kind=int32), intent(in) :: n_selected_axes number of selected axes integer(kind=int32), intent(in) :: n_selected_vecs number of selected vectors per axis","tags":"","url":"proc/project_selected_vecs_onto_rap.html"},{"title":"clock_hand_angle_between_vectors – TensorOmics","text":"public pure subroutine clock_hand_angle_between_vectors(v1, v2, n_dims, signed_angle, selected_axes_for_signed, ierr) Compute the signed clock hand angle between two RAP-projected and normalized vectors.\nCalculates the signed rotation angle between two normalized vectors in RAP space.\nFor 2D/3D: automatic directionality calculation. For >3D: uses selected axes for directionality. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims) :: v1 First normalized vector in RAP space real(kind=real64), intent(in), dimension(n_dims) :: v2 Second normalized vector in RAP space integer(kind=int32), intent(in) :: n_dims Dimension of both vectors real(kind=real64), intent(out) :: signed_angle Signed angle between vectors in radians [-π, π] integer(kind=int32), intent(in), dimension(3) :: selected_axes_for_signed Indices of 3 axes to use for directionality calculation (ignored if n_dims <= 3) integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/clock_hand_angle_between_vectors.html"},{"title":"clock_hand_angles_for_shift_vectors – TensorOmics","text":"public pure subroutine clock_hand_angles_for_shift_vectors(origins, targets, n_dims, n_vecs, vecs_selection_mask, n_selected_vecs, selected_axes_for_signed, signed_angles, ierr) Compute signed rotation angles between RAP-projected and normalized vector pairs.\nTakes separate arrays of RAP-projected and normalized vectors (e.g. expression centroids and paralogs) and computes the signed rotation angle between corresponding pairs.\nThis measures both magnitude and directionality of angular separation in RAP space. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims, n_vecs) :: origins First set of RAP-projected, normalized vectors (e.g. expression centroids) real(kind=real64), intent(in), dimension(n_dims, n_vecs) :: targets Second set of RAP-projected, normalized vectors (e.g. paralogs) integer(kind=int32), intent(in) :: n_dims Dimension of each vector in RAP space integer(kind=int32), intent(in) :: n_vecs Number of vector pairs logical, intent(in), dimension(n_vecs) :: vecs_selection_mask .true. for vector pairs where angle should be computed integer(kind=int32), intent(in) :: n_selected_vecs Count of .true. values in vecs_selection_mask integer(kind=int32), intent(in), dimension(3) :: selected_axes_for_signed Indices of 3 axes to use for directionality calculation (ignored if n_dims <= 3) real(kind=real64), intent(out), dimension(n_selected_vecs) :: signed_angles Signed rotation angles between vector pairs in radians [-π, π] integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/clock_hand_angles_for_shift_vectors.html"},{"title":"compute_relative_axis_contributions – TensorOmics","text":"public pure subroutine compute_relative_axis_contributions(vec, n_axes, contributions, ierr) Uses ieee_arithmetic Compute fractional contribution of each axis to a RAP-projected and normalized shift vector.\nShared utility: computes fractional contribution of each axis to a RAP-projected and normalized vector. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_axes) :: vec RAP-projected and normalized vector (expression or shift) integer(kind=int32), intent(in) :: n_axes Number of axes (length of vec and contributions) real(kind=real64), intent(out), dimension(n_axes) :: contributions Fractional contribution of each axis (output), values in [0,1], sum to 1 integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/compute_relative_axis_contributions.html"},{"title":"relative_axes_changes_from_shift_vector – TensorOmics","text":"public pure subroutine relative_axes_changes_from_shift_vector(vec, n_axes, contributions, ierr) Compute fractional contribution of each axis to a RAP-projected and normalized shift vector.\nWrapper for shift vectors (e.g. difference between two RAP-projected vectors) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_axes) :: vec RAP-projected and normalized shift vector integer(kind=int32), intent(in) :: n_axes Number of axes real(kind=real64), intent(out), dimension(n_axes) :: contributions Fractional contribution of each axis (output), values in [0,1], sum to 1 integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/relative_axes_changes_from_shift_vector.html"},{"title":"relative_axes_expression_from_expression_vector – TensorOmics","text":"public pure subroutine relative_axes_expression_from_expression_vector(vec, n_axes, contributions, ierr) Compute fractional contribution of each axis to a RAP-projected and normalized expression vector.\nWrapper for single RAP-projected expression vectors Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_axes) :: vec RAP-projected and normalized expression vector integer(kind=int32), intent(in) :: n_axes Number of axes real(kind=real64), intent(out), dimension(n_axes) :: contributions Fractional contribution of each axis (output), values in [0,1], sum to 1 integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/relative_axes_expression_from_expression_vector.html"},{"title":"read_expression_vectors_tsv – TensorOmics","text":"public  subroutine read_expression_vectors_tsv(file_list, gene_ids, expression_vectors, n_header_rows, gene_col, value_cols, start_row, ierr, delimiter) Uses ieee_arithmetic xxh3_hashmap_module Read expression vectors from csv/tsv files Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: file_list (:) List of files to read from character(len=*), intent(in) :: gene_ids (:) Array of gene IDS real(kind=real64), intent(inout) :: expression_vectors (:,:) Array of expression vectors integer(kind=int32), intent(in) :: n_header_rows Number of header rows to skip integer(kind=int32), intent(in) :: gene_col Index of column with gene_ids integer(kind=int32), intent(in) :: value_cols (:) Indicies of columns containing values integer(kind=int32), intent(in) :: start_row Row in the expression vectors to start in integer(kind=int32), intent(out) :: ierr Error code character(len=1), intent(in), optional :: delimiter optional delimiter, default is tab","tags":"","url":"proc/read_expression_vectors_tsv.html"},{"title":"read_gene_ids_from_tsv_file – TensorOmics","text":"public  subroutine read_gene_ids_from_tsv_file(filename, gene_ids, n_header_rows, gene_col, ierr) Only read the gene ids from a tsv file Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename Name of the file character(len=*), intent(out) :: gene_ids (:) gene ids array integer(kind=int32), intent(in) :: n_header_rows number of headers to skip integer(kind=int32), intent(in) :: gene_col Index of the column containing gene ids integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/read_gene_ids_from_tsv_file.html"},{"title":"read_orthofinder_file – TensorOmics","text":"public  subroutine read_orthofinder_file(filename, gene_ids, family_ids, gene_to_fam, ierr) Uses xxh3_hashmap_module Read a family file (Orthofinder) Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename Name of the file character(len=*), intent(in) :: gene_ids (:) gene ids array character(len=*), intent(out) :: family_ids (:) family ids array integer(kind=int32), intent(out) :: gene_to_fam (:) gene to family mapping integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/read_orthofinder_file.html"},{"title":"split_string – TensorOmics","text":"public  subroutine split_string(input, output, ierr, delimiter) Helper subroutine to split strings Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: input Input string to split character(len=:), intent(out), allocatable :: output (:) Output of parts integer(kind=int32), intent(out) :: ierr Error code character(len=1), intent(in), optional :: delimiter delimiter, default is space","tags":"","url":"proc/split_string.html"},{"title":"get_unassigned_mask – TensorOmics","text":"public  subroutine get_unassigned_mask(gene_to_fam, mask, n_genes_kept) Uses iso_fortran_env Helper to create a mask of genes that are unassigned Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping logical, intent(out) :: mask (size(gene_to_fam)) mask for mapping integer(kind=int32), intent(out) :: n_genes_kept number of genes kept","tags":"","url":"proc/get_unassigned_mask.html"},{"title":"apply_unassigned_mask – TensorOmics","text":"public  subroutine apply_unassigned_mask(gene_ids, expression_vectors, gene_to_fam, mask, n_genes_kept, ierr) Applies a precomputed mask to filter out unassigned genes Arguments Type Intent Optional Attributes Name character(len=*), intent(inout), allocatable :: gene_ids (:) gene ids array real(kind=real64), intent(inout), allocatable :: expression_vectors (:,:) expression vectors array integer(kind=int32), intent(inout), allocatable :: gene_to_fam (:) gene to family mapping logical, intent(in) :: mask (:) mask for mapping integer(kind=int32), intent(out) :: n_genes_kept number of genes kept integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/apply_unassigned_mask.html"},{"title":"serialize_char_1d – TensorOmics","text":"public  subroutine serialize_char_1d(arr, filename, ierr) Serialize a 1D character array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, character length, and the array data. Arguments Type Intent Optional Attributes Name character(len=*), intent(in), contiguous :: arr (:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/serialize_char_1d.html"},{"title":"serialize_char_2d – TensorOmics","text":"public  subroutine serialize_char_2d(arr, filename, ierr) Serialize a 2D character array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, character length, and the array data. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: arr (:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/serialize_char_2d.html"},{"title":"serialize_char_3d – TensorOmics","text":"public  subroutine serialize_char_3d(arr, filename, ierr) Serialize a 3D character array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, character length, and the array data. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: arr (:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/serialize_char_3d.html"},{"title":"serialize_char_4d – TensorOmics","text":"public  subroutine serialize_char_4d(arr, filename, ierr) Serialize a 4D character array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, character length, and the array data. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: arr (:,:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/serialize_char_4d.html"},{"title":"serialize_char_5d – TensorOmics","text":"public  subroutine serialize_char_5d(arr, filename, ierr) Serialize a 5D character array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, character length, and the array data. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: arr (:,:,:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/serialize_char_5d.html"},{"title":"serialize_char_nd – TensorOmics","text":"public  subroutine serialize_char_nd(flat, dims, ndim, clen, filename, ierr) Serialize a character array of arbitrary dimensions to a binary file.\nThe file will contain a magic number, type code, dimension, shape, character length, and the array data. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: flat (:) flat array to save integer(kind=int32), intent(in) :: dims (:) dimensions of the array integer(kind=int32), intent(in) :: ndim number of dimensions integer(kind=int32), intent(in) :: clen Length of each string character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"proc/serialize_char_nd.html"},{"title":"create_zip_archive – TensorOmics","text":"public  subroutine create_zip_archive(zip_filename, keys, filenames, ierr) Creates a zip archive with generic file lists Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: zip_filename Name of the zip file to create character(len=*), intent(in) :: keys (:) Array of keys for manifest entries character(len=*), intent(in) :: filenames (:) Array of filenames to add to zip integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/create_zip_archive.html"},{"title":"extract_zip_archive – TensorOmics","text":"public  subroutine extract_zip_archive(zip_filename, keys, filenames, ierr) Uses tox_conversions Extract a zip archive and return all key-value pairs from manifest Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: zip_filename Zip file to read character(len=:), intent(out), allocatable :: keys (:) Array of keys from manifest character(len=:), intent(out), allocatable :: filenames (:) Array of filenames from manifest integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/extract_zip_archive.html"},{"title":"delete_file – TensorOmics","text":"public  subroutine delete_file(filename, ierr) Delete a file from the disk Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename File to delete integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/delete_file.html"},{"title":"get_zip_entry_name – TensorOmics","text":"public  subroutine get_zip_entry_name(zip_handle, entry_index, entry_name, ierr) Uses tox_conversions Helper function to get the name of a ZIP entry Arguments Type Intent Optional Attributes Name type(c_ptr), intent(in) :: zip_handle Zip file connection integer(kind=c_int64_t), intent(in) :: entry_index Index of the entry character(len=:), intent(out), allocatable :: entry_name Name of the entry integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/get_zip_entry_name.html"},{"title":"extract_file_from_zip – TensorOmics","text":"public  subroutine extract_file_from_zip(zip_handle, filename, ierr) Uses tox_conversions Arguments Type Intent Optional Attributes Name type(c_ptr), intent(in) :: zip_handle Zip connection character(len=*), intent(in) :: filename Name of the file to extract integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/extract_file_from_zip.html"},{"title":"add_data_to_zip – TensorOmics","text":"public  subroutine add_data_to_zip(zip_handle, filename, data_source, data_type, ierr) Uses tox_conversions Arguments Type Intent Optional Attributes Name type(c_ptr), intent(in) :: zip_handle Zip connection character(len=*), intent(in) :: filename Filename to add character(len=*), intent(in) :: data_source File path or string content integer(kind=int32), intent(in) :: data_type Type of input integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/add_data_to_zip.html"},{"title":"write_manifest – TensorOmics","text":"public  subroutine write_manifest(keys, filenames, manifest_filename, ierr) Write manifest from given key-value pairs Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: keys (:) Array of keys for manifest entries character(len=*), intent(in) :: filenames (:) Array of filenames for manifest entries character(len=*), intent(in) :: manifest_filename Name of the manifest file (should be manifest.txt) integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/write_manifest.html"},{"title":"read_manifest_generic – TensorOmics","text":"public  subroutine read_manifest_generic(manifest_filename, keys, values, ierr) Read manifest file and return key-value pairs Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: manifest_filename Filename of the manifest (should be manifest.txt) character(len=:), intent(out), allocatable :: keys (:) Array of keys from manifest character(len=:), intent(out), allocatable :: values (:) Array of values from manifest integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/read_manifest_generic.html"},{"title":"extract_and_parse_manifest – TensorOmics","text":"public  subroutine extract_and_parse_manifest(zip_handle, keys, filenames, ierr) Uses tox_conversions Extract and parse the manifest file for generic key-value pairs. Arguments Type Intent Optional Attributes Name type(c_ptr), intent(in) :: zip_handle Zip file connection character(len=:), intent(out), allocatable :: keys (:) Array of keys from manifest character(len=:), intent(out), allocatable :: filenames (:) Array of filenames from manifest integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/extract_and_parse_manifest.html"},{"title":"save_tox_data – TensorOmics","text":"public  subroutine save_tox_data(zip_filename, ierr, gene_ids, gene_ids_file, expression, expression_file, gene_to_family, gene_to_family_file, family_ids, family_ids_file, family_centroids, family_centroids_file, shift_vectors, shift_vectors_file) Save standard tox data Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: zip_filename Zip filename integer(kind=int32), intent(out) :: ierr Error code character(len=*), intent(in), optional :: gene_ids (:) Gene ids array, will be saved if provided character(len=*), intent(in), optional :: gene_ids_file Name of the gene ids file real(kind=real64), intent(in), optional :: expression (:,:) Expression vectors array, will be saved if provided character(len=*), intent(in), optional :: expression_file Name of the expression file integer(kind=int32), intent(in), optional :: gene_to_family (:) Gene to family mapping array, will be saved if provided character(len=*), intent(in), optional :: gene_to_family_file Name of the gene to family mapping file character(len=*), intent(in), optional :: family_ids (:) Family ids array, will be saved if provided character(len=*), intent(in), optional :: family_ids_file Name of the family ids file real(kind=real64), intent(in), optional :: family_centroids (:,:) Family centroids array, will be saved if provided character(len=*), intent(in), optional :: family_centroids_file Name of the family centroids file real(kind=real64), intent(in), optional :: shift_vectors (:,:) Shift vectors array, will be saved if provided character(len=*), intent(in), optional :: shift_vectors_file Name of the shift vectors file","tags":"","url":"proc/save_tox_data.html"},{"title":"read_tox_data – TensorOmics","text":"public  subroutine read_tox_data(zip_filename, ierr, gene_ids, gene_ids_file, expression, expression_file, gene_to_family, gene_to_family_file, family_ids, family_ids_file, family_centroids, family_centroids_file, shift_vectors, shift_vectors_file) Uses tox_data_read_write array_utils iso_fortran_env Read standard tox from a zip archive Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: zip_filename Name of the zipfile integer(kind=int32), intent(out) :: ierr Error code character(len=:), intent(out), optional, allocatable :: gene_ids (:) Gene IDs array, will be populated if provided character(len=:), intent(out), optional, allocatable :: gene_ids_file Name of the gene ids file in the zip archive real(kind=real64), intent(out), optional, allocatable :: expression (:,:) Expression vectors array, will be populated if provided character(len=:), intent(out), optional, allocatable :: expression_file Name of the expression vectors file in the zip archive integer(kind=int32), intent(out), optional, allocatable :: gene_to_family (:) Gene to family mapping array, will be populated if provided character(len=:), intent(out), optional, allocatable :: gene_to_family_file Name of the gene to family mapping file in the zip archive character(len=:), intent(out), optional, allocatable :: family_ids (:) Family IDs array, will be populated if provided character(len=:), intent(out), optional, allocatable :: family_ids_file Name of the family ids file in the zip archive real(kind=real64), intent(out), optional, allocatable :: family_centroids (:,:) Family centroids array, will be populated if provided character(len=:), intent(out), optional, allocatable :: family_centroids_file Name of the family centroids file in the zip archive real(kind=real64), intent(out), optional, allocatable :: shift_vectors (:,:) Shift vectors array, will be populated if provided character(len=:), intent(out), optional, allocatable :: shift_vectors_file Name of the shift vectors file in the zip archive","tags":"","url":"proc/read_tox_data.html"},{"title":"malloc – TensorOmics","text":"interface public  function malloc(size) bind(C, name=\"malloc\") Arguments Type Intent Optional Attributes Name integer(kind=c_size_t), value :: size Return Value type(c_ptr)","tags":"","url":"interface/malloc.html"},{"title":"zip_open – TensorOmics","text":"interface public  function zip_open(path, flags, errorp) bind(C, name=\"zip_open\") Arguments Type Intent Optional Attributes Name character(kind=c_char, len=1), dimension(*) :: path integer(kind=c_int), value :: flags integer(kind=c_int), intent(out) :: errorp Return Value type(c_ptr)","tags":"","url":"interface/zip_open.html"},{"title":"zip_close – TensorOmics","text":"interface public  function zip_close(archive) bind(C, name=\"zip_close\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive Return Value integer(kind=c_int)","tags":"","url":"interface/zip_close.html"},{"title":"zip_file_add – TensorOmics","text":"interface public  function zip_file_add(archive, name, source, flags) bind(C, name=\"zip_file_add\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive character(kind=c_char, len=1), dimension(*) :: name type(c_ptr), value :: source integer(kind=c_int), value :: flags Return Value integer(kind=c_int64_t)","tags":"","url":"interface/zip_file_add.html"},{"title":"zip_source_buffer – TensorOmics","text":"interface public  function zip_source_buffer(archive, data, len, freep) bind(C, name=\"zip_source_buffer\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive type(c_ptr), value :: data integer(kind=c_size_t), value :: len integer(kind=c_int), value :: freep Return Value type(c_ptr)","tags":"","url":"interface/zip_source_buffer.html"},{"title":"zip_set_file_compression – TensorOmics","text":"interface public  function zip_set_file_compression(archive, index, comp, flags) bind(C, name=\"zip_set_file_compression\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive integer(kind=c_int64_t), value :: index integer(kind=c_int), value :: comp integer(kind=c_int), value :: flags Return Value integer(kind=c_int)","tags":"","url":"interface/zip_set_file_compression.html"},{"title":"zip_fopen – TensorOmics","text":"interface public  function zip_fopen(archive, fname, flags) bind(C, name=\"zip_fopen\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive character(kind=c_char, len=1), dimension(*) :: fname integer(kind=c_int), value :: flags Return Value type(c_ptr)","tags":"","url":"interface/zip_fopen.html"},{"title":"zip_fread – TensorOmics","text":"interface public  function zip_fread(file, buf, nbytes) bind(C, name=\"zip_fread\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: file type(c_ptr), value :: buf integer(kind=c_size_t), value :: nbytes Return Value integer(kind=c_int64_t)","tags":"","url":"interface/zip_fread.html"},{"title":"zip_fclose – TensorOmics","text":"interface public  function zip_fclose(file) bind(C, name=\"zip_fclose\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: file Return Value integer(kind=c_int)","tags":"","url":"interface/zip_fclose.html"},{"title":"zip_get_num_entries – TensorOmics","text":"interface public  function zip_get_num_entries(archive, flags) bind(C, name=\"zip_get_num_entries\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive integer(kind=c_int), value :: flags Return Value integer(kind=c_int64_t)","tags":"","url":"interface/zip_get_num_entries.html"},{"title":"zip_get_name – TensorOmics","text":"interface public  function zip_get_name(archive, index, flags) bind(C, name=\"zip_get_name\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: archive integer(kind=c_int64_t), value :: index integer(kind=c_int), value :: flags Return Value type(c_ptr)","tags":"","url":"interface/zip_get_name.html"},{"title":"free – TensorOmics","text":"interface public  subroutine free(ptr) bind(C, name=\"free\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: ptr","tags":"","url":"interface/free.html"},{"title":"zip_source_free – TensorOmics","text":"interface public  subroutine zip_source_free(source) bind(C, name=\"zip_source_free\") Arguments Type Intent Optional Attributes Name type(c_ptr), value :: source","tags":"","url":"interface/zip_source_free.html"},{"title":"is_err – TensorOmics","text":"public pure function is_err(ierr) result(not_ok) check if the error code indicates error Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ierr Return Value logical","tags":"","url":"proc/is_err.html"},{"title":"is_ok – TensorOmics","text":"public pure function is_ok(ierr) result(ok) check if the error code indicates success Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ierr Return Value logical","tags":"","url":"proc/is_ok.html"},{"title":"set_ok – TensorOmics","text":"public pure subroutine set_ok(ierr) set the error code to OK, use at beginning of procedures Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out) :: ierr","tags":"","url":"proc/set_ok.html"},{"title":"set_err – TensorOmics","text":"public pure subroutine set_err(ierr, code) set the error code to specific code Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(inout) :: ierr integer(kind=int32), intent(in) :: code","tags":"","url":"proc/set_err.html"},{"title":"set_err_once – TensorOmics","text":"public pure subroutine set_err_once(ierr, code) set the error code only if it is currently OK, use to prevent overwriting first error Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(inout) :: ierr integer(kind=int32), intent(in) :: code","tags":"","url":"proc/set_err_once.html"},{"title":"check_io_stat – TensorOmics","text":"public pure subroutine check_io_stat(ios, ierr) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ios integer(kind=int32), intent(out) :: ierr","tags":"","url":"proc/check_io_stat.html"},{"title":"validate_dimension_size – TensorOmics","text":"public pure subroutine validate_dimension_size(n, ierr) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n integer(kind=int32), intent(out) :: ierr","tags":"","url":"proc/validate_dimension_size.html"},{"title":"validate_in_range_int – TensorOmics","text":"public pure subroutine validate_in_range_int(val, ierr, min, max) Validates min<=e<=max for all elements e of an array Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: val value to be validated integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in), optional :: min lower bound for a value, default is lowest 32-bit integer -> -huge(1_int32) integer(kind=int32), intent(in), optional :: max upper bound for a value, default is largest 32-bit integer -> huge(1_int32)","tags":"","url":"proc/validate_in_range_int.html"},{"title":"validate_all_in_range_int – TensorOmics","text":"public pure subroutine validate_all_in_range_int(array, n_elements, ierr, min, max) Validates min<=e<=max for all elements e of an array Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in), dimension(n_elements) :: array Array to be validated integer(kind=int32), intent(in) :: n_elements Size of array integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in), optional :: min lower bound for a value, default is lowest 32-bit integer -> -huge(1_int32) integer(kind=int32), intent(in), optional :: max upper bound for a value, default is largest 32-bit integer -> huge(1_int32)","tags":"","url":"proc/validate_all_in_range_int.html"},{"title":"validate_in_range_real – TensorOmics","text":"public pure subroutine validate_in_range_real(val, ierr, min, max) Validates min<=e<=max AND e/=NaN for all elements e of an array Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: val value to be validated integer(kind=int32), intent(out) :: ierr Error code real(kind=real64), intent(in), optional :: min lower bound for a value, default is lowest 64-bit float -> -huge(1.0_real64) real(kind=real64), intent(in), optional :: max upper bound for a value, default is largest 64-bit float -> huge(1.0_real64)","tags":"","url":"proc/validate_in_range_real.html"},{"title":"validate_all_in_range_real – TensorOmics","text":"public pure subroutine validate_all_in_range_real(array, n_elements, ierr, min, max) Validates min<=e<=max AND e/=NaN for all elements e of an array Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_elements) :: array Array to be validated integer(kind=int32), intent(in) :: n_elements Size of array integer(kind=int32), intent(out) :: ierr Error code real(kind=real64), intent(in), optional :: min lower bound for a value, default is lowest 64-bit float -> -huge(1.0_real64) real(kind=real64), intent(in), optional :: max upper bound for a value, default is largest 64-bit float -> huge(1.0_real64)","tags":"","url":"proc/validate_all_in_range_real.html"},{"title":"validate_distance_matrix – TensorOmics","text":"public pure subroutine validate_distance_matrix(distances, n, ierr, min, max) Strictly validates a distance matrix of euclidean distances.\nThis means that distance X->X is exactly zero (no tolerance)\nand X->Y is exactly the same as Y->X (no tolerance). Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n, n) :: distances Matrix to be validated integer(kind=int32), intent(in) :: n Number of columns and rows of distances integer(kind=int32), intent(out) :: ierr Error code real(kind=real64), intent(in), optional :: min lower bound for a distance value, default is zero to have only positives real(kind=real64), intent(in), optional :: max upper bound for a distance value, default is largest 64-bit float -> huge(1.0_real64)","tags":"","url":"proc/validate_distance_matrix.html"},{"title":"normalization_pipeline – TensorOmics","text":"public pure subroutine normalization_pipeline(n_genes, n_tissues, input_matrix, buf_stddev, buf_quant, buf_avg, buf_log, temp_col, rank_means, perm, stack_left, stack_right, max_stack, group_s, group_c, n_grps, ierr) Complete normalization pipeline for gene expression data.\nPerforms: std dev normalization, quantile normalization, replicate averaging, log2(x+1) transformation.\nFinal result is in buf_log. If fold change is needed, call calc_fchange separately. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes (rows) integer(kind=int32), intent(in) :: n_tissues Number of tissues (columns) real(kind=real64), intent(in) :: input_matrix (n_genes*n_tissues) Flattened input matrix (n_genes * n_tissues), column-major real(kind=real64), intent(out) :: buf_stddev (n_genes*n_tissues) Buffer for std dev normalization (n_genes * n_tissues) real(kind=real64), intent(out) :: buf_quant (n_genes*n_tissues) Buffer for quantile normalization (n_genes * n_tissues) real(kind=real64), intent(out) :: buf_avg (n_genes*n_grps) Buffer for replicate averaging (n_genes * n_grps) real(kind=real64), intent(out) :: buf_log (n_genes*n_grps) Buffer for log2(x+1) transformation (n_genes * n_grps) real(kind=real64), intent(out) :: temp_col (n_genes) Temporary column vector for sorting (n_genes) real(kind=real64), intent(out) :: rank_means (n_genes) Buffer for rank means (n_genes) integer(kind=int32), intent(out) :: perm (n_genes) Permutation vector for sorting (n_genes) integer(kind=int32), intent(out) :: stack_left (max_stack) Left stack for quicksort (max_stack) integer(kind=int32), intent(out) :: stack_right (max_stack) Right stack for quicksort (max_stack) integer(kind=int32), intent(in) :: max_stack Stack size for quicksort integer(kind=int32), intent(in) :: group_s (n_grps) Start column index for each replicate group (n_grps) integer(kind=int32), intent(in) :: group_c (n_grps) Number of columns per replicate group (n_grps) integer(kind=int32), intent(in) :: n_grps Number of replicate groups integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/normalization_pipeline.html"},{"title":"normalize_by_std_dev – TensorOmics","text":"public pure subroutine normalize_by_std_dev(n_genes, n_tissues, input_matrix, output_matrix, ierr) Normalizes each gene's expression vector using sqrt(mean(x&#94;2)) across tissues (not classical standard deviation). Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes (rows) integer(kind=int32), intent(in) :: n_tissues Number of tissues (columns) real(kind=real64), intent(in) :: input_matrix (n_genes*n_tissues) Flattened input matrix of gene expression values (column-major) real(kind=real64), intent(out) :: output_matrix (n_genes*n_tissues) Output normalized matrix (same shape as input) integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/normalize_by_std_dev.html"},{"title":"quantile_normalization – TensorOmics","text":"public pure subroutine quantile_normalization(n_genes, n_tissues, input_matrix, output_matrix, temp_col, rank_means, perm, stack_left, stack_right, max_stack, ierr) Uses f42_utils Quantile normalization of a gene expression matrix (F42-compliant).\nComputes average expression per rank across tissues. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes (rows) integer(kind=int32), intent(in) :: n_tissues Number of tissues (columns) real(kind=real64), intent(in) :: input_matrix (n_genes*n_tissues) Flattened input matrix (column-major) real(kind=real64), intent(out) :: output_matrix (n_genes*n_tissues) Output normalized matrix (same shape as input) real(kind=real64), intent(out) :: temp_col (n_genes) Temporary vector for column sorting (size n_genes) real(kind=real64), intent(out) :: rank_means (n_genes) Preallocated vector to store rank means (size n_genes) integer(kind=int32), intent(out) :: perm (n_genes) Permutation vector (size n_genes) integer(kind=int32), intent(out) :: stack_left (max_stack) Manual quicksort stack (≥ log2(n_genes) + 10) integer(kind=int32), intent(out) :: stack_right (max_stack) Manual quicksort stack (same size as stack_left) integer(kind=int32), intent(in) :: max_stack Stack size passed from R integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/quantile_normalization.html"},{"title":"log2_transformation – TensorOmics","text":"public pure subroutine log2_transformation(n_genes, n_tissues, input_matrix, output_matrix, ierr) Apply log2(x + 1) transformation to each element of the input matrix.\nThis subroutine performs element-wise log2(x + 1) transformation on a\nmatrix flattened in column-major order. The log2 is computed via: log(x + 1) / log(2) , which is numerically equivalent and avoids the\nnon-portable log2 intrinsic for compatibility with WebAssembly (WASM). Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes (rows) integer(kind=int32), intent(in) :: n_tissues Number of tissues (columns) real(kind=real64), intent(in) :: input_matrix (n_genes*n_tissues) Flattened input matrix (size: n_genes * n_tissues) real(kind=real64), intent(out) :: output_matrix (n_genes*n_tissues) Output matrix (same size as input) integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/log2_transformation.html"},{"title":"calc_tiss_avg – TensorOmics","text":"public pure subroutine calc_tiss_avg(n_gene, n_grps, group_s, group_c, input_matrix, output_matrix, ierr) Calculate tissue averages by averaging replicates within each group.\nFor each group of tissue replicates, this subroutine computes the average\nexpression per gene. The input matrix is column-major, flattened as a 1D array. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_gene Number of genes (rows) integer(kind=int32), intent(in) :: n_grps Number of tissue groups integer(kind=int32), intent(in) :: group_s (n_grps) Start column index for each group (length: n_grps) integer(kind=int32), intent(in) :: group_c (n_grps) Number of columns per group (length: n_grps) real(kind=real64), intent(in) :: input_matrix (n_gene*sum(group_c)) Flattened input matrix (length: n_gene * n_col) real(kind=real64), intent(out) :: output_matrix (n_gene*n_grps) Flattened output matrix (length: n_gene * n_grps) integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_tiss_avg.html"},{"title":"calc_fchange – TensorOmics","text":"public pure subroutine calc_fchange(n_genes, n_cols, n_pairs, control_cols, cond_cols, i_matrix, o_matrix, ierr) Calculate log2 fold changes between condition and control columns.\nFor each control-condition pair, this subroutine computes the log2 fold change by subtracting the expression value in the control column from the corresponding\nvalue in the condition column, for all genes. The input matrix must be column-major and flattened as a 1D array. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes (rows) integer(kind=int32), intent(in) :: n_cols Number of columns in the input matrix integer(kind=int32), intent(in) :: n_pairs Number of control-condition pairs integer(kind=int32), intent(in) :: control_cols (n_pairs) Control column indices (length n_pairs) integer(kind=int32), intent(in) :: cond_cols (n_pairs) Condition column indices (length n_pairs) real(kind=real64), intent(in) :: i_matrix (n_genes*n_cols) Input matrix, flattened (length: n_genes × n_cols) real(kind=real64), intent(out) :: o_matrix (n_genes*n_pairs) Output matrix for fold changes (length: n_genes × n_pairs) integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"proc/calc_fchange.html"},{"title":"compute_tissue_versatility – TensorOmics","text":"public pure subroutine compute_tissue_versatility(n_axes, n_vectors, expression_vectors, exp_vecs_selection_index, n_selected_vectors, axes_selection, n_selected_axes, tissue_versatilities, tissue_angles_deg, ierr) Computes normalized tissue versatility for selected expression vectors.\nThe metric is based on the angle between each gene expression vector and the space diagonal.\nVersatility is normalized to [0, 1], where 0 means uniform expression and 1 means expression in only one axis. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_axes Number of axes (tissues/dimensions) integer(kind=int32), intent(in) :: n_vectors Number of expression vectors (genes) real(kind=real64), intent(in) :: expression_vectors (n_axes,n_vectors) 2D array (n_axes, n_vectors), each column is a gene expression vector logical, intent(in) :: exp_vecs_selection_index (n_vectors) Logical array (n_vectors), .TRUE. for vectors to process integer(kind=int32), intent(in) :: n_selected_vectors Number of selected expression vectors (count of .TRUE. in exp_vecs_selection_index) logical, intent(in) :: axes_selection (n_axes) Logical array (n_axes), .TRUE. for axes to include in calculation integer(kind=int32), intent(in) :: n_selected_axes Number of selected axes (count of .TRUE. in axes_selection) real(kind=real64), intent(out) :: tissue_versatilities (n_selected_vectors) Output, real array, length = n_selected_vectors, stores the calculated tissue versatilities real(kind=real64), intent(out) :: tissue_angles_deg (n_selected_vectors) Output, real array, length = n_selected_vectors, stores the calculated angles in degrees integer(kind=int32), intent(out) :: ierr Error code: 0 = success, non-zero = error","tags":"","url":"proc/compute_tissue_versatility.html"},{"title":"serialize_real – TensorOmics","text":"Uses iso_c_binding iso_fortran_env safeguard array_utils tox_errors Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: ARRAY_TYPE_REAL = 2 Subroutines public  subroutine serialize_real_1d (arr, filename, ierr) Serialize a 1D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_real_2d (arr, filename, ierr) Serialize a 2D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:,:) array to save character(len=*), intent(in) :: filename filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_real_3d (arr, filename, ierr) Serialize a 3D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:,:,:) array to save character(len=*), intent(in) :: filename filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_real_4d (arr, filename, ierr) Serialize a 4D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:,:,:,:) array to save character(len=*), intent(in) :: filename filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_real_5d (arr, filename, ierr) Serialize a 5D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:,:,:,:,:) array to save character(len=*), intent(in) :: filename filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_real_nd (arr, dims, ndim, filename, ierr) Writes serialized real array from R to file with metdata. Read more… Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:) array to save integer(kind=int32), intent(in) :: dims (:) Dimensions of the array integer(kind=int32), intent(in) :: ndim Number of dimensions character(len=*), intent(in) :: filename filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"module/serialize_real.html"},{"title":"config – TensorOmics","text":"Variables Type Visibility Attributes Name Initial integer, public, parameter :: alignment = 32 logical, public :: DEBUG = .false. logical, public :: debug_hashing = .false.","tags":"","url":"module/config.html"},{"title":"int_deserialize_mod – TensorOmics","text":"Module for deserializing integer arrays from files Uses iso_c_binding iso_fortran_env safeguard array_utils tox_errors Subroutines public  subroutine deserialize_int_1d (arr, filename, ierr) Deserialize a flat integer array from a file\nDirectly deserialize a 1D integer array from a file Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out) :: arr (:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_int_2d (arr, filename, ierr) Directly deserialize a 2D integer array from a file Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out) :: arr (:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_int_3d (arr, filename, ierr) Directly deserialize a 3D integer array from a file Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out) :: arr (:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_int_4d (arr, filename, ierr) Directly deserialize a 4D integer array from a file Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out) :: arr (:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the File integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_int_5d (arr, filename, ierr) Directly deserialize a 5D integer array from a file Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out) :: arr (:,:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/int_deserialize_mod.html"},{"title":"tox_gene_centroids – TensorOmics","text":"Module for computing expression centroids of gene families. Uses iso_fortran_env safeguard tox_errors Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: GROUP_ORTHOLOGS = 0 integer(kind=int32), public, parameter :: GROUP_ALL = 1 Subroutines public pure subroutine mean_vector (expression_vectors, n_axes, n_genes, gene_indices, n_selected_genes, centroid, ierr) Computes the element-wise mean for a given set of vectors. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: expression_vectors (n_axes,n_genes) The input matrix of all gene expression vectors (n_axes x n_genes). integer(kind=int32), intent(in) :: n_axes Number of axes (tissues/dimensions). integer(kind=int32), intent(in) :: n_genes Total number of genes in the input matrix. integer(kind=int32), intent(in) :: gene_indices (n_selected_genes) An array containing the column indices of the selected genes in 'expression_vectors'. integer(kind=int32), intent(in) :: n_selected_genes The number of genes in the current family to be averaged. real(kind=real64), intent(out) :: centroid (n_axes) The output vector representing the computed centroid. integer(kind=int32), intent(out) :: ierr Error code: 0 - success, non-zero = error public pure subroutine group_centroid (expression_vectors, n_axes, n_genes, gene_to_family, n_families, centroid_matrix, mode, selected_indices, ierr, ortholog_set) Iterates over families, filters gene indices, and computes centroids. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: expression_vectors (n_axes,n_genes) The input matrix of all gene expression vectors (n_axes x n_genes). integer(kind=int32), intent(in) :: n_axes Number of axes (tissues/dimensions). integer(kind=int32), intent(in) :: n_genes Total number of genes in the 'expression_vectors' matrix. integer(kind=int32), intent(in) :: gene_to_family (n_genes) An array mapping each gene (by index) to a family ID. integer(kind=int32), intent(in) :: n_families Total number of gene families to compute centroids for. real(kind=real64), intent(out) :: centroid_matrix (n_axes,n_families) The output matrix (n_axes x n_families) to store the computed centroids. integer(kind=int32), intent(in) :: mode A integer constant indicating the mode of operation (\"all\" or \"orthologs\"). integer(kind=int32), intent(out) :: selected_indices (n_genes) An output array for storing indices. integer(kind=int32), intent(out) :: ierr Error code: 0 - success, non-zero = error logical, intent(in), optional :: ortholog_set (n_genes) A logical array indicating if a gene is part of a specific subset (e.g., orthologs).","tags":"","url":"module/tox_gene_centroids.html"},{"title":"tox_euclidean_distance – TensorOmics","text":"Module with Euclidean distance computation routines for tensor omics. Uses iso_fortran_env safeguard Subroutines public pure subroutine euclidean_distance (vec1, vec2, d, result) Compute the Euclidean distance between two vectors.\nCalculates the L2 norm: result = sqrt(sum((vec1_i - vec2_i)&#94;2)) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: vec1 (d) First expression vector real(kind=real64), intent(in) :: vec2 (d) Second expression vector integer(kind=int32), intent(in) :: d Dimension of both vectors real(kind=real64), intent(out) :: result Output scalar distance public pure subroutine distance_to_centroid (n_genes, n_families, genes, centroids, gene_to_fam, distances, d) Compute distance from each gene to its corresponding family centroid.\nFor each gene, extracts its expression vector and the centroid of its assigned family, then computes the Euclidean distance between them. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of gene families real(kind=real64), intent(in) :: genes (d,n_genes) Gene expression matrix (d × n_genes), column-major real(kind=real64), intent(in) :: centroids (d,n_families) Family centroid matrix (d × n_families), column-major integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Gene-to-family mapping (1-based indexing) real(kind=real64), intent(out) :: distances (n_genes) Output distances array integer(kind=int32), intent(in) :: d Expression vector dimension","tags":"","url":"module/tox_euclidean_distance.html"},{"title":"serialize_int – TensorOmics","text":"Module for serializing integer arrays to binary files. Uses iso_c_binding iso_fortran_env safeguard array_utils tox_errors Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: ARRAY_TYPE_INT = 1 Subroutines public  subroutine serialize_int_1d (arr, filename, ierr) Serialize a 1D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_int_2d (arr, filename, ierr) Serialize a 2D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32) :: ierr error code public  subroutine serialize_int_3d (arr, filename, ierr) Serialize a 3D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32) :: ierr error code public  subroutine serialize_int_4d (arr, filename, ierr) Serialize a 4D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:,:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_int_5d (arr, filename, ierr) Serialize a 5D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:,:,:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_int_nd (arr, dims, ndim, filename, ierr) Serialize a flat integer array with specified dimensions and number of dimensions to a binary file. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:) Flat integer array to serialize integer(kind=int32), intent(in) :: dims (:) Dimensions of the array integer(kind=int32), intent(in) :: ndim Number of dimensions character(len=*), intent(in) :: filename filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"module/serialize_int.html"},{"title":"kd_tree – TensorOmics","text":"Uses f42_utils safeguard iso_fortran_env tox_errors Subroutines public pure subroutine build_kd_index (points, num_dimensions, num_points, kd_indices, dimension_order, workspace, value_buffer, permutation, left_stack, right_stack, recursion_stack, ierr) Build a k-d tree index using a stack-based, non-recursive approach.\nInitialize kd_indices to 1:num_points (original indices)\nChoose split dimension by cycling through dimension_order\nFind median index\nPartition kd_indices(left_idx:right_idx) by points(current_dim, kd_indices(:))\nPush right and left intervals onto stack Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: points (num_dimensions,num_points) Data points integer(kind=int32), intent(in) :: num_dimensions Number of dimensions integer(kind=int32), intent(in) :: num_points Number of points integer(kind=int32), intent(out) :: kd_indices (num_points) Output index array (k-d tree order) integer(kind=int32), intent(in) :: dimension_order (num_dimensions) Dimension order (by variance) integer(kind=int32), intent(out) :: workspace (num_points) Workspace array real(kind=real64), intent(out) :: value_buffer (num_points) Workspace for sorting integer(kind=int32), intent(out) :: permutation (num_points) Workspace for sorting integer(kind=int32), intent(out) :: left_stack (num_points) Workspace for sorting integer(kind=int32), intent(out) :: right_stack (num_points) Workspace for sorting integer(kind=int32), intent(out) :: recursion_stack (3,num_points) Stack for l, r, depth integer(kind=int32), intent(out) :: ierr Error code public pure subroutine build_spherical_kd (vectors, num_dimensions, num_vectors, sphere_indices, dimension_order, workspace, value_buffer, permutation, left_stack, right_stack, recursion_stack, ierr) Build spherical k-d tree index Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: vectors (num_dimensions,num_vectors) Input unit vectors integer(kind=int32), intent(in) :: num_dimensions Number of dimensions integer(kind=int32), intent(in) :: num_vectors Number of vectors integer(kind=int32), intent(out) :: sphere_indices (num_vectors) Output index array integer(kind=int32), intent(out) :: dimension_order (num_dimensions) Dimension order integer(kind=int32), intent(out) :: workspace (num_vectors) Workspace array real(kind=real64), intent(out) :: value_buffer (num_vectors) Value buffer integer(kind=int32), intent(out) :: permutation (num_vectors) Permutation array integer(kind=int32), intent(out) :: left_stack (num_vectors) Left stack integer(kind=int32), intent(out) :: right_stack (num_vectors) Right stack integer(kind=int32), intent(out) :: recursion_stack (3,num_vectors) Stack for recursive calls integer(kind=int32), intent(out) :: ierr Error code public pure subroutine get_kd_point (points, kd_indices, position, point_values, ierr) Get point from KD index Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: points (:,:) Input points integer(kind=int32), intent(in) :: kd_indices (:) KD index array integer(kind=int32), intent(in) :: position Position in index real(kind=real64), intent(out) :: point_values (:) Output point values integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/kd_tree.html"},{"title":"tox_conversions – TensorOmics","text":"Uses iso_c_binding iso_fortran_env tox_errors Subroutines public elemental subroutine c_int_as_logical (c_val, f_val) Converts a c_int value to logical, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in) :: c_val the element containing the c variant of the number logical, intent(out) :: f_val the element that will hold the logical representation of the c_int: 0 means .false. , else .true. public elemental subroutine logical_as_c_int (f_val, c_val) Converts a logical value to c_int, elemental -> any shape Arguments Type Intent Optional Attributes Name logical, intent(in) :: f_val the element containing the fortran variant of the number integer(kind=c_int), intent(out) :: c_val the element that will hold the c_int representation of the logical: 0 if .false. , else 1 public elemental subroutine c_char_as_char (c_val, f_val) Converts a c_char value to fortran character, elemental -> any shape Arguments Type Intent Optional Attributes Name character(kind=c_char, len=1), intent(in) :: c_val the element containing the c variant of the character character(len=1), intent(out) :: f_val the element that will hold the fortran char representation of the c_char public elemental subroutine char_as_c_char (f_val, c_val) Converts a character value to c_char, elemental -> any shape Arguments Type Intent Optional Attributes Name character(len=1), intent(in) :: f_val the element containing the fortran variant of the character character(kind=c_char, len=1), intent(out) :: c_val the element that will hold the c_char (ASCII) representation of the character public pure subroutine c_char_1d_as_string (c_char_array, str_out, ierr) Converts a 1D c_char array to string Arguments Type Intent Optional Attributes Name character(kind=c_char, len=1), intent(in), dimension(:) :: c_char_array c int array, representing characters character(len=:), intent(out), allocatable :: str_out Fortran string, length determined by occuring null char in c_char_array integer(kind=int32), intent(out) :: ierr Error code public pure subroutine string_as_c_char_1d (str, c_char_array) Converts a string to 1D c_char array Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: str Fortran string to be converted character(kind=c_char, len=1), intent(out), dimension(:) :: c_char_array c int array, representing chars of str , will always end with null char. If array too small, it will hold fitting trimmed str . public pure subroutine c_char_2d_as_string (c_char_array, str_out, ierr) Converts a 2D c_char array to 1D string array Arguments Type Intent Optional Attributes Name character(kind=c_char, len=1), intent(in), dimension(:, :) :: c_char_array c int array, columns as ascii arrays character(len=:), intent(out), dimension(:), allocatable :: str_out Fortran array of resulting strings integer(kind=int32), intent(out) :: ierr Error code public pure subroutine string_as_c_char_2d (strings, c_char_array) Converts a 1D string array to 2D c_char array Arguments Type Intent Optional Attributes Name character(len=*), intent(in), dimension(:) :: strings Fortran array of strings character(kind=c_char, len=1), intent(out), dimension(:, :) :: c_char_array c int array, columns as ascii arrays public elemental subroutine int32_as_c_int64 (f_val, c_val) Converts int32 to c_int64_t, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: f_val the element containing the fortran variant of the number integer(kind=c_int64_t), intent(out) :: c_val the element that will hold the c_int64_t representation public elemental subroutine c_int64_as_int32 (c_val, f_val) Converts c_int64_t to int32, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=c_int64_t), intent(in) :: c_val the element containing the c variant of the number integer(kind=int32), intent(out) :: f_val the element that will hold the int32 representation public elemental subroutine int32_as_c_size (f_val, c_val) Converts int32 to c_size_t, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: f_val the element containing the fortran variant of the number integer(kind=c_size_t), intent(out) :: c_val the element that will hold the c_size_t representation public elemental subroutine c_size_as_int32 (c_val, f_val) Converts c_size_t to int32, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=c_size_t), intent(in) :: c_val the element containing the c variant of the number integer(kind=int32), intent(out) :: f_val the element that will hold the int32 representation public elemental subroutine c_int64_as_c_size (c64_val, csize_val) Converts c_int64_t to c_size_t, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=c_int64_t), intent(in) :: c64_val the element containing the c_int64_t value integer(kind=c_size_t), intent(out) :: csize_val the element that will hold the c_size_t representation public elemental subroutine c_size_as_c_int64 (csize_val, c64_val) Converts c_size_t to c_int64_t, elemental -> any shape Arguments Type Intent Optional Attributes Name integer(kind=c_size_t), intent(in) :: csize_val the element containing the c_size_t value integer(kind=c_int64_t), intent(out) :: c64_val the element that will hold the c_int64_t representation","tags":"","url":"module/tox_conversions.html"},{"title":"array_utils – TensorOmics","text":"Module for array utilities Uses iso_fortran_env safeguard tox_errors Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: ARRAY_FILE_MAGIC = int(z'46413230', int32) Magic number for array files Subroutines public  subroutine check_okay_ioerror (ioerror, ierr, msg, unit) Check I/O error and set ierr accordingly Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ioerror IO error set by fortran integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in) :: msg Error code readable version used for setting integer(kind=int32), intent(in) :: unit pass unit allowing it to be closed public  subroutine check_okay_dims (dims, expected, ierr) check if array dimensions match the expected dimensions Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: dims (:) array of actual dimensions integer(kind=int32), intent(in) :: expected expected number of dimensions integer(kind=int32), intent(out) :: ierr error code public  subroutine check_okay_ndims (ndims, expected, unit, ierr) Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ndims number of dimensions integer(kind=int32), intent(in) :: expected expected number of dimensions integer(kind=int32), intent(in) :: unit unit representation integer(kind=int32), intent(out) :: ierr error code public  subroutine write_file_header (filename, unit, type_code, ndim, dims, ierr, clen) Opens unit and writes fileheader with all metadata to the given filename Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename filename to write to integer(kind=int32), intent(out) :: unit Fortran unit number for the file integer(kind=int32), intent(in) :: type_code type code of the array (1=int, 2=real, 3=char) integer(kind=int32), intent(in) :: ndim number of dimensions integer(kind=int32), intent(in) :: dims (ndim) dimensions of the array integer(kind=int32), intent(inout) :: ierr error code integer(kind=int32), intent(in), optional :: clen character length (only for character arrays) public  subroutine read_file_header (filename, unit, type_code, ndims, dims, clen, ierr) Opens unit and reads file header with all metadata from given file Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename filename to read from integer(kind=int32), intent(out) :: unit Fortran unit number for the file integer(kind=int32), intent(out) :: type_code type code of the array (1=int, 2=real, 3=char) integer(kind=int32), intent(out) :: ndims number of dimensions integer(kind=int32), allocatable :: dims (:) dimensions of the array integer(kind=int32), intent(out) :: clen character length (only for character arrays) integer(kind=int32), intent(out) :: ierr error code public  subroutine get_array_metadata (filename, dims_out, dims_out_capacity, ndims, ierr, clen) Get the metadata of an array file Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: dims_out (dims_out_capacity) Array to store output dimensions integer(kind=int32), intent(in) :: dims_out_capacity Capacity of the dims_out array integer(kind=int32), intent(out) :: ndims number of dimensions integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(out), optional :: clen length of each string (needed for char arrays) public  subroutine ascii_to_string (ascii_array, clen, str) subroutine to convert an ASCII array to a string Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: ascii_array (clen) Array of ASCII characters integer(kind=int32), intent(in) :: clen Length of the ASCII array character(len=:), intent(out), allocatable :: str Output string public  subroutine string_to_ascii_arr (flat, array_size, ascii_arr, clen) converts a string array to an ascii array Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: flat (array_size) input array with characters integer(kind=int32), intent(in) :: array_size size of the input array integer(kind=int32), intent(out) :: ascii_arr (array_size*clen) ascii output array integer(kind=int32), intent(in) :: clen length of the longest string","tags":"","url":"module/array_utils.html"},{"title":"tox_data_read_write – TensorOmics","text":"Wrappers for serialization/deserialization of arrays Uses iso_fortran_env serialize_char char_deserialize_mod safeguard serialize_int int_deserialize_mod real_deserialize_mod tox_errors serialize_real Subroutines public  subroutine save_gene_ids (gene_ids, filename, ierr) Wrapper for serialize_char_1D function Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: gene_ids (:) Gene IDs to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine save_expression_vectors (expression_vectors, filename, ierr) Wrapper for serialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: expression_vectors (:,:) Expression vectors to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine save_gene_to_family (gene_to_fam, filename, ierr) Wrapper for serialize_int_1D function Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_to_fam (:) Gene to family mapping to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr public  subroutine save_family_ids (family_ids, filename, ierr) Wrapper for serialize_char_1D function Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: family_ids (:) Family IDs to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine save_family_centroids (family_centroids, filename, ierr) Wrapper for serialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: family_centroids (:,:) Family centroids to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine save_shift_vectors (shift_vectors, filename, ierr) Wrapper for serialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: shift_vectors (:,:) Shift vectors to write character(len=*), intent(in) :: filename Filename to write to integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine load_gene_ids (gene_ids, filename, ierr) Wrapper for deserialize_char_1D function Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: gene_ids (:) Gene IDs to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine load_expression_vectors (expression_vectors, filename, ierr) Wrapper for deserialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: expression_vectors (:,:) Expression vectors to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine load_gene_to_family (gene_to_fam, filename, ierr) Wrapper for deserialize_int_1D function Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out) :: gene_to_fam (:) Gene to family mapping to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine load_family_ids (family_ids, filename, ierr) Wrapper for deserialize_char_1D function Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: family_ids (:) Family IDs to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code (0 if successful) public  subroutine load_family_centroids (family_centroids, filename, ierr) Wrapper for deserialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: family_centroids (:,:) Family centroids to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code public  subroutine load_shift_vectors (shift_vectors, filename, ierr) Wrapper for deserialize_real_2D function Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: shift_vectors (:,:) Shift vectors to read character(len=*), intent(in) :: filename Filename to read from integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/tox_data_read_write.html"},{"title":"real_deserialize_mod – TensorOmics","text":"Module for deserializing real (double precision) arrays from binary files Uses iso_c_binding iso_fortran_env safeguard array_utils tox_errors Subroutines public  subroutine deserialize_real_1d (arr, filename, ierr) Directly deserialize a 1D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_real_2d (arr, filename, ierr) Directly deserialize a 2D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_real_3d (arr, filename, ierr) Directly deserialize a 3D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_real_4d (arr, filename, ierr) Directly deserialize a 4D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_real_5d (arr, filename, ierr) Directly deserialize a 5D real array from a file (array already allocated) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out) :: arr (:,:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/real_deserialize_mod.html"},{"title":"tox_clustering – TensorOmics","text":"Uses iso_fortran_env ieee_arithmetic safeguard tox_errors Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: METHOD_AVERAGE = 0 integer(kind=int32), public, parameter :: METHOD_WEIGHTED = 1 integer(kind=int32), public, parameter :: METHOD_WARD = 2 Subroutines public pure subroutine cluster_factor_trajectories_k_means (n_clusters, trajectories, n_factors, n_samples, n_timepoints, centroids, labels, label_counts, ierr, max_iterations) Performs k-means clustering on factor trajectories, so factor evolution over time Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_clusters number ( k ) of clusters real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories matrix with data points to cluster integer(kind=int32), intent(in) :: n_factors number of factors integer(kind=int32), intent(in) :: n_samples number of samples integer(kind=int32), intent(in) :: n_timepoints number of timepoints real(kind=real64), intent(inout), dimension(n_factors, n_clusters) :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. Read more… integer(kind=int32), intent(out), dimension(n_samples * n_timepoints) :: labels array of labels, each index corresponds to the respective point's index, so first label is first point's label. Read more… integer(kind=int32), intent(out), dimension(n_clusters) :: label_counts holds the number of points having the respective label assigned integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in) :: max_iterations number of maximum iterations of the clustering public pure subroutine k_means_clustering (n_clusters, data_points, n_points, n_dims, centroids, labels, label_counts, ierr, max_iterations) k-means clustering algorithm: Read more… Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_clusters number ( k ) of clusters real(kind=real64), intent(in), dimension(n_dims, n_points) :: data_points matrix with data points to cluster integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: n_dims number of elements a point has real(kind=real64), intent(inout), dimension(n_dims, n_clusters) :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. Read more… integer(kind=int32), intent(out), dimension(n_points) :: labels array of labels, each index corresponds to the respective point's index, so first label is first point's label. Read more… integer(kind=int32), intent(out), dimension(n_clusters) :: label_counts holds the number of points having the respective label assigned integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in), optional :: max_iterations number of maximum iterations of the clustering, default 300 public pure subroutine k_means_recompute_cluster_centroids_helper (data_points, n_points, n_dims, centroids, n_clusters, labels, label_counts) Helper to recompute the centroids in k-means by taking the mean of assigned points Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims, n_points) :: data_points matrix with data points to cluster integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: n_dims number of elements a point has real(kind=real64), intent(inout), dimension(n_dims, n_clusters) :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. Read more… integer(kind=int32), intent(in) :: n_clusters number ( k ) of clusters integer(kind=int32), intent(in), dimension(n_points) :: labels array of labels, each index corresponds to the respective point's index, so first label is first point's label. Read more… integer(kind=int32), intent(in), dimension(n_clusters) :: label_counts holds the number of points having the respective label assigned public pure subroutine k_means_assign_cluster_helper (i_point, n_clusters, data_points, n_points, n_dims, centroids, label) Helper routine to assign a cluster's label to a point in k-means Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: i_point index of the point that should be assigned a cluster integer(kind=int32), intent(in) :: n_clusters number ( k ) of clusters real(kind=real64), intent(in), dimension(n_dims, n_points) :: data_points matrix with data points to cluster integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: n_dims number of elements a point has real(kind=real64), intent(in), dimension(n_dims, n_clusters) :: centroids matrix with initial centroids of the clusters, could be random data or actual points or unassigned garbage.\nThe centroids should be unique. This is not checked in this routine. Read more… integer(kind=int32), intent(out) :: label assigned label public pure subroutine linkage_clustering (distances, n_points, merge_i, merge_j, heights, cluster_sizes, method, ierr) Perform linkage clustering on a distance matrix. Read more… Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances symmetric distance matrix, holding the positive distances between points. Distance of X->X is always zero. Read more… integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(out), dimension(n_points - 1) :: merge_i holds cluster labels of the merged node pair at iteration k -> positives relate to leafs/data point indices, negatives to inner nodes integer(kind=int32), intent(out), dimension(n_points - 1) :: merge_j holds cluster labels of the merged node pair at iteration k -> positives relate to leafs/data point indices, negatives to inner nodes real(kind=real64), intent(out), dimension(n_points - 1) :: heights height of the shorter branch of the merge, e.g. if (A,B)+(C) merges to ((A,B),C), the branch to (A,B) is shorter integer(kind=int32), intent(out), dimension(n_points - 1) :: cluster_sizes size of cluster at iteration k integer(kind=int32), intent(in) :: method used algorithm Read more… integer(kind=int32), intent(out) :: ierr Error code public pure subroutine recover_distance_matrix_helper (distances, n_points) Helper to recover a distance matrix from its top triangle. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances top triangle holds distances, bottom triangle will be recovered integer(kind=int32), intent(in) :: n_points number of points to cluster public pure subroutine get_cluster_data_linkage_helper (distances, n_points, cluster_sizes, idx, weight, cluster_label) Helper for linkage clustering to get the size/weight and label of a cluster\nby using the self-distance as indicator in which iteration the cluster was merged Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_points, n_points) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in), dimension(n_points - 1) :: cluster_sizes size of cluster at iteration k integer(kind=int32), intent(in) :: idx index of cluster in distances integer(kind=int32), intent(out) :: weight number of leafs of cluster integer(kind=int32), intent(out) :: cluster_label index/label of cluster public pure subroutine merge_distances_xPGMA_linkage_helper (distances, n_points, idx_A, idx_B, size_A, size_B, iteration_k) Helper for *PGMA algorithms for updating the distance matrix on merge of two clusters Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: idx_A row index of min distance in distances integer(kind=int32), intent(in) :: idx_B column index of min distance in distances integer(kind=int32), intent(in) :: size_A cluster size of cluster at idx_A integer(kind=int32), intent(in) :: size_B cluster size of cluster at idx_B integer(kind=int32), intent(in) :: iteration_k iteration of current merge public pure subroutine merge_distances_ward_linkage_helper (distances, n_points, idx_A, idx_B, size_A, size_B, iteration_k, cluster_sizes, dist_AB) Helper for ward algorithm for updating the distance matrix on merge of two clusters Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: idx_A row index of min distance in distances integer(kind=int32), intent(in) :: idx_B column index of min distance in distances integer(kind=int32), intent(in) :: size_A cluster size of cluster at idx_A integer(kind=int32), intent(in) :: size_B cluster size of cluster at idx_B integer(kind=int32), intent(in) :: iteration_k iteration of current merge integer(kind=int32), intent(in), dimension(n_points - 1) :: cluster_sizes size of cluster at iteration k, needed for ward algorithm real(kind=real64), intent(in) :: dist_AB distance between cluster A and B public pure subroutine post_merge_distances_helper (distances, n_points, idx_A, idx_B, iteration_k) Helper for doing last updates after merge: disable merged cluster, update self-distance to current iteration Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_points, n_points) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n_points number of points to cluster integer(kind=int32), intent(in) :: idx_A row index of min distance in distances integer(kind=int32), intent(in) :: idx_B column index of min distance in distances integer(kind=int32), intent(in) :: iteration_k iteration of current merge public pure subroutine get_min_distance_indices_helper (distances, n, row_idx, col_idx, min_dist) Helper routine to find the indices of the minimum value a distance matrix. Read more… Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n, n) :: distances distance matrix, holding the distances between points integer(kind=int32), intent(in) :: n number of rows and columns of square matrix distances integer(kind=int32), intent(out) :: row_idx row index of min distance in distances integer(kind=int32), intent(out) :: col_idx column index of min distance in distances real(kind=real64), intent(out) :: min_dist min distance","tags":"","url":"module/tox_clustering.html"},{"title":"tox_trajectory_contribution_analysis – TensorOmics","text":"Uses iso_fortran_env f42_utils safeguard ieee_arithmetic tox_errors Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: MODE_NORMAL = 1 integer(kind=int32), public, parameter :: MODE_RAP = 2 Subroutines public pure subroutine trajectory_contribution (factor, dependent, n_timepoints, mode, contribution, ierr) Calculates trajectory contribution using cosine similarity There are two modes: Read more… Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_timepoints) :: factor Vector of independent variable that contributes to dependent real(kind=real64), intent(in), dimension(n_timepoints) :: dependent Vector of dependent variable integer(kind=int32), intent(in) :: n_timepoints Number of timepoints included in factor and dependent integer(kind=int32), intent(in) :: mode Read more… real(kind=real64), intent(out) :: contribution Contribution value integer(kind=int32), intent(out) :: ierr Error code public pure subroutine spike_contribution (factor, dependent, n_timepoints, mode, contribution, ierr) Calculates spike contributions using cosine similarity for specific indices There are two modes: Read more… Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_timepoints) :: factor Vector of independent variable that contributes to dependent real(kind=real64), intent(in), dimension(n_timepoints) :: dependent Vector of independent variable that contributes dependent integer(kind=int32), intent(in) :: n_timepoints Number of timepoints included in factor and dependent integer(kind=int32), intent(in) :: mode Read more… real(kind=real64), intent(out), dimension(n_timepoints) :: contribution Contribution value integer(kind=int32), intent(out) :: ierr Error code public pure subroutine calc_contributions (trajectories, n_factors, n_samples, n_timepoints, i_factor, dependent_idx, mode, spike_contribs, integrated_contribs, temp_factor_vector, temp_dependent_vector, ierr) Calculates both spike and integrated contributions for a given factor against a dependent variable Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories of expression data integer(kind=int32), intent(in) :: n_factors Number of factors in trajectories integer(kind=int32), intent(in) :: n_samples Number of samples in trajectories integer(kind=int32), intent(in) :: n_timepoints Number of timepoints in trajectories integer(kind=int32), intent(in) :: i_factor Factor (independent variable) index the contributions should be calculated for integer(kind=int32), intent(in) :: dependent_idx Index of the dependent variable the contributions should be calculated for integer(kind=int32), intent(in) :: mode Read more… real(kind=real64), intent(out), dimension(n_timepoints, n_samples) :: spike_contribs Output array to hold the timpoint-wise contributions per sample real(kind=real64), intent(out), dimension(n_samples) :: integrated_contribs Output array to hold the contribution per sample real(kind=real64), intent(out), dimension(n_timepoints) :: temp_factor_vector Work array to hold the vector of i_factor per sample real(kind=real64), intent(out), dimension(n_timepoints) :: temp_dependent_vector Work array to hold the vector of dependent_idx per sample integer(kind=int32), intent(out) :: ierr Error code public pure subroutine calc_contributions_alloc (trajectories, n_factors, n_samples, n_timepoints, i_factor, dependent_idx, mode, spike_contribs, integrated_contribs, ierr) Calculates both spike and integrated contributions for a given factor against a dependent variable Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories of expression data integer(kind=int32), intent(in) :: n_factors Number of factors in trajectories integer(kind=int32), intent(in) :: n_samples Number of samples in trajectories integer(kind=int32), intent(in) :: n_timepoints Number of timepoints in trajectories integer(kind=int32), intent(in) :: i_factor Factor (independent variable) index the contributions should be calculated for integer(kind=int32), intent(in) :: dependent_idx Index of the dependent variable the contributions should be calculated for integer(kind=int32), intent(in) :: mode Read more… real(kind=real64), intent(out), dimension(n_timepoints, n_samples) :: spike_contribs Output array to hold the timpoint-wise contributions per sample real(kind=real64), intent(out), dimension(n_samples) :: integrated_contribs Output array to hold the contribution per sample integer(kind=int32), intent(out) :: ierr Error code public pure subroutine get_vec_across_samples (trajectories, n_factors, n_samples, n_timepoints, i_factor, i_timepoint, result_vector, ierr) Accessor routine to extract sample data for a specific factor and timepoint Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories of expression data integer(kind=int32), intent(in) :: n_factors Number of factors in trajectories integer(kind=int32), intent(in) :: n_samples Number of samples in trajectories integer(kind=int32), intent(in) :: n_timepoints Number of timepoints in trajectories integer(kind=int32), intent(in) :: i_factor Factor index the retrieved samples should be related to integer(kind=int32), intent(in) :: i_timepoint Timepoint index the retrieved samples should be related to real(kind=real64), intent(out), dimension(n_samples) :: result_vector Result vector, equivalent to trajectories(i_factor, :, i_timepoint) integer(kind=int32), intent(out) :: ierr Error code public pure subroutine get_vec_across_timepoints (trajectories, n_factors, n_samples, n_timepoints, i_factor, i_sample, result_vector, ierr) Accessor routine to extract timepoint data for a specific factor and sample Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories of expression data integer(kind=int32), intent(in) :: n_factors Number of factors in trajectories integer(kind=int32), intent(in) :: n_samples Number of samples in trajectories integer(kind=int32), intent(in) :: n_timepoints Number of timepoints in trajectories integer(kind=int32), intent(in) :: i_factor Factor index the retrieved timepoints should be related to integer(kind=int32), intent(in) :: i_sample Timepoint index the retrieved timepoints should be related to real(kind=real64), intent(out), dimension(n_timepoints) :: result_vector Result vector, equivalent to trajectories(i_factor, i_sample, :) integer(kind=int32), intent(out) :: ierr Error code public  subroutine process_trajectories_alloc (trajectories, n_factors, n_samples, n_timepoints, factor_mask, factor_mask_count, dependent_idx, mode, percentile, integrated_contribs, spike_contribs, thresholds_integrated_contrib, outliers_integrated_contrib, thresholds_spike_contrib, outliers_spike_contrib, ierr) Process trajectories with one percentile per timepoint for spike contributions.\nThis subroutine uses multiple allocations. If you want to avoid this, you need to do the full pipeline manually step-by-step. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories array integer(kind=int32), intent(in) :: n_factors Number of factors integer(kind=int32), intent(in) :: n_samples Number of samples integer(kind=int32), intent(in) :: n_timepoints Number of timepoints logical, intent(in), dimension(n_factors) :: factor_mask Mask for what factors should be included integer(kind=int32), intent(in) :: factor_mask_count Number of true values in the factor mask integer(kind=int32), intent(in) :: dependent_idx Index of the dependend factor integer(kind=int32), intent(in) :: mode Mode for contribution calculation real(kind=real64), intent(in) :: percentile Percentile (0-100) real(kind=real64), intent(out), dimension(n_samples, factor_mask_count) :: integrated_contribs Integrated contributions real(kind=real64), intent(out), dimension(n_timepoints, n_samples, factor_mask_count) :: spike_contribs Spike contributions real(kind=real64), intent(out), dimension(factor_mask_count) :: thresholds_integrated_contrib Thresholds of integrated contributions based on the provided percentile logical, intent(out), dimension(n_samples, factor_mask_count) :: outliers_integrated_contrib Detected outliers of the integrated contributions real(kind=real64), intent(out), dimension(n_timepoints, factor_mask_count) :: thresholds_spike_contrib Thresholds of spike contributions based on the provided percentile logical, intent(out), dimension(n_timepoints, n_samples, factor_mask_count) :: outliers_spike_contrib Detected outliers of the spike contributions integer(kind=int32), intent(out) :: ierr public  subroutine process_trajectories_flat_alloc (trajectories, n_factors, n_samples, n_timepoints, factor_mask, factor_mask_count, dependent_idx, mode, percentile, integrated_contribs, spike_contribs, thresholds_integrated_contrib, outliers_integrated_contrib, thresholds_spike_contrib, outliers_spike_contrib, ierr) Process trajectories with global percentile for spike contributions (flattened)\nThis subroutine uses multiple allocations. If you want to avoid this, you need to do the full pipeline manually step-by-step. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories Trajectories array integer(kind=int32), intent(in) :: n_factors Number of factors integer(kind=int32), intent(in) :: n_samples Number of samples integer(kind=int32), intent(in) :: n_timepoints Number of timepoints logical, intent(in), dimension(n_factors) :: factor_mask Logical mask for factors integer(kind=int32), intent(in) :: factor_mask_count Number of true values in the factor mask integer(kind=int32), intent(in) :: dependent_idx Index of the dependent factor integer(kind=int32), intent(in) :: mode Mode to use for contribution calculation real(kind=real64), intent(in) :: percentile Percentile value (0.0 - 100.0) real(kind=real64), intent(out), dimension(n_samples, factor_mask_count) :: integrated_contribs Integrated contributions real(kind=real64), intent(out), dimension(n_timepoints, n_samples, factor_mask_count) :: spike_contribs Spike contributions real(kind=real64), intent(out), dimension(factor_mask_count) :: thresholds_integrated_contrib Thresholds of integrated contributions based on provided percentile logical, intent(out), dimension(n_samples, factor_mask_count) :: outliers_integrated_contrib Outliers of integrated contributions based on provided percentile real(kind=real64), intent(out), dimension(factor_mask_count) :: thresholds_spike_contrib Thresholds of spike contributions based on provided percentile logical, intent(out), dimension(n_timepoints, n_samples, factor_mask_count) :: outliers_spike_contrib Outliers of spike contributions based on provided percentile integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/tox_trajectory_contribution_analysis.html"},{"title":"tox_get_outliers – TensorOmics","text":"Module to identify gene outliers based on their distances to family centroids. Uses iso_fortran_env f42_utils safeguard ieee_arithmetic tox_errors Subroutines public pure subroutine compute_family_scaling (n_genes, n_families, distances, gene_to_fam, dscale, loess_x, loess_y, indices_used, perm_tmp, stack_left_tmp, stack_right_tmp, family_distances, ierr) Compute family scaling factors (dscale) to normalize distances.\nUses LOESS on the median/stddev of intra-family distances for scaling, regardless of orthologs. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of gene families real(kind=real64), intent(in) :: distances (n_genes) Array of Euclidean distances for each gene integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Mapping of each gene to its family (1-based) real(kind=real64), intent(out) :: dscale (n_families) Output: array of scaling factors per family real(kind=real64), intent(inout) :: loess_x (n_families) Reference x-coordinates. real(kind=real64), intent(inout) :: loess_y (n_families) Reference y-coordinates (length n_total). integer(kind=int32), intent(inout) :: indices_used (n_families) Indices of reference points used for smoothing. integer(kind=int32), intent(inout) :: perm_tmp (n_genes) Permutation array for sorting gene distances integer(kind=int32), intent(inout) :: stack_left_tmp (n_genes) Stack array for left indices during sorting integer(kind=int32), intent(inout) :: stack_right_tmp (n_genes) Stack array for right indices during sorting real(kind=real64), intent(out) :: family_distances (n_genes) Pre-allocated work array for family distances (dimension n_genes) integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid family indices public pure subroutine compute_family_scaling_alloc (n_genes, n_families, distances, gene_to_fam, dscale, loess_x, loess_y, indices_used, ierr) Helper routine that allocates internal arrays and calls compute_family_scaling.\nThis makes usage easier since users don't need to care about internal array requirements. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of gene families real(kind=real64), intent(in) :: distances (n_genes) Array of Euclidean distances for each gene integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Mapping of each gene to its family (1-based) real(kind=real64), intent(out) :: dscale (n_families) Output: array of scaling factors per family real(kind=real64), intent(inout) :: loess_x (n_families) Reference x-coordinates. real(kind=real64), intent(inout) :: loess_y (n_families) Reference y-coordinates (length n_total). integer(kind=int32), intent(inout) :: indices_used (n_families) Indices of reference points used for smoothing. integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid family indices public pure subroutine compute_rdi (n_genes, distances, gene_to_fam, dscale, rdi, sorted_rdi, perm, stack_left, stack_right) Compute the hybrid RDI for each gene.\nRDI = Euclidean distance / family scaling factor Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes real(kind=real64), intent(in) :: distances (n_genes) Array of Euclidean distances for each gene to its centroid integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Gene-to-family mapping (1-based indexing) real(kind=real64), intent(in) :: dscale (:) Array of scaling factors for each family real(kind=real64), intent(out) :: rdi (n_genes) Output array of RDI values for each gene real(kind=real64), intent(inout) :: sorted_rdi (n_genes) Work array for sorting (dimension n_genes) integer(kind=int32), intent(inout) :: perm (n_genes) Permutation array for sorting (dimension n_genes, should be pre-initialized with 1:n_genes) integer(kind=int32), intent(inout) :: stack_left (n_genes) Stack array for sorting (dimension n_genes) integer(kind=int32), intent(inout) :: stack_right (n_genes) Stack array for sorting (dimension n_genes) public pure subroutine identify_outliers (n_genes, rdi, sorted_rdi, is_outlier, threshold, percentile) Identify gene outliers based on the top percentile of RDI values.\nExpects sorted_rdi to be filtered (no negative values) and sorted in ascending order before calling.\nIf sorted_rdi contains negatives or is not sorted, results may be invalid. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes real(kind=real64), intent(in) :: rdi (n_genes) Array of RDI values for each gene real(kind=real64), intent(in) :: sorted_rdi (n_genes) Sorted RDI array (must be filtered to remove negatives and sorted in ascending order before calling) logical, intent(out) :: is_outlier (n_genes) Output boolean array indicating outliers real(kind=real64), intent(out) :: threshold Output threshold value used for detection real(kind=real64), intent(in), optional :: percentile (optional) Percentile threshold (default: 95 for top 5%) public pure subroutine detect_outliers (n_genes, n_families, distances, gene_to_fam, work_array, perm, stack_left, stack_right, is_outlier, loess_x, loess_y, loess_n, ierr, percentile) Main routine to detect outliers using RDI and LOESS-based scaling. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of gene families real(kind=real64), intent(in) :: distances (n_genes) Array of Euclidean distances for each gene to its centroid integer(kind=int32), intent(in) :: gene_to_fam (n_genes) Gene-to-family mapping (1-based indexing) real(kind=real64), intent(inout) :: work_array (n_genes) Work array for sorting (dimension n_genes) integer(kind=int32), intent(inout) :: perm (n_genes) Permutation array for sorting (dimension n_genes) integer(kind=int32), intent(inout) :: stack_left (n_genes) Stack array for left indices during sorting integer(kind=int32), intent(inout) :: stack_right (n_genes) Stack array for right indices during sorting logical, intent(out) :: is_outlier (n_genes) Output boolean array indicating outliers real(kind=real64), intent(inout) :: loess_x (n_families) Reference x-coordinates. real(kind=real64), intent(inout) :: loess_y (n_families) Reference y-coordinates (length n_total). integer(kind=int32), intent(inout) :: loess_n (n_families) Indices of reference points used for smoothing. integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid family indices real(kind=real64), intent(in), optional :: percentile (optional) Percentile threshold for outlier detection (default: 95)","tags":"","url":"module/tox_get_outliers.html"},{"title":"tox_data_validation – TensorOmics","text":"Uses iso_fortran_env safeguard tox_errors config Subroutines public  subroutine validate_data_structure (n_genes, n_families, n_samples, gene_ids, gene_family_ids, gene_to_fam, expression_vectors, family_centroids, shift_vectors, ierr) Validate full data structure Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Expected number of genes integer(kind=int32), intent(in) :: n_families Expected number of families integer(kind=int32), intent(in) :: n_samples Expected number of samples character(len=*), intent(in) :: gene_ids (:) Gene ids character(len=*), intent(in) :: gene_family_ids (:) Gene family ids integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping real(kind=real64), intent(in) :: expression_vectors (:,:) Expression vectors real(kind=real64), intent(in) :: family_centroids (:,:) Family centroids real(kind=real64), intent(in) :: shift_vectors (:,:) Shift vectors integer(kind=int32), intent(out) :: ierr Error code public  subroutine validate_gene_to_family_mapping (gene_to_fam, n_families, ierr) Validate gene to family mapping Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping integer(kind=int32), intent(in) :: n_families number of families integer(kind=int32), intent(out) :: ierr Error code public  subroutine validate_expression_data (expression_vectors, check_non_negative, ierr) Validate expresssion data Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: expression_vectors (:,:) Expression vectors logical, intent(in) :: check_non_negative Defines if non negative should be checked integer(kind=int32), intent(out) :: ierr Error code public  subroutine validate_family_centroids (family_centroids, ierr) Validate the family centroids Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: family_centroids (:,:) Family centroids array integer(kind=int32), intent(out) :: ierr Error code public  subroutine validate_shift_vectors (shift_vectors, expression_vectors, family_centroids, gene_to_fam, n_samples, ierr) Validates shift vectors Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: shift_vectors (:,:) shift vectors real(kind=real64), intent(in) :: expression_vectors (:,:) expression vectors real(kind=real64), intent(in) :: family_centroids (:,:) family centroids integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping integer(kind=int32), intent(in) :: n_samples Number of samples integer(kind=int32), intent(out) :: ierr Error code public  subroutine check_for_nan_inf (array, ierr) Check if an array of type real contains NaN or Inf values Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:,:) Input array integer(kind=int32), intent(out) :: ierr Error code public  subroutine validate_string_array_uniqueness (str_arr, ierr) Validate that no string appears more than once Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: str_arr (:) string array integer(kind=int32), intent(out) :: ierr Error code public  subroutine validate_empty_strings (string_array, array_name, ierr) Validate that strings in an array are not empty Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: string_array (:) Array of strings character(len=*), intent(in) :: array_name Name of the array integer(kind=int32), intent(out) :: ierr Error code public  subroutine validate_all_data (n_genes, n_families, n_samples, gene_ids, gene_family_ids, gene_to_fam, expression_vectors, family_centroids, shift_vectors, ierr, check_uniqueness, check_shift_consistency) Comprehensive validation routine, combining all checks Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes Number of genes integer(kind=int32), intent(in) :: n_families Number of families integer(kind=int32), intent(in) :: n_samples Number of samples character(len=*), intent(in) :: gene_ids (:) Gene ids array character(len=*), intent(in) :: gene_family_ids (:) gene family ids integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping real(kind=real64), intent(in) :: expression_vectors (:,:) Expression vectors real(kind=real64), intent(in) :: family_centroids (:,:) family centroids real(kind=real64), intent(in) :: shift_vectors (:,:) shift vectors integer(kind=int32), intent(out) :: ierr error code logical, intent(in), optional :: check_uniqueness Check ID arrays for uniqueness logical, intent(in), optional :: check_shift_consistency Check consitency of shift array","tags":"","url":"module/tox_data_validation.html"},{"title":"f42_utils – TensorOmics","text":"Utility module for data analysis.\nThis module provides general-purpose utility functions for data analysis, to be used as needed. Uses iso_fortran_env ieee_arithmetic safeguard tox_errors Variables Type Visibility Attributes Name Initial real(kind=real64), public, parameter :: EPS = epsilon(1.0_real64) Interfaces public        interface sort_array public pure subroutine sort_real (array, perm, stack_left, stack_right) Sort a real array indirectly using quicksort.\nCreates a sorted version of the array by reordering the perm vector. The original data in array remains unchanged. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine sort_integer (array, perm, stack_left, stack_right) Sort an integer array indirectly using quicksort.\nSimilar to sort_real , but for integer input. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine sort_character (array, perm, stack_left, stack_right) Sort a character array indirectly using quicksort.\nUses lexicographic ordering and permutation vector sorting. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public        interface sort_array_heapsort public pure subroutine sort_real_heapsort (array, perm) Sort a real array indirectly using heapsort.\nCreates a sorted version of the array by reordering the perm vector. The original data in array remains unchanged. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine sort_integer_heapsort (array, perm) Sort an integer array indirectly using heapsort.\nSimilar to sort_real_heapsort , but for integer input. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine sort_character_heapsort (array, perm) Sort a character array indirectly using heapsort.\nUses lexicographic ordering and permutation vector sorting. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted Functions public pure function is_close (a, b) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: a First variable of comparison a==b real(kind=real64), intent(in) :: b Second variable of comparison a==b Return Value logical public  function next_power_of_two (n) result(power) Find the next power of two greater than or equal to n Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n input value Return Value integer(kind=int32) next greater value that is a power of two public pure function real_less (a, b) NaN-aware less-than comparison for real(real64).\nFinite values are always considered smaller than NaN.\nTwo NaNs are treated as equal (neither less nor greater). Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: a real(kind=real64), intent(in) :: b Return Value logical public pure function real_greater (a, b) NaN-aware greater-than comparison for real(real64).\nNaN is treated as greater than any finite number.\nTwo NaNs are treated as equal. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: a real(kind=real64), intent(in) :: b Return Value logical Subroutines public pure subroutine sort_real (array, perm, stack_left, stack_right) Sort a real array indirectly using quicksort.\nCreates a sorted version of the array by reordering the perm vector. The original data in array remains unchanged. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine sort_integer (array, perm, stack_left, stack_right) Sort an integer array indirectly using quicksort.\nSimilar to sort_real , but for integer input. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine sort_character (array, perm, stack_left, stack_right) Sort a character array indirectly using quicksort.\nUses lexicographic ordering and permutation vector sorting. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine sort_real_heapsort (array, perm) Sort a real array indirectly using heapsort.\nCreates a sorted version of the array by reordering the perm vector. The original data in array remains unchanged. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine sort_integer_heapsort (array, perm) Sort an integer array indirectly using heapsort.\nSimilar to sort_real_heapsort , but for integer input. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine sort_character_heapsort (array, perm) Sort a character array indirectly using heapsort.\nUses lexicographic ordering and permutation vector sorting. Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine quicksort_real (array, perm, n, stack_left, stack_right) Internal quicksort implementation for real arrays.\nSorts indirectly using the permutation vector perm . Manual stack replaces recursion. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(in) :: n Size of the array integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine quicksort_int (array, perm, n, stack_left, stack_right) Internal quicksort implementation for integer arrays.\nIndirectly sorts array using perm , same algorithm as quicksort_real . Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(in) :: n Size of the array integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine quicksort_char (array, perm, n, stack_left, stack_right) Internal quicksort implementation for character arrays.\nLexicographic quicksort using string comparison, indirect via perm . Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted integer(kind=int32), intent(in) :: n Size of the array integer(kind=int32), intent(inout) :: stack_left (:) Manual stack of left indices for quicksort recursion integer(kind=int32), intent(inout) :: stack_right (:) Manual stack of right indices for quicksort recursion public pure subroutine heapsort_real (array, perm) Sorts indirectly using the permutation vector perm . Uses heapify_real to maintain heap property. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Real input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine heapsort_integer (array, perm) Internal heapsort implementation for integer arrays.\nIndirectly sorts array using perm , same algorithm as heapsort_real . Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: array (:) Integer input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine heapsort_character (array, perm) Internal heapsort implementation for character arrays.\nLexicographic heapsort using string comparison, indirect via perm . Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: array (:) Character input array to sort integer(kind=int32), intent(inout) :: perm (:) Permutation vector that will be sorted public pure subroutine swap_int (a, b) Swap two integer values in-place. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(inout) :: a First integer to swap integer(kind=int32), intent(inout) :: b Second integer to swap public pure subroutine which (mask, n, idx_out, m_max, m_out, ierr) Finds the indices of the true values in a logical mask. Arguments Type Intent Optional Attributes Name logical, intent(in) :: mask (:) Logical array of size n. integer(kind=int32), intent(in) :: n Size of the mask. integer(kind=int32), intent(out) :: idx_out (:) Integer array to store the indices of true values. integer(kind=int32), intent(in) :: m_max Maximum size of idx_out. integer(kind=int32), intent(out) :: m_out Actual size of idx_out (number of true values found). integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid input, 202=empty input public pure subroutine loess_smooth_2d (n_total, n_target, x_ref, y_ref, indices_used, n_used, x_query, kernel_sigma, kernel_cutoff, y_out, ierr) Performs LOESS smoothing on a set of data points.\nSmooths y_ref at x_query using reference points x_ref, y_ref, and kernel parameters.\nThe user must pre-filter data and provide only valid indices in indices_used. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_total Total number of reference points. integer(kind=int32), intent(in) :: n_target Number of target points to smooth. real(kind=real64), intent(in) :: x_ref (n_total) Reference x-coordinates. real(kind=real64), intent(in) :: y_ref (n_total) Reference y-coordinates (length n_total). integer(kind=int32), intent(in) :: indices_used (n_used) Indices of reference points used for smoothing (only valid indices). integer(kind=int32), intent(in) :: n_used Number of indices actually used for smoothing. real(kind=real64), intent(in) :: x_query (n_target) Target x-coordinates to smooth. real(kind=real64), intent(in) :: kernel_sigma Bandwidth parameter for the kernel. real(kind=real64), intent(in) :: kernel_cutoff Cutoff for the kernel. real(kind=real64), intent(out) :: y_out (n_target) Output smoothed values (length n_target). integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid input, 202=empty input public  subroutine compute_edf (values, n_values, perm, unique_values, cdf_values, n_unique, ierr) Compute the Empirical Distribution Function (EDF) from pre-sorted permutation.\nReturns the sorted unique values and their cumulative frequencies in [0,1].\nAssumes perm is already sorted by values[perm]. Caller controls sorting algorithm.\nThe number of unique values can be determined by finding the last non-zero cdf_value. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (n_values) Array of observed data values (e.g., contributions or spikes). integer(kind=int32), intent(in) :: n_values Number of values in the input array. integer(kind=int32), intent(in) :: perm (n_values) Pre-sorted permutation indices (must be sorted by values[perm]). real(kind=real64), intent(out) :: unique_values (n_values) Sorted unique data values. real(kind=real64), intent(out) :: cdf_values (n_values) Corresponding cumulative frequencies between 0 and 1. integer(kind=int32), intent(out) :: n_unique Number of unique values found (actual size of output arrays) integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid input, 202=empty input public  subroutine compute_edf_alloc (values, n_values, unique_values, cdf_values, n_unique, ierr) Helper routine that sorts and calls compute_edf.\nAllocates workspace internally and performs sorting before computing EDF.\nUse this for convenience; use compute_edf directly for custom sorting. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (n_values) Array of observed data values (e.g., contributions or spikes). integer(kind=int32), intent(in) :: n_values Number of values in the input array. real(kind=real64), intent(out) :: unique_values (n_values) Sorted unique data values. real(kind=real64), intent(out) :: cdf_values (n_values) Corresponding cumulative frequencies between 0 and 1. integer(kind=int32), intent(out) :: n_unique Number of unique values found (actual size of output arrays) integer(kind=int32), intent(out) :: ierr Error code: 0=ok, 201=invalid input, 202=empty input public pure subroutine calc_percentile (array, permutation, percentile, value, ierr) Calculate the percentile of an array given a sorted permutation.\nUses linear interpolation between adjacent values. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) input array integer(kind=int32), intent(in) :: permutation (:) permutation vector representing sorted order real(kind=real64), intent(in) :: percentile desired percentile (0-100) real(kind=real64), intent(out) :: value output percentile value integer(kind=int32), intent(out) :: ierr Error code public  subroutine calc_percentile_alloc (array, percentile, value, ierr) Calculate the percentile of an array, allocating necessary arrays when no sorting permutation is given Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: array (:) Input array real(kind=real64), intent(in) :: percentile Desired percentile (0-100) real(kind=real64), intent(out) :: value Output percentile value integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/f42_utils.html"},{"title":"char_deserialize_mod – TensorOmics","text":"Module for deserializing character arrays from files Uses iso_fortran_env array_utils safeguard tox_errors Subroutines public  subroutine deserialize_char_flat (flat, dims, clen, filename, ierr) Subroutine to deserialize a flat character array from a file Arguments Type Intent Optional Attributes Name character(len=:), intent(out), pointer :: flat (:) Output flat character array integer(kind=int32), intent(out), allocatable :: dims (:) Output dimensions of the array integer(kind=int32), intent(out) :: clen Maximum length of character string character(len=*), intent(in) :: filename Name of the file to read integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_char_1d (arr, filename, ierr) Directly deserialize a 1D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out), contiguous :: arr (:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file to read from integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_char_2d (arr, filename, ierr) Directly deserialize a 2D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: arr (:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_char_3d (arr, filename, ierr) Directly deserialize a 3D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: arr (:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_char_4d (arr, filename, ierr) Directly deserialize a 4D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: arr (:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code public  subroutine deserialize_char_5d (arr, filename, ierr) Directly deserialize a 5D character array from a file (array already allocated) Arguments Type Intent Optional Attributes Name character(len=*), intent(out) :: arr (:,:,:,:,:) Pre-allocated array to read the data into character(len=*), intent(in) :: filename Name of the file integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/char_deserialize_mod.html"},{"title":"xxh3_hashmap_module – TensorOmics","text":"Uses iso_c_binding f42_utils iso_fortran_env safeguard tox_errors config Derived Types type, public :: hashmap_type Components Type Visibility Attributes Name Initial integer(kind=int32), public :: size = 0 integer(kind=int32), public :: count = 0 type(hashmap_node_type), public, pointer :: buckets (:) => null() type, public :: hashset_type Components Type Visibility Attributes Name Initial integer(kind=int32), public :: size = 0 integer(kind=int32), public :: count = 0 type(hashset_node_type), public, pointer :: buckets (:) => null() Functions public  function is_in_hashset (hashset, key) result(res) Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(in) :: hashset character(len=*), intent(in) :: key Return Value logical public  function hashmap_get (map, key) result(value) Lookup a key Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(in) :: map hashmap character(len=*), intent(in) :: key key to look for Return Value integer(kind=int32) return value Subroutines public  subroutine hashmap_create (map, initial_size) Create the hashmap Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(out) :: map Hashmap object to create integer(kind=int32), intent(in), optional :: initial_size Size of the hashmap public  subroutine hashset_create (map, initial_size) Create the hashmap Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(out) :: map Hashmap object to create integer(kind=int32), intent(in), optional :: initial_size Size of the hashmap public  subroutine hashmap_destroy (map) Destroy the hashmap Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(inout) :: map The hashmap to delete public  subroutine hashset_destroy (set) Destroy the set Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(inout) :: set The set to delete public  subroutine hashmap_put (map, key, value) Insert a key-value pair Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(inout) :: map hashmap to insert into character(len=*), intent(in) :: key Key to store integer(kind=int32), intent(in) :: value value to store public  subroutine hashset_put (set, key, ierr) Insert a key-value pair Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(inout) :: set hashmap to insert into character(len=*), intent(in) :: key Key to store integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/xxh3_hashmap_module.html"},{"title":"tox_data_accessors – TensorOmics","text":"Uses iso_fortran_env safeguard tox_errors Functions public  function get_gene_index (gene_ids, gene) result(idx) Helper function to find gene index Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: gene_ids (:) gene ids array character(len=*), intent(in) :: gene gene to look for Return Value integer(kind=int32) public  function get_family_index (family_ids, family) result(idx) Helper function to find family index Arguments Type Intent Optional Attributes Name character(len=*), intent(in) :: family_ids (:) family ids array character(len=*), intent(in) :: family family to look for Return Value integer(kind=int32) Subroutines public  subroutine get_family_for_gene_index (gene_idx, gene_to_fam, out_family_idx, ierr) returns family index for gene index Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_idx gene index integer(kind=int32), intent(in) :: gene_to_fam (:) gene to family mapping integer(kind=int32), intent(out) :: out_family_idx family index integer(kind=int32), intent(out) :: ierr error code public  subroutine get_expression_vector (gene_idx, expression_vectors, out_vector, ierr) get expression vector for a specific gene id Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_idx target gene index real(kind=real64), intent(in) :: expression_vectors (:,:) expression vectors real(kind=real64), intent(out) :: out_vector (:) output vector integer(kind=int32), intent(out) :: ierr error code public  subroutine get_family_centroid (family_idx, family_centroids, out_centroid, ierr) get family centroid for a specific family index Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: family_idx Target index real(kind=real64), intent(in) :: family_centroids (:,:) centroid array real(kind=real64), intent(out) :: out_centroid (:) Output centroid integer(kind=int32), intent(out) :: ierr Error code public  subroutine get_shift_components (gene_idx, shift_vectors, d, out_start, out_shift, ierr) returns the centroid and the shift of a gene Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: gene_idx gene index to look for real(kind=real64), intent(in) :: shift_vectors (:,:) shift vectors integer(kind=int32), intent(in) :: d number of tissues real(kind=real64), intent(out) :: out_start (:) centroid of the genes family real(kind=real64), intent(out) :: out_shift (:) shift vector of the gene integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/tox_data_accessors.html"},{"title":"tox_trajectory_contribution_analysis_outlier_detection – TensorOmics","text":"Module for trajectory explanatory contribution analysis (TCA)\nProvides functionality for detecting outliers in trajectory and spike contributions Uses iso_fortran_env f42_utils safeguard tox_errors Subroutines public pure subroutine calc_spike_thresholds (spike_contribs, n_timepoints, n_samples, percentile_val, thresholds, permutation, ierr) Calculate empirical thresholds for spike contributions (using pre-sorted permutations) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: spike_contribs (n_timepoints,n_samples) 2D array of spike contributions integer(kind=int32), intent(in) :: n_timepoints Number of timepoints integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=real64), intent(out) :: thresholds (n_timepoints) 1D array of thresholds for each timepoint integer(kind=int32), intent(in) :: permutation (n_samples,n_timepoints) Pre-computed permutation indices integer(kind=int32), intent(out) :: ierr Error code public  subroutine calc_spike_thresholds_alloc (spike_contribs, n_timepoints, n_samples, percentile_val, thresholds, ierr) Calculate empirical thresholds for spike contributions (with internal allocations and sorting) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: spike_contribs (n_timepoints,n_samples) 2D array of spike contributions integer(kind=int32), intent(in) :: n_timepoints Number of timepoints integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=real64), intent(out) :: thresholds (n_timepoints) 1D array of thresholds integer(kind=int32), intent(out) :: ierr Error code public pure subroutine calc_integrated_threshold (contributions, n_samples, percentile_val, threshold, permutation, ierr) Calculate empirical threshold for integrated (trajectory-level) contributions Read more… Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: contributions (n_samples) 1D array of integrated contributions integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=real64), intent(out) :: threshold Scalar threshold value integer(kind=int32), intent(in) :: permutation (n_samples) Pre-computed permutation indices for sorted contributions integer(kind=int32), intent(out) :: ierr Error code public  subroutine calc_integrated_threshold_alloc (contributions, n_samples, percentile_val, threshold, ierr) Calculate empirical threshold for integrated contributions (with internal allocation and sorting) Read more… Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: contributions (n_samples) 1D array of integrated contributions integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: percentile_val Percentile value for threshold (0.0-100.0) real(kind=real64), intent(out) :: threshold Scalar threshold value integer(kind=int32), intent(out) :: ierr Error code public pure subroutine detect_outliers_integrated (contributions, n_samples, threshold, outlier_mask, ierr) Detect outliers in integrated (trajectory-level) contributions Read more… Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: contributions (n_samples) Array of integrated contributions integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: threshold Scalar threshold value for outlier detection logical, intent(out) :: outlier_mask (n_samples) 1D logical array indicating outliers integer(kind=int32), intent(out) :: ierr Error code public pure subroutine detect_outliers_spike (spike_contribs, n_timepoints, n_samples, thresholds, outlier_mask, ierr) Detect outliers in spike contributions Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: spike_contribs (n_timepoints,n_samples) 2D array of spike contributions integer(kind=int32), intent(in) :: n_timepoints Number of timepoints integer(kind=int32), intent(in) :: n_samples Number of samples real(kind=real64), intent(in) :: thresholds (n_timepoints) Array of thresholds logical, intent(out) :: outlier_mask (n_timepoints,n_samples) 2D logical array indicating outliers integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/tox_trajectory_contribution_analysis_outlier_detection.html"},{"title":"tox_shift_vectors – TensorOmics","text":"Module for computing the shift vector field for all genes. Uses iso_fortran_env safeguard tox_errors Subroutines public pure subroutine compute_shift_vector_field (d, n_genes, n_families, expression_vectors, family_centroids, gene_to_centroid, shift_vectors, ierr) Compute the shift vector field for all genes.\nComputes the shift vectors by substracting the corresponding family centroid from the expression vector. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: d Expression vector dimension integer(kind=int32), intent(in) :: n_genes Total number of genes integer(kind=int32), intent(in) :: n_families Total number of families real(kind=real64), intent(in) :: expression_vectors (d,n_genes) Gene expression matrix (d × n_genes) real(kind=real64), intent(in) :: family_centroids (d,n_families) Family centroid matrix (d × n_families) integer(kind=int32), intent(in) :: gene_to_centroid (n_genes) Mapping from genes to family centroids to genes of expression_vectors -> family_centroids(:, gene_to_centroid(n)) returns the family centroid of expression_vectors(:,n) real(kind=real64), intent(out) :: shift_vectors (2*d,n_genes) Output, real matrix array, size = 2d x n_genes , stores the centroid of the gene's family in rows 1..d and the shift vectors in rows d+1...2d integer(kind=int32), intent(out) :: ierr Error code: 0 - success, non-zero = error","tags":"","url":"module/tox_shift_vectors.html"},{"title":"binary_search_tree – TensorOmics","text":"Uses f42_utils safeguard iso_fortran_env tox_errors Functions public  function get_sorted_value (values, sorted_indices, position, ierr) result(sorted_value) Get the value at the sorted position. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (:) Input real array integer(kind=int32), intent(in) :: sorted_indices (:) Permutation index array integer(kind=int32), intent(in) :: position Sorted position (1-based) integer(kind=int32), intent(out) :: ierr Error code Return Value real(kind=real64) Subroutines public pure subroutine build_bst_index (values, num_values, sorted_indices, left_stack, right_stack, ierr) Build the BST index by sorting indices using values in x. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (num_values) Input real array to be indexed integer(kind=int32), intent(in) :: num_values Number of elements in values array integer(kind=int32), intent(out) :: sorted_indices (num_values) Output permutation index integer(kind=int32), intent(out) :: left_stack (num_values) Manual stack for left indices integer(kind=int32), intent(out) :: right_stack (num_values) Manual stack for right indices integer(kind=int32), intent(out) :: ierr Error code public pure subroutine bst_range_query (values, sorted_indices, num_values, lower_bound, upper_bound, output_indices, num_matches, ierr) Perform a 1D range query over the sorted index. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: values (num_values) Input real array integer(kind=int32), intent(in) :: sorted_indices (num_values) Permutation index array (sorted) integer(kind=int32), intent(in) :: num_values Number of elements real(kind=real64), intent(in) :: lower_bound Lower bound of range (inclusive) real(kind=real64), intent(in) :: upper_bound Upper bound of range (inclusive) integer(kind=int32), intent(out) :: output_indices (num_values) Output array of matching indices integer(kind=int32), intent(out) :: num_matches Number of matches found integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/binary_search_tree.html"},{"title":"relative_axis_plane_tools – TensorOmics","text":"Module for tools related to relative axis planes (RAPs), i.e. planes in higher-dimensional gene expression space Uses iso_fortran_env ieee_arithmetic safeguard tox_errors Functions public pure function cross_product_orientation_sign (a, b, n_dims, selected_axes) result(orientation_sign) Compute orientation sign from cross product of two vectors, using selected axes Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: a (n_dims) real(kind=real64), intent(in) :: b (n_dims) integer(kind=int32), intent(in) :: n_dims integer(kind=int32), intent(in) :: selected_axes (3) Return Value real(kind=real64) Subroutines public pure subroutine omics_vector_RAP_projection (vecs, n_axes, n_vecs, vecs_selection_mask, n_selected_vecs, axes_selection_mask, n_selected_axes, projections, ierr) Project selected vectors (e.g. expression vectors) onto the RAP constructed from a selected set of axes. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_axes, n_vecs) :: vecs matrix with expression vectors integer(kind=int32), intent(in) :: n_axes number of axes integer(kind=int32), intent(in) :: n_vecs number of vectors per axis logical, intent(in), dimension(n_vecs) :: vecs_selection_mask .true. for vectors where projection is to be computed integer(kind=int32), intent(in) :: n_selected_vecs count of .true. values in vecs_selection_mask logical, intent(in), dimension(n_axes) :: axes_selection_mask .true. for axes to be included in RAP integer(kind=int32), intent(in) :: n_selected_axes count of .true. values in axes_selection_mask real(kind=real64), intent(out), dimension(n_selected_axes, n_selected_vecs) :: projections projected vectors integer(kind=int32), intent(out) :: ierr Error code public pure subroutine omics_field_RAP_projection (vecs, n_axes, n_vecs, vecs_selection_mask, n_selected_vecs, axes_selection_mask, n_selected_axes, projections, ierr) Project selected vector fields (e.g. shift vectors) onto the RAP constructed from a selected set of axes. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(2 * n_axes, n_vecs) :: vecs matrix with vector fields, first n rows mean vector origin, last n rows vector targets integer(kind=int32), intent(in) :: n_axes number of axes integer(kind=int32), intent(in) :: n_vecs number of vectors per axis logical, intent(in), dimension(n_vecs) :: vecs_selection_mask .true. for vectors where projection is to be computed integer(kind=int32), intent(in) :: n_selected_vecs count of .true. values in vecs_selection_mask logical, intent(in), dimension(n_axes) :: axes_selection_mask .true. for axes to be included in RAP integer(kind=int32), intent(in) :: n_selected_axes count of .true. values in axes_selection_mask real(kind=real64), intent(out), dimension(n_selected_axes, n_selected_vecs) :: projections projected vectors integer(kind=int32), intent(out) :: ierr Error code public pure subroutine project_selected_vecs_onto_rap (selected_vecs, n_selected_axes, n_selected_vecs) Projects selected vectors onto its RAP Arguments Type Intent Optional Attributes Name real(kind=real64), intent(inout), dimension(n_selected_axes, n_selected_vecs) :: selected_vecs matrix with vectors for selected axes integer(kind=int32), intent(in) :: n_selected_axes number of selected axes integer(kind=int32), intent(in) :: n_selected_vecs number of selected vectors per axis public pure subroutine clock_hand_angle_between_vectors (v1, v2, n_dims, signed_angle, selected_axes_for_signed, ierr) Compute the signed clock hand angle between two RAP-projected and normalized vectors.\nCalculates the signed rotation angle between two normalized vectors in RAP space.\nFor 2D/3D: automatic directionality calculation. For >3D: uses selected axes for directionality. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims) :: v1 First normalized vector in RAP space real(kind=real64), intent(in), dimension(n_dims) :: v2 Second normalized vector in RAP space integer(kind=int32), intent(in) :: n_dims Dimension of both vectors real(kind=real64), intent(out) :: signed_angle Signed angle between vectors in radians [-π, π] integer(kind=int32), intent(in), dimension(3) :: selected_axes_for_signed Indices of 3 axes to use for directionality calculation (ignored if n_dims <= 3) integer(kind=int32), intent(out) :: ierr Error code public pure subroutine clock_hand_angles_for_shift_vectors (origins, targets, n_dims, n_vecs, vecs_selection_mask, n_selected_vecs, selected_axes_for_signed, signed_angles, ierr) Compute signed rotation angles between RAP-projected and normalized vector pairs.\nTakes separate arrays of RAP-projected and normalized vectors (e.g. expression centroids and paralogs) and computes the signed rotation angle between corresponding pairs.\nThis measures both magnitude and directionality of angular separation in RAP space. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims, n_vecs) :: origins First set of RAP-projected, normalized vectors (e.g. expression centroids) real(kind=real64), intent(in), dimension(n_dims, n_vecs) :: targets Second set of RAP-projected, normalized vectors (e.g. paralogs) integer(kind=int32), intent(in) :: n_dims Dimension of each vector in RAP space integer(kind=int32), intent(in) :: n_vecs Number of vector pairs logical, intent(in), dimension(n_vecs) :: vecs_selection_mask .true. for vector pairs where angle should be computed integer(kind=int32), intent(in) :: n_selected_vecs Count of .true. values in vecs_selection_mask integer(kind=int32), intent(in), dimension(3) :: selected_axes_for_signed Indices of 3 axes to use for directionality calculation (ignored if n_dims <= 3) real(kind=real64), intent(out), dimension(n_selected_vecs) :: signed_angles Signed rotation angles between vector pairs in radians [-π, π] integer(kind=int32), intent(out) :: ierr Error code public pure subroutine compute_relative_axis_contributions (vec, n_axes, contributions, ierr) Compute fractional contribution of each axis to a RAP-projected and normalized shift vector.\nShared utility: computes fractional contribution of each axis to a RAP-projected and normalized vector. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_axes) :: vec RAP-projected and normalized vector (expression or shift) integer(kind=int32), intent(in) :: n_axes Number of axes (length of vec and contributions) real(kind=real64), intent(out), dimension(n_axes) :: contributions Fractional contribution of each axis (output), values in [0,1], sum to 1 integer(kind=int32), intent(out) :: ierr Error code public pure subroutine relative_axes_changes_from_shift_vector (vec, n_axes, contributions, ierr) Compute fractional contribution of each axis to a RAP-projected and normalized shift vector.\nWrapper for shift vectors (e.g. difference between two RAP-projected vectors) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_axes) :: vec RAP-projected and normalized shift vector integer(kind=int32), intent(in)