t :: expr Expression matrix containing real(kind=c_double), intent(in), dimension(n_genes), target :: means Per-gene mean expression values real(kind=c_double), intent(out), dimension(n_reps, n_genes), target :: resid Matrix of signed residuals integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/compute_residuals_c.html"},{"title":"pool_means_c – TensorOmics","text":"pure subroutine pool_means_c(n_genes_S1, mean_S1, n_genes_S2, mean_S2, n_points, n_pool, x_star, ierr) bind(C, name=\"pool_means_c\") Uses tox_data_integration tox_errors iso_c_binding C-compatible wrapper for pool_means_alloc Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_genes_S1 Number of genes in study S1 real(kind=c_double), intent(in), dimension(n_genes_S1), target :: mean_S1 Per-gene mean expression values integer(kind=c_int), intent(in), target :: n_genes_S2 Number of genes in study S2 real(kind=c_double), intent(in), dimension(n_genes_S2), target :: mean_S2 Per-gene mean expression values integer(kind=c_int), intent(in), target :: n_points Number of reference points to define integer(kind=c_int), intent(out), target :: n_pool Total number of included (non-NaN) pooled mean-expression values real(kind=c_double), intent(out), dimension(n_points), target :: x_star Mean-expression reference points integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/pool_means_c.html"},{"title":"pool_means_expert_c – TensorOmics","text":"pure subroutine pool_means_expert_c(pooled_means, pooled_means_perm, pool_size, n_points, n_pool, x_star, ierr) bind(C, name=\"pool_means_expert_c\") Uses tox_data_integration tox_errors iso_c_binding C-compatible wrapper for pool_means Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(pool_size), target :: pooled_means Pooled means integer(kind=c_int), intent(in), dimension(pool_size), target :: pooled_means_perm Sorting permutation for p