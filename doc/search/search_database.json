icates (included ones) integer(kind=c_int), intent(out), target :: ierr Error code integer(kind=c_int), intent(in), dimension(n_neighbors, n_points), target :: neighbor_mask Mask to exclude specific neighbors (e.g. for family-wise analysis)","tags":"","url":"proc/build_residual_histograms_filtered_c.html"},{"title":"compute_divergence_per_reference_point_c – TensorOmics","text":"pure subroutine compute_divergence_per_reference_point_c(pmf_S1, pmf_S2, n_points, n_bins, js_divergences, ierr) bind(C, name=\"compute_divergence_per_reference_point_c\") Uses tox_data_integration tox_errors iso_c_binding C-compatible wrapper for compute_divergence_per_reference_point Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_points, n_bins), target :: pmf_S1 Computed normalized hostogram counts from build_residual_histograms for study 1 real(kind=c_double), intent(in), dimension(n_points, n_bins), target :: pmf_S2 Computed normalized hostogram counts from build_residual_histograms for study 2 integer(kind=c_int), intent(in), target :: n_points Number of reference points (k) integer(kind=c_int), intent(in), target :: n_bins Number of equally sized histogram bins in range [-R,R] real(kind=c_double), intent(out), dimension(n_points), target :: js_divergences Jensen-Shannon divergence per reference point integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/compute_divergence_per_reference_point_c.html"},{"title":"compute_weighted_global_divergence_c – TensorOmics","text":"pure subroutine compute_weighted_global_divergence_c(js_divergences, n_points, included_n_reps_S1, included_n_reps_S2, global_js_divergence, weights, ierr) bind(C, name=\"compute_weighted_global_divergence_c\") Uses tox_data_integration tox_errors iso_c_binding C-compatible wrapper for compute_weighted_global_divergence Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_points), target :: js_divergences Jensen-Shannon divergence per reference point, computed for studies S1 and S2 integer(kind=c_int), intent(in), target :: n_points Number of reference points (k) integer(kind=c_int), intent(in), dimension(n_points), target :: included_n_reps_S1 Count of non-NaN residuals (included ones) in study 1 integer(kind=c_int), intent(in), dimension(n_points), target :: included_n_reps_S2 Count of non-NaN residuals (included ones) in study 2 real(kind=c_double), intent(out), target :: global_js_divergence Weighted global Jensen-Shannon divergence real(kind=c_double), intent(out), dimension(n_points), target :: weights Weights used for calculating the global weighted Jensen-Shannon divergence global_js_divergence integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/compute_weighted_global_divergence_c.html"},{"title":"get_array_metadata_C – TensorOmics","text":"subroutine get_array_metadata_C(filename_raw, fn_len, dims_out, dims_out_capacity, ndims, ierr, clen) bind(C, name=\"get_array_metadata_C\") Uses tox_conversions tox_errors iso_c_binding iso_fortran_env f42_array_utils C binding for the subroutine to get the dimensions of an array file Arguments Type Intent Optional Attributes Name character(kind=c_char, len=1), intent(in), target :: filename_raw (fn_len) Array of ASCII characters representing the filename integer(kind=c_int), intent(in), target :: fn_len Length of the filename array integer(kind=c_int), intent(out), target :: dims_out (dims_out_capacity) Output array for dimensions integer(kind=c_int), intent(in), target :: dims_out_capacity integer(kind=c_int), intent(out), target :: ndims Output variable for the number of dimensions integer(kind=c_int), intent(out), target :: ierr Error code integer(kind=c_int), intent(out), target :: clen Character length (only for character arrays)","tags":"","url":"proc/get_array_metadata_c.html"},{"title":"which_c – TensorOmics","text":"pure subroutine which_c(mask, n, idx_out, m_max, m_out, ierr) bind(C, name=\"which_c\") Uses tox_conversions tox_errors iso_c_binding f42_utils iso_fortran_env C wrapper for which.\nConverts integer mask to logical and calls which. Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: mask (n) Integer mask array (0/1 values). integer(kind=c_int), intent(in), target :: n Size of the mask. integer(kind=c_int), intent(out), target :: idx_out (m_max) Output array for indices of true values. integer(kind=c_int), intent(in), target :: m_max Maximum size of idx_out. integer(kind=c_int), intent(out), target :: m_out Actual size of idx_out (number of true values found). integer(kind=c_int), intent(out), target :: ierr Error code: 0=ok, 201=invalid input, 202=empty input","tags":"","url":"proc/which_c.html"},{"title":"loess_smooth_2d_c – TensorOmics","text":"pure subroutine loess_smooth_2d_c(n_total, n_target, x_ref, y_ref, indices_used, n_used, x_query, kernel_sigma, kernel_cutoff, y_out, ierr) bind(C, name=\"loess_smooth_2d_c\") Uses f42_utils iso_fortran_env tox_errors iso_c_binding C wrapper for loess_smooth_2d.\nDirect wrapper - user must pre-filter indices in C before calling. Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_total Total number of reference points. integer(kind=c_int), intent(in), target :: n_target Number of target points to smooth. real(kind=c_double), intent(in), target :: x_ref (n_total) Reference x-coordinates. real(kind=c_double), intent(in), target :: y_ref (n_total) Reference y-coordinates (length n_total). integer(kind=c_int), intent(in), target :: indices_used (n_used) Indices of reference points used for smoothing (pre-filtered). integer(kind=c_int), intent(in), target :: n_used Number of indices actually used for smoothing. real(kind=c_double), intent(in), target :: x_query (n_target) Target x-coordinates to smooth. real(kind=c_double), intent(in), target :: kernel_sigma Bandwidth parameter for the kernel. real(kind=c_double), intent(in), target :: kernel_cutoff Cutoff for the kernel. real(kind=c_double), intent(out), target :: y_out (n_target) Output smoothed values (length n_target). integer(kind=c_int), intent(out), target :: ierr Error code: 0=ok, 201=invalid input, 202=empty input","tags":"","url":"proc/loess_smooth_2d_c.html"},{"title":"compute_edf_c – TensorOmics","text":"subroutine compute_edf_c(values, n_values, unique_values, cdf_values, n_unique, ierr) bind(C, name=\"compute_edf_c\") Uses f42_utils iso_fortran_env tox_errors iso_c_binding IMPORTANT - When using these C wrapper functions, no copies of the arrays will be created.\nThe Fortran routine will operate directly on the memory provided by the caller.\nC wrapper for compute_edf.\nAllocates workspace internally and exposes a simple interface with C types.\nThe number of unique values is returned via n_unique output parameter. Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), target :: values (n_values) Array of observed data values (e.g., contributions or spikes). integer(kind=c_int), intent(in), target :: n_values Number of values in the input array. real(kind=c_double), intent(out), target :: unique_values (n_values) Sorted unique data values (sized to n_values). real(kind=c_double), intent(out), target :: cdf_values (n_values) Corresponding cumulative frequencies between 0 and 1 (sized to n_values). integer(kind=c_int), intent(out), target :: n_unique Number of unique values found. integer(kind=c_int), intent(out), target :: ierr Error code: 0=ok, 201=invalid input, 202=empty input","tags":"","url":"proc/compute_edf_c.html"},{"title":"compute_edf_expert_c – TensorOmics","text":"subroutine compute_edf_expert_c(values, n_values, perm, unique_values, cdf_values, n_unique, ierr) bind(C, name=\"compute_edf_expert_c\") Uses f42_utils iso_fortran_env tox_errors iso_c_binding Expert C wrapper for compute_edf.\nDirect interface to compute_edf for users who have already sorted their data\nor have a custom permutation vector. This skips the internal sorting step\nfor better performance when the caller has full control. Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), target :: values (n_values) Array of observed data values (e.g., contributions or spikes). integer(kind=c_int), intent(in), target :: n_values Number of values in the input array. integer(kind=c_int), intent(in), target :: perm (n_values) Pre-sorted permutation indices (must be sorted by values[perm]).\nCaller is responsible for sorting this array before calling. real(kind=c_double), intent(out), target :: unique_values (n_values) Sorted unique data values (sized to n_values). real(kind=c_double), intent(out), target :: cdf_values (n_values) Corresponding cumulative frequencies between 0 and 1 (sized to n_values). integer(kind=c_int), intent(out), target :: n_unique Number of unique values found. integer(kind=c_int), intent(out), target :: ierr Error code: 0=ok, 201=invalid input, 202=empty input","tags":"","url":"proc/compute_edf_expert_c.html"},{"title":"serialize_char_nd_C – TensorOmics","text":"subroutine serialize_char_nd_C(raw_chars, dims, ndim, clen, filename_c, fn_len, ierr) bind(C, name=\"serialize_char_nd_C\") Uses tox_conversions tox_errors iso_c_binding f42_serialize_char iso_fortran_env Arguments Type Intent Optional Attributes Name character(kind=c_char, len=1), intent(in), target :: raw_chars (clen,product(dims)) Raw chars array integer(kind=c_int), intent(in), target :: dims (ndim) Dimensions of the array integer(kind=c_int), intent(in), target :: ndim Number of dimensions integer(kind=c_int), intent(in), target :: clen Length of each string character(kind=c_char, len=1), intent(in), target :: filename_c (fn_len) filename as c_char array integer(kind=c_int), intent(in), target :: fn_len length of the filename array integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/serialize_char_nd_c.html"},{"title":"normalize_variable_timeseries_C – TensorOmics","text":"pure subroutine normalize_variable_timeseries_C(v, v_norm, n_points, ierr, status) bind(C, name=\"normalize_variable_timeseries_C\") Uses tox_trajectory_normalization tox_errors iso_c_binding Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_points), target :: v Original time series real(kind=c_double), intent(out), dimension(n_points), target :: v_norm Normalized time series integer(kind=c_int), intent(in), target :: n_points Vector length integer(kind=c_int), intent(out), target :: ierr Error code integer(kind=c_int), intent(out), target :: status Status code for specific warnings","tags":"","url":"proc/normalize_variable_timeseries_c.html"},{"title":"normalize_single_trajectory_C – TensorOmics","text":"pure subroutine normalize_single_trajectory_C(trajectory, trajectory_norm, n_factors, n_timepoints, ierr, status) bind(C, name=\"normalize_single_trajectory_C\") Uses tox_trajectory_normalization tox_errors iso_c_binding Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_timepoints, n_factors), target :: trajectory Original trajectory for one sample real(kind=c_double), intent(out), dimension(n_timepoints, n_factors), target :: trajectory_norm Normalized trajectory for one sample integer(kind=c_int), intent(in), target :: n_factors Number of factors integer(kind=c_int), intent(in), target :: n_timepoints Number of time points integer(kind=c_int), intent(out), target :: ierr Error code integer(kind=c_int), intent(out), target :: status Status code for specific warnings","tags":"","url":"proc/normalize_single_trajectory_c.html"},{"title":"normalize_all_trajectories_C – TensorOmics","text":"pure subroutine normalize_all_trajectories_C(trajectories, trajectories_norm, n_factors, n_samples, n_timepoints, ierr, status) bind(C, name=\"normalize_all_trajectories_C\") Uses tox_trajectory_normalization tox_errors iso_c_binding Arguments Type Intent Optional Attri