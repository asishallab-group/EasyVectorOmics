ons integer(kind=int32), intent(in) :: dims (ndim) Dimensions of the array","tags":"","url":"proc/write_real_array_header.html"},{"title":"serialize_real_1d – TensorOmics","text":"public  subroutine serialize_real_1d(arr, filename) Serialize a 1D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:) array to save character(len=*), intent(in) :: filename output filename","tags":"","url":"proc/serialize_real_1d.html"},{"title":"serialize_real_2d – TensorOmics","text":"public  subroutine serialize_real_2d(arr, filename) Serialize a 2D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:,:) array to save character(len=*), intent(in) :: filename filename","tags":"","url":"proc/serialize_real_2d.html"},{"title":"serialize_real_3d – TensorOmics","text":"public  subroutine serialize_real_3d(arr, filename) Serialize a 3D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data.\n@param arr The input real array to serialize.\n@param filename The output filename. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:,:,:) array to save character(len=*), intent(in) :: filename filename","tags":"","url":"proc/serialize_real_3d.html"},{"title":"serialize_real_4d – TensorOmics","text":"public  subroutine serialize_real_4d(arr, filename) Serialize a 4D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:,:,:,:) array to save character(len=*), intent(in) :: filename filename","tags":"","url":"proc/serialize_real_4d.html"},{"title":"serialize_real_5d – TensorOmics","text":"public  subroutine serialize_real_5d(arr, filename) Serialize a 5D real(real64) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:,:,:,:,:) array to save character(len=*), intent(in) :: filename filename","tags":"","url":"proc/serialize_real_5d.html"},{"title":"serialize_real_nd – TensorOmics","text":"public  subroutine serialize_real_nd(arr, dims, ndim, filename) @brief Writes serialized real array from R to file with metdata. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in) :: arr (:) array to save integer(kind=int32), intent(in) :: dims (:) Dimensions of the array integer(kind=int32), intent(in) :: ndim Number of dimensions character(len=*), intent(in) :: filename filename","tags":"","url":"proc/serialize_real_nd.html"},{"title":"deserialize_real_flat – TensorOmics","text":"public  subroutine deserialize_real_flat(flat, dims, filename) Uses iso_c_binding Deserialize a flat real array from a file Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out), pointer :: flat (:) Output flat array integer(kind=int32), intent(out), allocatable, target :: dims (:) dimensions array character(len=*), intent(in) :: filename","tags":"","url":"proc/deserialize_real_flat.html"},{"title":"deserialize_real_1d – TensorOmics","text":"public  subroutine deserialize_real_1d(arr, filename) Uses iso_c_binding Deserialize a 1D real array from a file Note This file just moves a pointer, it exists for consistency Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out), pointer :: arr (:) Output array character(len=*), intent(in) :: filename Name of the file to read","tags":"","url":"proc/deserialize_real_1d.html"},{"title":"deserialize_real_2d – TensorOmics","text":"public  subroutine deserialize_real_2d(arr, filename) 