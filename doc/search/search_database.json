_bins) :: pmf_S2 Absolute counts of a residual per bin obtained from build_residual_histograms integer(kind=int32), intent(out), dimension(n_points, n_bins) :: tmp_counts Working array for build_residual_histograms logical, intent(in), optional, dimension(n_neighbors, n_points) :: neighbor_mask_S1 Optional mask to exclude specific neighbors from study 1 (e.g. for family-wise analysis) logical, intent(in), optional, dimension(n_neighbors, n_points) :: neighbor_mask_S2 Optional mask to exclude specific neighbors from study 2 (e.g. for family-wise analysis) public        interface fjct_compute_jsd_alloc public pure module subroutine fjct_compute_jsd_alloc(family_idx, gene_to_family_S1, gene_to_family_S2, n_genes_S1, n_genes_S2, neighborhood_residuals_S1, neighborhood_residuals_S2, neighborhood_genes_S1, neighborhood_genes_S2, n_reps_S1, n_reps_S2, n_neighbors, n_points, n_bins, shared_residual_range, js_divergences, included_n_reps_S1, included_n_reps_S2, total_included_n_reps, global_js_divergence, weights, ierr) Computes the family-level compatibility score global_js_divergence between two studies for a single gene family ( family_idx ), by reusing the same conditioning-on-mean-expression pipeline as the global gJCT, but restricting residual samples to genes belonging to the specified family Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: family_idx Index of the family that should be analyzed integer(kind=int32), intent(in), dimension(n_genes_S1) :: gene_to_family_S1 Mapping for study 1: Each index (gene) holds the index of its family integer(kind=int32), intent(in), dimension(n_genes_S2) :: gene_to_family_S2 Mapping for study 2: Each index (gene) holds the index of its family integer(kind=int32), intent(in) :: n_genes_S1 Number of genes in study 1 integer(kind=int32), intent(in) :: n_genes_S2 Number of genes in study 2 real(kind=real64), intent(in), dimension(n_reps_S1, n_neighbors, n_points) :: neighborhood_residuals_S1 Computed neighborhood residuals for study 1 ( construct_neighborhoods ), NaN is explicitly allowed for missing values real(kind=real64), intent(in), dimension(n_reps_S2, n_neighbors, n_points) :: neighborhood_residuals_S2 Computed neighborhood residuals for study 2 ( construct_neighborhoods ), NaN is explicitly allowed for missing values integer(kind=int32), intent(in), dimension(n_neighbors, n_points) :: neighborhood_genes_S1 Indices of selected neighborhood genes, obtained from neighborhood_indices of construct_neighborhoods integer(kind=int32), intent(in), dimension(n_neighbors, n_points) :: neighborhood_genes_S2 Indices of selected neighborhood genes, obtained from neighborhood_indices of construct_neighborhoods integer(kind=int32), intent(in) :: n_reps_S1 Number of replicates in study 1 integer(kind=int32), intent(in) :: n_reps_S2 Number of replicates in study 2 integer(kind=int32), intent(in) :: n_neighbors Number of neighbors in the studies integer(kind=int32), intent(in) :: n_points Number of reference points in the studies integer(kind=int32), intent(in) :: n_bins Number of equally sized histogram bins used for the studies in build_residual_histograms real(kind=real64), intent(in) :: shared_residual_range Computed residual range for both studies, from determine_shared_residual_range real(kind=real64), intent(out), dimension(n_points) :: js_divergences Jensen-Shannon divergence per reference point, computed for studies S1 and S2 integer(kind=int32), intent(out), dimension(n_points) :: included_n_reps_S1 Count of non-NaN residuals (included ones) in study 1 (obtained from build_residual_histograms ) integer(kind=int32), intent(out), dimension(n_points) :: included_n_reps_S2 Count of non-NaN residuals (included ones) in study 2 (obtained from build_residual_histograms ) integer(kind=int32), intent(out) :: total_included_n_reps Total number of included replicates from both studies ( ) real(kind=real64), intent(out) :: global_js_divergence Weighted global Jensen-Shannon divergence real(kind=real64), intent(out), dimension(n_points) :: weights Weights used for calculating the global weighted Jensen-Shannon divergence global_js_divergence integer(kind=int32), intent(out) :: ierr Error code public        interface fjct_compute_jsd public pure module subroutine fjct_compute_jsd(neighborhood_residuals_S1, neighborhood_residuals_S2, n_reps_S1, n_reps_S2, n_neighbors, n_points, neighbor_mask_S1, neighbor_mask_S2, n_bins, shared_residual_range, js_divergences, included_n_reps_S1, included_n_reps_S2, total_included_n_reps, global_js_divergence, weights, pmf_S1, pmf_S2, tmp_counts, ierr) Computes the compatibility score global_js_divergence between two studies per sub-neighborhood/family for a single gene family ( family_idx ), by reusing the same conditioning-on-mean-expression pipeline as the global gJCT, but restricting residual samples to genes belonging to the specified family Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_reps_S1, n_neighbors, n_points) :: neighborhood_residuals_S1 Computed neighborhood residuals for study 1 ( construct_neighborhoods ), NaN is explicitly allowed for missing values real(kind=real64), intent(in), dimension(n_reps_S2, n_neighbors, n_points) :: neighborhood_residuals_S2 Computed neighborhood residuals for study 2 ( construct_neighborhoods ), NaN is explicitly allowed for missing values integer(kind=int32), intent(in) :: n_reps_S1 Number of replicates in study 1 integer(kind=int32), intent(in) :: n_reps_S2 Number of replicates in study 2 integer(kind=int32), intent(in) :: n_neighbors Number of neighbors in the studies integer(kind=int32), intent(in) :: n_points Number of reference points in the studies logical, intent(in), dimension(n_neighbors, n_points) :: neighbor_mask_S1 Optional mask to exclude specific neighbors from study 1 (e.g. for family-wise analysis) logical, intent(in), dimension(n_neighbors, n_points) :: neighbor_mask_S2 Optional mask to exclude specific neighbors from study 2 (e.g. for family-wise analysis) integer(kind=int32), intent(in) :: n_bins Number of equally sized histogram bins used for the studies in build_residual_histograms real(kind=real64), intent(in) :: shared_residual_range Computed residual range for both studies, from determine_shared_residual_range real(kind=real64), intent(out), dimension(n_points) :: js_divergences Jensen-Shannon divergence per reference point, computed for studies S1 and S2 integer(kind=int32), intent(out), dimension(n_points) :: included_n_reps_S1 Count of non-NaN residuals (included ones) in study 1 (will be obtained from build_residual_histograms ) integer(kind=int32), intent(out), dimension(n_points) :: included_n_reps_S2 Count of non-NaN residuals (included ones) in study 2 (will be obtained from build_residual_histograms ) integer(kind=int32), intent(out) :: total_included_n_reps Total number of included replicates from both studies ( ) real(kind=real64), intent(out) :: global_js_divergence Weighted global Jensen-Shannon divergence real(kind=real64), intent(out), dimension(n_points) :: weights Weights used for calculating the global weighted Jensen-Shannon divergence global_js_divergence real(kind=real64), intent(out), dimension(n_points, n_bins) :: pmf_S1 Absolute counts of a residual per bin (will be obtained from build_residual_histograms ) real(kind=real64), intent(out), dimension(n_points, n_bins) :: pmf_S2 Absolute counts of a residual per bin (will be obtained from build_residual_histograms ) integer(kind=int32), intent(out), dimension(n_points, n_bins) :: tmp_counts Working array for build_residual_histograms integer(kind=int32), intent(out) :: ierr Error code public        interface fjct_compute_contribution_scores public pure module subroutine fjct_compute_contribution_scores(global_js_divergences, total_included_n_reps_per_f, k_families, support_weights, contribution_scores, ierr) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(k_families) :: global_js_divergences Per-sub-neighborhood weighted global JSD integer(kind=int32), intent(in), dimension(k_families) :: total_included_n_reps_per_f Per-sub-neighborhood total_included_n_reps integer(kind=int32), intent(in) :: k_families Number of sub-neighborhoods analyzed real(kind=real64), intent(out), dimension(k_families) :: support_weights Per-sub-neighborhood calculated support weight (ratio between its total_included_n_reps and sum(total_included_n_reps_per_f) , zero if there were no replicates included at all) real(kind=real64), intent(out), dimension(k_families) :: contribution_scores Per-sub-neighborhood calculated contribution ( ) integer(kind=int32), intent(out), target :: ierr Error code public        interface fjct_compute_contribution_scores_helper public pure module subroutine fjct_compute_contribution_scores_helper(global_js_divergences, total_included_n_reps_per_f, k_families, support_weights, contribution_scores) (no input validation) Computes the per-family/per-sub-neighborhood contribution score that combines how divergent the family is between the studies (``), and how much residual support the family has overall (), using the outputs from tox_data_integration_per_family , collected for the analyzed sub-neighborhoods. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(k_families) :: global_js_divergences Per-sub-neighborhood weighted global JSD integer(kind=int32), intent(in), dimension(k_families) :: total_included_n_reps_per_f Per-sub-neighborhood total_included_n_reps integer(kind=int32), intent(in) :: k_families Number of sub-neighborhoods analyzed real(kind=real64), intent(out), dimension(k_families) :: support_weights Per-sub-neighborhood calculated support weight (ratio between its total_included_n_reps and sum(total_included_n_reps_per_f) , zero if there were no replicates included at all) real(kind=real64), intent(out), dimension(k_families) :: contribution_scores Per-sub-neighborhood calculated contribution ( )","tags":"","url":"module/tox_data_integration.html"},{"title":"f42_xxh3_hashmap – TensorOmics","text":"Uses safeguard tox_errors iso_c_binding f42_utils config iso_fortran_env Derived Types type, public :: hashmap_type Components Type Visibility Attributes Name Initial integer(kind=int32), public :: size = 0 integer(kind=int32), public :: count = 0 type(hashmap_node_type), public, pointer :: buckets (:) => null() type, public :: hashset_type Components Type Visibility Attributes Name Initial integer(kind=int32), public :: size = 0 integer(kind=int32), public :: count = 0 type(hashset_node_type), public, pointer :: buckets (:) => null() Functions public  function is_in_hashset (hashset, key) result(res) Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(in) :: hashset character(len=*), intent(in) :: key Return Value logical public  function hashmap_get (map, key) result(value) Lookup a key Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(in) :: map hashmap character(len=*), intent(in) :: key key to look for Return Value integer(kind=int32) return value Subroutines public  subroutine hashmap_create (map, initial_size) Create the hashmap Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(out) :: map Hashmap object to create integer(kind=int32), intent(in), optional :: initial_size Size of the hashmap public  subroutine hashset_create (map, initial_size) Create the hashmap Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(out) :: map Hashmap object to create integer(kind=int32), intent(in), optional :: initial_size Size of the hashmap public  subroutine hashmap_destroy (map) Destroy the hashmap Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(inout) :: map The hashmap to delete public  subroutine hashset_destroy (set) Destroy the set Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(inout) :: set The set to delete public  subroutine hashmap_put (map, key, value) Insert a key-value pair Arguments Type Intent Optional Attributes Name type( hashmap_type ), intent(inout) :: map hashmap to insert into character(len=*), intent(in) :: key Key to store integer(kind=int32), intent(in) :: value value to store public  subroutine hashset_put (set, key, ierr) Insert a key-value pair Arguments Type Intent Optional Attributes Name type( hashset_type ), intent(inout) :: set hashmap to insert into character(len=*), intent(in) :: key Key to store integer(kind=int32), intent(out) :: ierr Error code","tags":"","url":"module/f42_xxh3_hashmap.html"},{"title":"f42_serialize_int – TensorOmics","text":"Module for serializing integer arrays to binary files. Uses safeguard tox_errors iso_c_binding iso_fortran_env f42_array_utils Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: ARRAY_TYPE_INT = 1 Subroutines public  subroutine serialize_int_1d (arr, filename, ierr) Serialize a 1D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_int_2d (arr, filename, ierr) Serialize a 2D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32) :: ierr error code public  subroutine serialize_int_3d (arr, filename, ierr) Serialize a 3D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32) :: ierr error code public  subroutine serialize_int_4d (arr, filename, ierr) Serialize a 4D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:,:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_int_5d (arr, filename, ierr) Serialize a 5D integer(int32) array to a binary file.\nThe file will contain a magic number, type code, dimension, shape, and the array data. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:,:,:,:,:) array to save character(len=*), intent(in) :: filename output filename integer(kind=int32), intent(out) :: ierr error code public  subroutine serialize_int_nd (arr, dims, ndim, filename, ierr) Serialize a flat integer array with specified dimensions and number of dimensions to a binary file. Read more… Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: arr (:) Flat integer array to serialize integer(kind=int32), intent(in) :: dims (:) Dimensions of the array integer(kind=int32), intent(in) :: ndim Number of dimensions character(len=*), intent(in) :: filename filename integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"module/f42_serialize_int.html"},{"title":"tox_paralog_analysis – TensorOmics","text":"Uses f42_utils safeguard iso_fortran_env tox_errors Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: DOSAGE_PATTERN = 0 integer(kind=int32), public, parameter :: SUBFUNC_PATTERN = 1 Functions public pure function mask_get_first_successor_idx (bit_mask) result(idx) Helper function that returns the index after the last active gene in bit_mask , so the first succeeding gene. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in), dimension(:) :: bit_mask chunked mask to mark active genes Return Value integer(kind=int32) index of last active gene public pure function mask_check_state (bit_mask, i_gene) result(state) Checks the state of a bit/paralog in bit_mask -> .true. if 1 else .false. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in), dimension(:) :: bit_mask chunked mask to mark active paralogs integer(kind=int32), intent(in) :: i_gene index of paralog to be marked active Return Value logical check result Subroutines public pure subroutine detect_neofunctionalization (ancestors, n_families, genes, n_axes, gene_to_fam, n_genes, thresholds, neofunc, ierr) Identifies neofunctionalization for genes by checking whether the difference of expression to its ancestor exceeds the threshold for the respective axis. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_axes, n_families) :: ancestors RAP projected unit length expression vector of ancestral ortholog integer(kind=int32), intent(in) :: n_families number of vectors in ancestors real(kind=real64), intent(in), dimension(n_axes, n_genes) :: genes RAP projected unit length expression vectors of genes integer(kind=int32), intent(in) :: n_axes size of ancestors vector and vectors in genes integer(kind=int32), intent(in), dimension(n_genes) :: gene_to_fam mapping of gene index to family index integer(kind=int32), intent(in) :: n_genes number of vectors in genes real(kind=real64), intent(in), dimension(n_axes) :: thresholds threshold per axis that defines significant change in expression, may be a percentile of all genes' changes per axis logical, intent(out), dimension(n_genes, n_axes) :: neofunc .true. if neofunctionalization has been detected for the respective axes integer(kind=int32), intent(out) :: ierr error code public pure subroutine detect_dosage_effect (ancestor, genes, n_genes, n_dims, filtered_paralogs_mask, n_mask_chunks, n_results, max_subset_size, work_arr_paralog_subsets, n_paralog_subsets, active_mask, temp_paralog_vector, ierr, max_angle, gain_gamma) Identifies subsets of paralogs with small angle to the ancestor (max_angle) and sum to a magnitude significantly exceeding norm(ancestor) (gain) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims) :: ancestor expression vector of ancestral ortholog real(kind=real64), intent(in), dimension(n_dims, n_genes) :: genes expression vectors of genes integer(kind=int32), intent(in) :: n_genes number of vectors in genes integer(kind=int32), intent(in) :: n_dims size of ancestor vector and vectors in genes integer(kind=int32), intent(in), dimension(n_mask_chunks) :: filtered_paralogs_mask bit mask with genes' indices kept by pattern set to 1, else 0. Use filter_paralogs_by_pattern for its calculation integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes. Use subroutine mask_chunk_count for calculation integer(kind=int32), intent(out) :: n_results number of resulting subsets. They are stored as the first n_results elements of work_arr_paralog_subsets integer(kind=int32), intent(in) :: max_subset_size maximum subset size of checked gene subsets. USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=int32), intent(out), dimension(n_mask_chunks, n_paralog_subsets) :: work_arr_paralog_subsets working array to hold bitmask encoded subsets for detection. Read more… integer(kind=int32), intent(in) :: n_paralog_subsets number of gene subsets that can be stored in work_arr_paralog_subsets . USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=int32), intent(out), dimension(n_mask_chunks) :: active_mask working array to hold the extended subsets real(kind=real64), intent(out), dimension(n_dims) :: temp_paralog_vector vector used for pruning subsets integer(kind=int32), intent(out) :: ierr error code real(kind=real64), intent(in), optional :: max_angle in dosage mode maximum angle in radians 0<=angle<=Pi that a subset candidate must not exceed, otherwise pruned, default is Pi real(kind=real64), intent(in), optional :: gain_gamma positive magnitude gain for dosage effect, default 0.1 public pure subroutine detect_subfunctionalization (ancestor, genes, n_genes, n_dims, rdi_threshold, filtered_paralogs_mask, n_mask_chunks, n_results, max_subset_size, work_arr_paralog_subsets, n_paralog_subsets, active_mask, temp_paralog_vector, paralog_norms, sorted_paralog_norms_perm, temp_work_array, ierr) Identifies subsets of paralogs exhibiting significant angles to the ancestor Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims) :: ancestor expression vector of ancestral ortholog real(kind=real64), intent(in), dimension(n_dims, n_genes) :: genes expression vectors of genes integer(kind=int32), intent(in) :: n_genes number of vectors in genes integer(kind=int32), intent(in) :: n_dims size of ancestor vector and vectors in genes real(kind=real64), intent(in) :: rdi_threshold max allowed residual distance from ancestor integer(kind=int32), intent(in), dimension(n_mask_chunks) :: filtered_paralogs_mask bit mask with genes' indices kept by pattern set to 1, else 0. Use filter_paralogs_by_pattern for its calculation integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes. Use subroutine mask_chunk_count for calculation integer(kind=int32), intent(out) :: n_results number of resulting subsets. They are stored as the first n_results elements of work_arr_paralog_subsets integer(kind=int32), intent(in) :: max_subset_size maximum subset size of checked gene subsets. USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=int32), intent(out), dimension(n_mask_chunks, n_paralog_subsets) :: work_arr_paralog_subsets working array to hold bitmask encoded subsets for detection. Read more… integer(kind=int32), intent(in) :: n_paralog_subsets number of gene subsets that can be stored in work_arr_paralog_subsets . USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=int32), intent(out), dimension(n_mask_chunks) :: active_mask working array to hold the extended subsets real(kind=real64), intent(out), dimension(n_dims) :: temp_paralog_vector vector used for pruning subsets real(kind=real64), intent(in), dimension(n_genes) :: paralog_norms needed for subset pruning, holds the euclidean norms of genes (you can use the norm function from f42_utils function for this) integer(kind=int32), intent(in), dimension(n_genes) :: sorted_paralog_norms_perm needed for subset pruning, as the minimum norm of the genes that could extend a subset should not be lower than the subset angle to the ancestor real(kind=real64), intent(out), dimension(n_genes) :: temp_work_array needed for efficient check of minimum value after a certain index integer(kind=int32), intent(out) :: ierr error code public pure subroutine detect_patterns (ancestor, genes, n_genes, n_dims, pattern, filtered_paralogs_mask, n_mask_chunks, n_results, max_subset_size, work_arr_paralog_subsets, n_paralog_subsets, active_mask, temp_paralog_vector, dosage_max_angle, dosage_gain_gamma, subfunc_rdi_threshold, subfunc_paralog_norms, subfunc_sorted_paralog_norms_perm, subfunc_temp_work_array, ierr) Identifies subsets of paralogs where dosage effect or subfunctionalization applies, depending on pattern Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims) :: ancestor expression vector of ancestral ortholog real(kind=real64), intent(in), dimension(n_dims, n_genes) :: genes expression vectors of genes integer(kind=int32), intent(in) :: n_genes number of vectors in genes integer(kind=int32), intent(in) :: n_dims size of ancestor vector and vectors in genes integer(kind=int32), intent(in) :: pattern used pattern for detection Read more… integer(kind=int32), intent(in), dimension(n_mask_chunks) :: filtered_paralogs_mask bit mask with genes' indices kept by pattern set to 1, else 0. Use filter_paralogs_by_pattern for its calculation integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes. Use subroutine mask_chunk_count for calculation integer(kind=int32), intent(out) :: n_results number of resulting subsets. They are stored as the first n_results elements of work_arr_paralog_subsets integer(kind=int32), intent(in) :: max_subset_size maximum subset size of checked gene subsets. USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=int32), intent(out), dimension(n_mask_chunks, n_paralog_subsets) :: work_arr_paralog_subsets working array to hold bitmask encoded subsets for detection. Read more… integer(kind=int32), intent(in) :: n_paralog_subsets number of gene subsets that can be stored in work_arr_paralog_subsets . USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=int32), intent(out), dimension(n_mask_chunks) :: active_mask working array to hold the extended subsets real(kind=real64), intent(out), dimension(n_dims) :: temp_paralog_vector vector used for pruning subsets real(kind=real64), intent(in), optional :: dosage_max_angle in dosage mode maximum angle in radians 0<=angle<=Pi that a subset candidate must not exceed, otherwise pruned, default is Pi real(kind=real64), intent(in), optional :: dosage_gain_gamma in dosage mode required positive magnitude gain for dosage, default 0.1 real(kind=real64), intent(in), optional :: subfunc_rdi_threshold max allowed residual distance from ancestor real(kind=real64), intent(in), optional, dimension(n_genes) :: subfunc_paralog_norms in subfunctionalization mode needed for subset pruning, holds the euclidean norms of genes (you can use the norm from f42_utils function for this) integer(kind=int32), intent(in), optional, dimension(n_genes) :: subfunc_sorted_paralog_norms_perm in subfunctionalization mode needed for subset pruning, as the minimum norm of the genes that could extend a subset should not be lower than the subset angle to the ancestor real(kind=real64), intent(out), optional, dimension(n_genes) :: subfunc_temp_work_array in subfunctionalization mode needed for efficient check of minimum value after a certain index integer(kind=int32), intent(out) :: ierr error code public pure subroutine generate_subsets_helper (candidate_mask, filtered_paralogs_mask, n_mask_chunks, pattern, ancestor, genes, n_genes, n_dims, temp_paralog_vector, work_arr_paralog_subsets, n_paralog_subsets, n_results, n_active_masks, n_new_active_masks, dosage_max_angle, dosage_gain_gamma, subfunc_rdi_threshold, subfunc_paralog_norms, subfunc_sorted_paralog_norms_perm, subfunc_temp_work_array, ierr) Generates subsets for candidate_mask by extending it with one valid gene.\nSubsets with bad gene constellation will be pruned,\nothers will be added to the work array, either as new active subset that will be extended in coming iterations or as result. Read more… Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(inout), dimension(n_mask_chunks) :: candidate_mask working array to hold a subset that is a potential result candidate integer(kind=int32), intent(in), dimension(n_mask_chunks) :: filtered_paralogs_mask bit mask that will have indices of genes kept by pattern set to 1, else 0 integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=int32), intent(in) :: pattern used pattern for detection Read more… real(kind=real64), intent(in), dimension(n_dims) :: ancestor expression vector of ancestral ortholog real(kind=real64), intent(in), dimension(n_dims, n_genes) :: genes expression vectors of genes integer(kind=int32), intent(in) :: n_genes number of vectors in genes integer(kind=int32), intent(in) :: n_dims size of ancestor vector and vectors in genes real(kind=real64), intent(inout), dimension(n_dims) :: temp_paralog_vector vector used for pruning subsets integer(kind=int32), intent(out), dimension(n_mask_chunks, n_paralog_subsets) :: work_arr_paralog_subsets working array to hold bitmask encoded subsets for detection. integer(kind=int32), intent(in) :: n_paralog_subsets number of gene subsets that can be stored in work_arr_paralog_subsets . USE calc_work_arr_paralog_subsets_size TO DETERMINE THIS NUMBER integer(kind=int32), intent(inout) :: n_results number of results in work_arr_paralog_subsets integer(kind=int32), intent(in) :: n_active_masks number of active subsets in work_arr_paralog_subsets integer(kind=int32), intent(inout) :: n_new_active_masks number of new active subsets in work_arr_paralog_subsets real(kind=real64), intent(in), optional :: dosage_max_angle in dosage mode maximum angle in radians that a subset candidate must not exceed, otherwise pruned, default is Pi real(kind=real64), intent(in), optional :: dosage_gain_gamma in dosage mode required positive magnitude gain for dosage, default 0.1 real(kind=real64), intent(in), optional :: subfunc_rdi_threshold max allowed residual distance from ancestor real(kind=real64), intent(in), optional, dimension(n_genes) :: subfunc_paralog_norms in subfunctionalization mode needed for subset pruning, holds the euclidean norms of genes (you can use the norm from f42_utils function for this) integer(kind=int32), intent(in), optional, dimension(n_genes) :: subfunc_sorted_paralog_norms_perm in subfunctionalization mode needed for subset pruning, as the minimum norm of the genes that could extend a subset should not be lower than the subset angle to the ancestor real(kind=real64), intent(out), optional, dimension(n_genes) :: subfunc_temp_work_array in subfunctionalization mode needed for efficient check of minimum value after a certain index integer(kind=int32), intent(out) :: ierr error code public pure subroutine fill_array_with_minvals_for_each_idx (out_arr, src_arr, sorted_src_arr_perm, src_arr_len, ierr) Helper for subfunctionalization pruning. It initializes a working array with each index i holding the min value in subarray src_arr(i:src_arr_len) Arguments Type Intent Optional Attributes Name real(kind=real64), intent(out), optional, dimension(src_arr_len) :: out_arr output array, e.g. source [50, 75, 0, 100, 25] would lead to out_arr [0, 0, 0, 25, 25] real(kind=real64), intent(in), optional, dimension(src_arr_len) :: src_arr array that holds the original values integer(kind=int32), intent(in), optional, dimension(src_arr_len) :: sorted_src_arr_perm sorted permutation vector, so each index holds the index of the value in src_arr as if src_arr was soted ascending integer(kind=int32), intent(in) :: src_arr_len number elements in src_arr integer(kind=int32), intent(out) :: ierr error code public pure subroutine take_active_mask_helper (subsets, n_mask_chunks, n_subsets, n_results, n_active_masks, n_new_active_masks, active_mask, ierr) For memory efficiency this subroutine helps holding different kinds of masks in a single array.\nTo achieve this, subsets has this structure: [...results, ...active_masks, ...new_active_masks]\nThis routine removes an active mask from the subsets array and returns it in active_mask . Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(inout), dimension(n_mask_chunks, n_subsets) :: subsets working array to hold bitmask encoded subsets for detection. integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks in a mask integer(kind=int32), intent(in) :: n_subsets number of subsets that can be hold integer(kind=int32), intent(in) :: n_results number of results in subsets integer(kind=int32), intent(inout) :: n_active_masks number of active masks in subsets integer(kind=int32), intent(in) :: n_new_active_masks number of new active masks in subsets integer(kind=int32), intent(out), dimension(n_mask_chunks) :: active_mask taken active mask from subsets , will be remove from subsets integer(kind=int32), intent(out) :: ierr error code public pure subroutine add_to_results_helper (subsets, n_mask_chunks, n_subsets, n_results, n_active_masks, n_new_active_masks, result, ierr) For memory efficiency this subroutine helps holding different kinds of masks in a single array.\nTo achieve this, subsets has this structure: [...results, ...active_masks, ...new_active_masks]\nThis routine adds a result mask to subsets array. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(inout), dimension(n_mask_chunks, n_subsets) :: subsets working array to hold bitmask encoded subsets for detection. integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks in a mask integer(kind=int32), intent(in) :: n_subsets number of subsets that can be hold integer(kind=int32), intent(inout) :: n_results number of results in subsets integer(kind=int32), intent(in) :: n_active_masks number of active masks in subsets integer(kind=int32), intent(in) :: n_new_active_masks number of new active masks in subsets integer(kind=int32), intent(in), dimension(n_mask_chunks) :: result result to add to subsets integer(kind=int32), intent(out) :: ierr error code public pure subroutine add_new_active_mask_helper (subsets, n_mask_chunks, n_subsets, n_results, n_active_masks, n_new_active_masks, new_active_mask, ierr) For memory efficiency this subroutine helps holding different kinds of masks in a single array.\nTo achieve this, subsets has this structure: [...results, ...active_masks, ...new_active_masks]\nThis routine adds a new active mask to the subsets array. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out), dimension(n_mask_chunks, n_subsets) :: subsets working array to hold bitmask encoded subsets for detection. integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks in a mask integer(kind=int32), intent(in) :: n_subsets number of subsets that can be hold integer(kind=int32), intent(in) :: n_results number of results in subsets integer(kind=int32), intent(in) :: n_active_masks number of active masks in subsets integer(kind=int32), intent(inout) :: n_new_active_masks number of new active masks in subsets integer(kind=int32), intent(in), dimension(n_mask_chunks) :: new_active_mask new active mask to add to subsets integer(kind=int32), intent(out) :: ierr error code public pure subroutine mask_chunk_count (n_genes, count) This subroutine easily determines the needed chunk count for subset bit masks, as an integer has only 32 bits. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_genes number of genes integer(kind=int32), intent(out) :: count number of 32 bit chunks a mask needs to encode n_genes genes Read more… public pure subroutine filter_paralogs_by_pattern_subfunctionalization (gene_angles, threshold, n_genes, n_families, gene_to_fam, masks, n_mask_chunks, ierr) This subroutine prefilters the genes for subfunctionalization,\nas genes that are already too close in angle to the ancestor don't match the pattern and don't need to be tried as subset extensions. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_genes) :: gene_angles vector, holding the angles between ancestor and genes (0<=angle<=Pi) real(kind=real64), intent(in) :: threshold filter threshold integer(kind=int32), intent(in) :: n_genes number of genes integer(kind=int32), intent(in) :: n_families number of families integer(kind=int32), intent(in), dimension(n_genes) :: gene_to_fam a mapping of gene index to family index, so gene i is related to gene_angles(i) and part of family j=gene_to_fam(i) . integer(kind=int32), intent(out), dimension(n_mask_chunks, n_families) :: masks bit mask that will have indices of genes kept by pattern set to 1, else 0 integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=int32), intent(out) :: ierr error code public pure subroutine filter_paralogs_by_pattern_dosage_effect (gene_angles, threshold, n_genes, n_families, gene_to_fam, masks, n_mask_chunks, ierr) This subroutine prefilters the genes for dosage effect,\nas genes that are already too distant in angle to the ancestor don't match the pattern and don't need to be tried as subset extensions. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_genes) :: gene_angles vector, holding the angles between ancestor and genes (0<=angle<=Pi) real(kind=real64), intent(in) :: threshold filter threshold integer(kind=int32), intent(in) :: n_genes number of genes integer(kind=int32), intent(in) :: n_families number of families integer(kind=int32), intent(in), dimension(n_genes) :: gene_to_fam a mapping of gene index to family index, so gene i is related to gene_angles(i) and part of family j=gene_to_fam(i) . integer(kind=int32), intent(out), dimension(n_mask_chunks, n_families) :: masks bit mask that will have indices of genes kept by pattern set to 1, else 0 integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=int32), intent(out) :: ierr error code public pure subroutine filter_paralogs_by_pattern (pattern, gene_angles, threshold, n_genes, n_families, gene_to_fam, masks, n_mask_chunks, ierr) This subroutine prefilters the genes for a specific pattern to reduce detection overhead, as less subsets need to be tried. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: pattern used pattern for detection Read more… real(kind=real64), intent(in), dimension(n_genes) :: gene_angles vector, holding the angles between ancestor and genes (0<=angle<=Pi) real(kind=real64), intent(in) :: threshold filter threshold integer(kind=int32), intent(in) :: n_genes number of genes integer(kind=int32), intent(in) :: n_families number of families integer(kind=int32), intent(in), dimension(n_genes) :: gene_to_fam a mapping of gene index to family index, so gene i is related to gene_angles(i) and part of family j=gene_to_fam(i) . integer(kind=int32), intent(out), dimension(n_mask_chunks, n_families) :: masks bit mask that will have indices of genes kept by pattern set to 1, else 0 integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=int32), intent(out) :: ierr error code public pure subroutine calc_work_arr_paralog_subsets_size (max_subset_size, n_genes, work_array_size, filtered_paralogs_mask, n_mask_chunks, ierr) The detect_* subroutines need a work array for the to be tested subsets.\nIn worst case, all need to be tried and subsets that cannot be extended will be kept as results.\nThis is the reason why the work array holds the results as well, as all subsets that are stored in the array can be results as well. Read more… Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(inout) :: max_subset_size maximum size that a subset must not exceed. Read more… integer(kind=int32), intent(in) :: n_genes number of genes integer(kind=int32), intent(out) :: work_array_size The calculated needed work array size in absolute worst case scenario. Look into source for details. integer(kind=int32), intent(in), dimension(n_mask_chunks) :: filtered_paralogs_mask Output mask with all genes disabled that did not pass the filter integer(kind=int32), intent(in) :: n_mask_chunks number of 32 bit chunks a mask needs to encode n_genes genes integer(kind=int32), intent(out) :: ierr Error code public pure subroutine mask_set_state (bit_mask, i_gene, state, ierr) Sets the state of a bit/gene in bit_mask Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(out), dimension(:) :: bit_mask chunked mask to mark active paralogs integer(kind=int32), intent(in) :: i_gene index of paralog to be marked active logical, intent(in) :: state state the bit should be set to integer(kind=int32), intent(out) :: ierr error code","tags":"","url":"module/tox_paralog_analysis.html"},{"title":"tox_trajectory_contribution_analysis – TensorOmics","text":"Uses f42_utils safeguard iso_fortran_env tox_errors Variables Type Visibility Attributes Name Initial integer(kind=int32), public, parameter :: BASELINE_RAW = 1 integer(kind=int32), public, parameter :: BASELINE_MIN = 2 integer(kind=int32), public, parameter :: BASELINE_MEAN = 3 Subroutines public  subroutine select_random_sample_helper (n_samples, current_sample, random_sample, ierr) Selects a random sample different to current_sample . For reproducibility call init_random beforehand. Arguments Type Intent Optional Attributes Name integer(kind=int32), intent(in) :: n_samples number of samples integer(kind=int32), intent(in) :: current_sample sample that won't be selected integer(kind=int32), intent(out) :: random_sample selected random sample integer(kind=int32), intent(out) :: ierr Error code public  subroutine perform_permutation_test (trajectories, n_factors, n_samples, n_timepoints, factor_idx, dependent_idx, sample_idx, mode, n_permutations, local_contributions, total_contributions, temp_factor, temp_dependent, ierr, random_seed) For a given factor-dependent pair, this subroutine calculates the contributions by taking the same dependent but from a random different sample. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_factors, n_samples, n_timepoints) :: trajectories expression vectors across different samples over time integer(kind=int32), intent(in) :: n_factors number of factors integer(kind=int32), intent(in) :: n_samples number of samples integer(kind=int32), intent(in) :: n_timepoints number of timepoints integer(kind=int32), intent(in) :: factor_idx index of factor to compute the permutation contributions for integer(kind=int32), intent(in) :: dependent_idx index of dependent to compute the permutation contributions for integer(kind=int32), intent(in) :: sample_idx index of sample to compute the permutation contributions for integer(kind=int32), intent(in) :: mode Baseline mode: 1=RAW, 2=MIN, 3=MEAN integer(kind=int32), intent(in) :: n_permutations number of permutations to perform real(kind=real64), intent(out), dimension(n_timepoints, n_permutations) :: local_contributions Per-timepoint contributions per permutation real(kind=real64), intent(out), dimension(n_permutations) :: total_contributions Total contribution ( sum(local_contributions) ) per permutation real(kind=real64), intent(out), dimension(n_timepoints) :: temp_factor Working array to hold the factor in contiguous memory real(kind=real64), intent(out), dimension(n_timepoints) :: temp_dependent Working array to hold the random dependent in contiguous memory integer(kind=int32), intent(out) :: ierr Error code integer(kind=int32), intent(in), optional :: random_seed Seed to use for random number generation. public pure subroutine compute_p_values (local_contributions_observed, total_contribution_observed, local_contributions_perm, total_contributions_perm, n_timepoints, n_permutations, local_p_values, total_p_value, ierr) Once the permutation tests are calculated ( perform_permutation_test ),\nthis subroutine calculates the p values for the contributions, i.e. how many of the permutation contributions were at least as high as the real contributions. Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_timepoints) :: local_contributions_observed Per-timepoint contributions for the observed factor-dependent-sample combination real(kind=real64), intent(in) :: total_contribution_observed Total contribution ( sum(local_contributions) ) for the observed factor-dependent-sample combination real(kind=real64), intent(in), dimension(n_timepoints, n_permutations) :: local_contributions_perm Per-timepoint contributions for the factor-dependent-random_sample combinations from perform_permutation_test real(kind=real64), intent(in), dimension(n_permutations) :: total_contributions_perm Total contribution ( sum(local_contributions) ) for the factor-dependent-random_sample combinations from perform_permutation_test integer(kind=int32), intent(in) :: n_timepoints number of timepoints integer(kind=int32), intent(in) :: n_permutations number of permutations to perform real(kind=real64), intent(out), dimension(n_timepoints) :: local_p_values calculated p values for local contributions, like: (local_contributions_perm >= local_contributions_observed)/n_permutations real(kind=real64), intent(out) :: total_p_value calculated p values for total contributions, like: (total_contributions_perm >= total_contribution_observed)/n_permutations integer(kind=int32), intent(out) :: ierr Error code public pure subroutine compute_contributions_helper (factor, dependent, n_dims, mode, local_contributions, total_contribution, ierr) This routine performs contribution analysis for a specific factor–dependent pair, no input validation Arguments Type Intent Optional Attributes Name real(kind=real64), intent(in), dimension(n_dims) :: factor Factor time series, length n_timepoints real(kind=real64), intent(in), dimension(n_dims) :: dependent Dependent variable time series, length n_timepoints integer(kind=int32), intent(in) :: n_dims Number of elements in factor and dependent integer(kind=int32), intent(in) :: mode Baseline mode: 1=RAW, 2=MIN, 3=MEAN real(kind=real64), intent(out), dimension(n_dims) :: local_contributions Per-element contributions real(kind=real64), intent(out) :: total_contribution Total contribution ( sum(local_contributions) ) integer(kind=int32), intent(out) :: ierr Error code public pure subroutine compute_contributions (factor, dependent, n_dims, mode, local_contributions, total_contribution, ierr) This routine performs contribution analysis for a specific factor–dependent pair, including input validation Arguments Type Intent Option