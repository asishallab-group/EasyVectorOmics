HECK_IERR_NON_NULL M_CHECK_NON_NULL ( arr_size ) M_CHECK_NON_NULL ( fn_len ) M_CHECK_NON_NULL ( arr ) M_CHECK_NON_NULL ( filename_raw ) call set_ok ( ierr ) ! ASCII to String call c_char_1d_as_string ( filename_raw , filename , ierr ) if (. not . is_ok ( ierr )) return call deserialize_real_flat ( arr , filename , ierr ) end subroutine deserialize_real_nd_C","tags":"","url":"sourcefile/f42_deserialize_real.f90.html"}]}