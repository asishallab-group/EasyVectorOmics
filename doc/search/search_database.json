, input_matrix, output_matrix, ierr) bind(C, name=\"calc_tiss_avg_c\") Uses tox_errors tox_normalization iso_c_binding C-compatible wrapper for calc_tiss_avg Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_gene integer(kind=c_int), intent(in), target :: n_grps integer(kind=c_int), intent(in), target :: group_s (n_grps) integer(kind=c_int), intent(in), target :: group_c (n_grps) real(kind=c_double), intent(in), target :: input_matrix (n_gene*sum(group_c)) real(kind=c_double), intent(out), target :: output_matrix (n_gene*n_grps) integer(kind=c_int), intent(out), target :: ierr","tags":"","url":"proc/calc_tiss_avg_c.html"},{"title":"calc_fchange_c – TensorOmics","text":"pure subroutine calc_fchange_c(n_genes, n_cols, n_pairs, control_cols, cond_cols, i_matrix, o_matrix, ierr) bind(C, name=\"calc_fchange_c\") Uses tox_errors tox_normalization iso_c_binding C-compatible wrapper for calc_fchange Arguments Type Intent Optional Attributes Name integer(kind=c_int), intent(in), target :: n_genes integer(kind=c_int), intent(in), target :: n_cols integer(kind=c_int), intent(in), target :: n_pairs integer(kind=c_int), intent(in), target :: control_cols (n_pairs) integer(kind=c_int), intent(in), target :: cond_cols (n_pairs) real(kind=c_double), intent(in), target :: i_matrix (n_genes*n_cols) real(kind=c_double), intent(out), target :: o_matrix (n_genes*n_pairs) integer(kind=c_int), intent(out), target :: ierr","tags":"","url":"proc/calc_fchange_c.html"},{"title":"normalize_unit_length_c – TensorOmics","text":"pure subroutine normalize_unit_length_c(vector, n_dims, ierr) bind(C, name=\"normalize_unit_length_c\") Uses tox_errors tox_normalization iso_c_binding C-compatible wrapper for normalize_unit_length Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(inout), dimension(n_dims), target :: vector Vector that will be normalized to unit length integer(kind=c_int), intent(in), target :: n_dims number of elements i