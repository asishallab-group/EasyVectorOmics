arget :: factor_baseline Computed baseline for factor real(kind=c_double), intent(out), target :: dependent_baseline Computed baseline for dependent variable integer(kind=c_int), intent(out), target :: ierr Error code","tags":"","url":"proc/compute_baselines_factor_dependent_c.html"},{"title":"perform_permutation_test_c – TensorOmics","text":"subroutine perform_permutation_test_c(trajectories, n_factors, n_samples, n_timepoints, factor_idx, dependent_idx, sample_idx, mode, n_permutations, local_contributions, total_contributions, temp_factor, temp_dependent, ierr, random_seed) bind(C, name=\"perform_permutation_test_c\") Uses tox_errors iso_fortran_env tox_trajectory_contribution_analysis iso_c_binding C-compatible wrapper for perform_permutation_test Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_factors, n_samples, n_timepoints), target :: trajectories expression vectors across different samples over time integer(kind=c_int), intent(in), target :: n_factors number of factors integer(kind=c_int), intent(in), target :: n_samples number of samples integer(kind=c_int), intent(in), target :: n_timepoints number of timepoints integer(kind=c_int), intent(in), target :: factor_idx index of factor to compute the permutation contributions for integer(kind=c_int), intent(in), target :: dependent_idx index of dependent to compute the permutation contributions for integer(kind=c_int), intent(in), target :: sample_idx index of sample to compute the permutation contributions for character(kind=c_char, len=1), intent(in), dimension(*), target :: mode Baseline mode: 1=RAW, 2=MIN, 3=MEAN integer(kind=c_int), intent(in), target :: n_permutations number of permutations to perform real(kind=c_double), intent(out), dimension(n_timepoints, n_permutations), target :: local_contributions Per-timepoint contributions per permutation real(kind=c_double), intent(out), dimension(n_permutations), target :: total_contributions Total contribution ( sum(local_contributions) ) per permutation real(kind=c_double), intent(out), dimension(n_timepoints), target :: temp_factor Working array to hold the factor in contiguous memory real(kind=c_double), intent(out), dimension(n_timepoints), target :: temp_dependent Working array to hold the random dependent in contiguous memory integer(kind=c_int), intent(out), target :: ierr Error code integer(kind=c_int), intent(in), target :: random_seed Seed to use for random number generation.","tags":"","url":"proc/perform_permutation_test_c.html"},{"title":"compute_p_values_c – TensorOmics","text":"pure subroutine compute_p_values_c(local_contributions_observed, total_contribution_observed, local_contributions_perm, total_contributions_perm, n_timepoints, n_permutations, local_p_values, total_p_value, ierr) bind(C, name=\"compute_p_values_c\") Uses tox_errors tox_trajectory_contribution_analysis iso_c_binding C-compatible wrapper for compute_p_values Arguments Type Intent Optional Attributes Name real(kind=c_double), intent(in), dimension(n_timepoints), target :: local_contributions_observed observed local contributions real(kind=c_double), intent(in), target :: total_contribution_observed observed total contribution real(kind=c_double), intent(in), dimension(n_timepoints, n_permutations), target :: local_contributions_perm permutation local contributions real(kind=c_double), intent(in), dimension(n_permutations), target :: total_contributions_perm permutation total contributions integer(kind=c_int), intent(in), target :: n_timepoints number of timepoints integer(kind=c_int), intent(in), target :: n_permutations number of permutations real(kind=c_double), intent(out), dimension(n_timepoints), target :: local_p_values output local p-values real(kind=c_double), intent(out), target :: total_p_value output total p-value integer(kind=c_int), intent(out), target :: ierr error code","tags":"","url":"proc/compute_p_values_c.html"},{"title":"compute_velocity_trajectories_c – TensorOmics","te