    "R BST Index Builder": {
        "prefix": "R_f42:build_bst_index",
        "body": [
            "#' Build BST index (1D)",
            "build_bst_index <- function(x) {",
            "  n <- as.integer(length(x))",
            "  ix <- integer(n)",
            "  stack_left <- integer(n)",
            "  stack_right <- integer(n)",
            "",
            "  res <- .Fortran(\"build_bst_index_r\",",
            "                  as.double(x),",
            "                  as.integer(n),",
            "                  ix,",
            "                  stack_left,",
            "                  stack_right)",
            "  res[[3]]",
            "}"
        ],
        "description": "R-Wrapper for 1D BST index builder"
    },
