    "R KD-Tree Builder": {
        "prefix": "R_f42:build_kd_index",
        "body": [
            "#' Build KD-Tree index (multidimensional)",
            "build_kd_index <- function(X, dim_order) {",
            "  d <- as.integer(nrow(X))",
            "  n <- as.integer(ncol(X))",
            "  kd_ix <- integer(n)",
            "  work <- integer(n)",
            "  subarray <- double(n)",
            "  perm <- integer(n)",
            "  stack_left <- integer(64)",
            "  stack_right <- integer(64)",
            "",
            "  res <- .Fortran(\"build_kd_index_r\",",
            "                  X = as.double(X), ",
            "                  d = d, ",
            "                  n = n, ",
            "                  kd_ix = kd_ix, ",
            "                  dim_order = as.integer(dim_order), ",
            "                  work = work, ",
            "                  subarray = subarray, ",
            "                  perm = perm, ",
            "                  stack_left = stack_left, ",
            "                  stack_right = stack_right)",
            "  res$kd_ix",
            "}"
        ],
        "description": "KD-Tree-Indexing for multidimensional data in R"
