	editor = {Nelson, Karen E},
	month = jul,
	year = {2022},
	pages = {pgac068},
	file = {Volltext:/home/aaron/Zotero/storage/EVNEPB4D/Hajheidari et al. - 2022 - Crop genetic diversity uncovers metabolites, elements, and gene networks predicted to be associated.pdf:application/pdf},
}

