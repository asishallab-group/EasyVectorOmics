# === .env ===

# Compiler optimization flags for gfortran
FPM_FLAGS_GFORTRAN="-O3 -march=native -mtune=native -fopenmp -ffast-math -funroll-loops -ftree-vectorize -fassociative-math"

# Compiler optimization flags for Intel ifx/ifort
FPM_FLAGS_IFX="-O3 -qopenmp -xHost -align array64byte -qopt-zmm-usage=high -qopt-prefetch=3 -qopt-matmul -DUSE_ALIGNED"

# Default memory alignment (in bytes) if detection fails
DEFAULT_ALIGNMENT=32
